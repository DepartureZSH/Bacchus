/* pages/inventory/inventory.wxss */

.inv-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-base);
}

/* ── 搜索栏 ── */
.inv-search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx 12rpx;
}

.inv-search-wrap { flex: 1; position: relative; }

.inv-search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  margin-top: -18rpx;
  font-size: 28rpx;
  z-index: 1;
  line-height: 1;
}

.inv-search-input {
  width: 100%;
  height: 72rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 20rpx 24rpx 20rpx 72rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-placeholder { color: var(--text-muted); }

.scan-btn {
  width: 72rpx; height: 72rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-btn-svg {
  width: 40rpx;
  height: 40rpx;
}

/* ── 扫码选择弹出栏 ── */
.scan-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  padding: 16rpx 32rpx 48rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform var(--dur-base) cubic-bezier(0.32,0.72,0,1);
}

.scan-sheet-show { transform: translateY(0); }

.scan-sheet-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  margin: 16rpx 0 32rpx;
}

.scan-sheet-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scan-option-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  padding: 28rpx 32rpx;
}

.scan-option-btn-out {
  border-color: rgba(224,92,92,0.2);
}

.scan-option-icon { font-size: 48rpx; }

.scan-option-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.scan-option-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.scan-option-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.scan-sheet-cancel {
  margin-top: 20rpx;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--r-lg);
  font-size: 28rpx;
  color: var(--text-secondary);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
}

/* ── 筛选 chips ── */
.filter-scroll { width: 100%; flex-shrink: 0; }

.filter-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: var(--r-full);
  font-size: 24rpx;
  font-weight: 500;
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-secondary);
  background: var(--bg-surface);
  white-space: nowrap;
}

.filter-chip-active {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}

/* ── 统计栏 ── */
.inv-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 0 32rpx 24rpx;
  background: var(--bg-surface);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xl);
  padding: 20rpx 0;
}

.inv-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.inv-stat-divider { width: 1.5rpx; height: 40rpx; background: var(--border-mid); }

.inv-stat-num { font-size: 36rpx; font-weight: 700; color: var(--text-primary); display: block; }
.inv-stat-num.ok     { color: var(--clr-success); }
.inv-stat-num.warn   { color: #e09a3a; }
.inv-stat-num.danger { color: var(--clr-danger); }
.inv-stat-label { font-size: 20rpx; color: var(--text-muted); display: block; }

/* ── 原料列表 ── */
.inv-scroll { flex: 1; }

.ing-list { padding: 0 32rpx; }

.cat-label {
  font-size: 22rpx; font-weight: 700; color: var(--text-muted);
  letter-spacing: 3rpx; padding: 16rpx 0 12rpx; display: block;
}

.ing-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-surface);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-2xl);
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

/* 左侧状态色条（替代 border-left） */
.ing-item::before {
  content: '';
  position: absolute;
  top: 16rpx;
  left: 0;
  width: 3rpx;
  height: calc(100% - 32rpx);
  border-radius: 0 var(--r-xs) var(--r-xs) 0;
  background: var(--border-mid);
}
.ing-item-danger::before { background: var(--clr-danger); }
.ing-item-warn::before   { background: #e09a3a; }
.ing-item-ok::before     { background: var(--border-mid); }

.ing-main {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  min-width: 0;
  padding: 20rpx 0 20rpx 20rpx;
  gap: 20rpx;
}

.ing-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }

.ing-info {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 6rpx;
}

.ing-name  { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.ing-brand { font-size: 22rpx; color: var(--text-muted); display: block; }

.ing-bar-bg { height: 6rpx; background: var(--border-mid); border-radius: 4rpx; margin: 6rpx 0; }
.ing-bar    { height: 6rpx; border-radius: 4rpx; min-width: 4rpx; }
.ing-bar-danger { background: var(--clr-danger); }
.ing-bar-warn   { background: #e09a3a; }
.ing-bar-ok     { background: var(--clr-success); }

.ing-threshold { font-size: 20rpx; color: var(--text-muted); display: block; }

.ing-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-right: 24rpx;
}

.ing-stock { font-size: 36rpx; font-weight: 700; color: var(--text-primary); display: block; }
.ing-stock-danger { color: var(--clr-danger); }
.ing-stock-warn   { color: #e09a3a; }
.ing-unit  { font-size: 22rpx; color: var(--text-muted); display: block; }

/* 空状态 */
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: var(--text-muted); display: block; }

/* ── FAB ── */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 104rpx; height: 104rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-2xl);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: var(--bg-base);
  z-index: 99;
  box-shadow: var(--shadow-gold);
}

/* ── 出库相关 ── */

.scan-out-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-lg);
  padding: 10rpx 18rpx;
  color: var(--gold-main);
  font-size: 28rpx;
}
.scan-btn-icon  { font-size: 28rpx; }
.scan-btn-label { font-size: 24rpx; font-weight: 600; }

.quick-out-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(224,92,92,0.08);
  border: 1.5rpx solid rgba(224,92,92,0.2);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.quick-out-icon {
  font-size: 36rpx;
  color: var(--clr-danger);
  font-weight: 300;
  line-height: 1;
}

/* ── 出库抽屉 ── */
.drawer-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  pointer-events: none;
  transition: background var(--dur-base) var(--ease-smooth);
}
.drawer-mask-show {
  background: rgba(0,0,0,0.6);
  pointer-events: auto;
}

.out-drawer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  padding: 0 32rpx 60rpx;
  max-height: 90vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform var(--dur-base) cubic-bezier(0.32,0.72,0,1);
}
.out-drawer-show { transform: translateY(0); }

.drawer-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: var(--r-full);
  background: var(--border-str);
  margin: 20rpx auto 0;
}

.drawer-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 20rpx;
}
.drawer-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.drawer-close {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: var(--bg-raised);
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--text-secondary);
}

/* 已选原料卡 */
.selected-ing-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.selected-ing-emoji { font-size: 48rpx; flex-shrink: 0; line-height: 1; }
.selected-ing-info  { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.selected-ing-name  { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.selected-ing-stock { font-size: 22rpx; color: var(--text-secondary); display: block; }
.selected-ing-change {
  padding: 10rpx 20rpx;
  border-radius: var(--r-xs);
  background: var(--bg-overlay);
  font-size: 22rpx;
  color: var(--gold-main);
  flex-shrink: 0;
}

/* 原料搜索选择器 */
.ing-picker { margin-bottom: 24rpx; }

.ing-picker-search {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  padding: 0 20rpx;
  margin-bottom: 12rpx;
}
.search-icon-sm { font-size: 26rpx; }
.ing-picker-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  padding: 18rpx 0;
  background: none;
}
.picker-ph { color: var(--text-muted); }

.ing-picker-list {
  max-height: 320rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  overflow: hidden;
}

.picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.picker-item-emoji { font-size: 36rpx; flex-shrink: 0; line-height: 1; }
.picker-item-info  { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.picker-item-name  { font-size: 26rpx; color: var(--text-primary); font-weight: 600; display: block; }
.picker-item-stock { font-size: 22rpx; color: var(--text-secondary); display: block; }
.stock-warn        { color: #e09a3a; }

/* ── 数量区 ── */
.qty-section { margin-bottom: 24rpx; }

.field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.qty-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 300; line-height: 1;
  flex-shrink: 0;
}
.qty-minus { background: rgba(224,92,92,0.1);  color: var(--clr-danger); }
.qty-plus  { background: rgba(76,175,132,0.1); color: var(--clr-success); }

.qty-input {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  height: 72rpx;
  font-weight: 800;
  color: var(--text-primary);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
}

.qty-unit {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  min-width: 48rpx;
}

.qty-preview {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: var(--r-sm);
  background: var(--bg-raised);
}
.qty-preview.danger { background: rgba(224,92,92,0.08); }
.qty-preview.warn   { background: rgba(224,154,58,0.08); }

.qty-preview-label { font-size: 22rpx; color: var(--text-secondary); }
.qty-preview-val   { font-size: 24rpx; font-weight: 700; color: var(--text-primary); }
.qty-preview-warn  { font-size: 22rpx; color: var(--clr-danger); margin-left: 16rpx; }
.qty-preview-warn.warn { color: #e09a3a; }

/* ── 原因选择 ── */
.reason-section { margin-bottom: 24rpx; }

.reason-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.reason-chip {
  padding: 12rpx 24rpx;
  border-radius: var(--r-full);
  font-size: 24rpx;
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-secondary);
  background: var(--bg-raised);
}
.reason-chip-on {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}

.reason-custom-input {
  width: 100%;
  height: auto;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* 错误 & 确认按钮 */
.out-error {
  padding: 14rpx 18rpx;
  background: rgba(224,92,92,0.08);
  border: 1.5rpx solid rgba(224,92,92,0.25);
  border-radius: var(--r-sm);
  font-size: 24rpx;
  color: var(--clr-danger);
  margin-bottom: 16rpx;
}

.out-confirm-btn {
  background: linear-gradient(135deg, var(--clr-danger), #b03a3a);
  border-radius: var(--r-xl);
  padding: 12rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
}
.out-confirm-disabled {
  background: var(--bg-overlay);
  color: var(--text-muted);
}
