/* pages/inventory/inventory.wxss */

.inv-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0d0e12;
}

.inv-search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx 12rpx;
}

.inv-search-wrap { flex: 1; position: relative; }

.inv-search-icon {
  position: absolute;
  left: 24rpx;
  top: 50%;
  margin-top: -18rpx;
  font-size: 28rpx;
  z-index: 1;
  line-height: 1;
}

.inv-search-input {
  width: 100%;
  height: 72rpx;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 24rpx;
  padding: 20rpx 24rpx 20rpx 72rpx;
  color: #f0ede8;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-placeholder { color: #5c5b65; }

.scan-btn {
  width: 72rpx; height: 72rpx;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-btn-svg {
  width: 40rpx;
  height: 40rpx;
}

/* ── 扫码选择弹出栏 ── */
.scan-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #1a1c23;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 32rpx 48rpx;
  box-sizing: border-box;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
}

.scan-sheet-show { transform: translateY(0); }

.scan-sheet-title {
  font-size: 28rpx;
  color: #9a98a0;
  text-align: center;
  margin: 16rpx 0 32rpx;
}

.scan-sheet-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scan-option-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: #16181f;
  border: 2rpx solid #2a2d38;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
}

.scan-option-btn-out {
  border-color: rgba(224,92,92,0.2);
}

.scan-option-icon { font-size: 48rpx; }

.scan-option-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.scan-option-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #f0ede8;
}

.scan-option-desc {
  font-size: 22rpx;
  color: #9a98a0;
}

.scan-sheet-cancel {
  margin-top: 20rpx;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #9a98a0;
  background: #16181f;
  border: 2rpx solid #2a2d38;
}

.filter-scroll { width: 100%; flex-shrink: 0; }

.filter-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid #2a2d38;
  color: #9a98a0;
  background: #16181f;
  white-space: nowrap;
}

.filter-chip-active {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.4);
  color: #c9a96e;
}

.inv-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 0 32rpx 24rpx;
  background: #16181f;
  border: 2rpx solid #2a2d38;
  border-radius: 24rpx;
  padding: 20rpx 0;
}

.inv-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.inv-stat-divider { width: 2rpx; height: 40rpx; background: #2a2d38; }

.inv-stat-num { font-size: 36rpx; font-weight: 700; color: #f0ede8; display: block; }
.inv-stat-num.ok     { color: #4caf84; }
.inv-stat-num.warn   { color: #e09a3a; }
.inv-stat-num.danger { color: #e05c5c; }
.inv-stat-label { font-size: 20rpx; color: #5c5b65; display: block; }

.inv-scroll { flex: 1; }

.ing-list { padding: 0 32rpx; }

.cat-label {
  font-size: 22rpx; font-weight: 700; color: #5c5b65;
  letter-spacing: 3rpx; padding: 16rpx 0 12rpx; display: block;
}

.ing-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  background: #16181f;
  border: 2rpx solid #2a2d38;
  border-radius: 32rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border-left-width: 6rpx;
}

.ing-item-danger { border-left-color: #e05c5c; }
.ing-item-warn   { border-left-color: #e09a3a; }
.ing-item-ok     { border-left-color: #2a2d38; }

.ing-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }

.ing-info {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 6rpx;
}

.ing-name  { font-size: 28rpx; font-weight: 700; color: #f0ede8; display: block; }
.ing-brand { font-size: 22rpx; color: #5c5b65; display: block; }

.ing-bar-bg { height: 6rpx; background: #2a2d38; border-radius: 4rpx; margin: 6rpx 0; }
.ing-bar    { height: 6rpx; border-radius: 4rpx; min-width: 4rpx; }
.ing-bar-danger { background: #e05c5c; }
.ing-bar-warn   { background: #e09a3a; }
.ing-bar-ok     { background: #4caf84; }

.ing-threshold { font-size: 20rpx; color: #5c5b65; display: block; }

.ing-right {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.ing-stock { font-size: 36rpx; font-weight: 700; color: #f0ede8; display: block; }
.ing-stock-danger { color: #e05c5c; }
.ing-stock-warn   { color: #e09a3a; }
.ing-unit  { font-size: 22rpx; color: #5c5b65; display: block; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 20rpx;
}
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: #5c5b65; display: block; }

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 104rpx; height: 104rpx;
  background: linear-gradient(135deg, #c9a96e, #a67c3e);
  border-radius: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #0d0e12;
  z-index: 99;
}

/* ══ 出库相关新增样式 ══ */

/* 扫码按钮区 */
.scan-out-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: rgba(201,169,110,0.12);
  border: 2rpx solid rgba(201,169,110,0.3);
  border-radius: 20rpx;
  padding: 10rpx 18rpx;
  color: #c9a96e;
  font-size: 28rpx;
}
.scan-btn-icon  { font-size: 28rpx; }
.scan-btn-label { font-size: 24rpx; font-weight: 600; }

/* 列表项改造：ing-item 分左主区 + 右出库按钮 */
.ing-item {
  display: flex !important;
  flex-direction: row !important;
  align-items: center !important;
}
.ing-main {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  min-width: 0;
  padding: 20rpx 0 20rpx 20rpx;
  gap: 20rpx;
}

.quick-out-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(224,92,92,0.08);
  border: 2rpx solid rgba(224,92,92,0.2);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}
.quick-out-icon {
  font-size: 36rpx;
  color: #e05c5c;
  font-weight: 300;
  line-height: 1;
}

/* ══ 出库抽屉 ══ */
.drawer-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.25s ease;
}
.drawer-mask-show {
  background: rgba(0,0,0,0.6);
  pointer-events: auto;
}

.out-drawer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #16181f;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx 60rpx;
  max-height: 90vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
}
.out-drawer-show { transform: translateY(0); }

.drawer-handle {
  width: 64rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #2a2d38;
  margin: 20rpx auto 0;
}

.drawer-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 20rpx;
}
.drawer-title { font-size: 32rpx; font-weight: 700; color: #f0ede8; }
.drawer-close {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: #1e2029;
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 28rpx; color: #9a98a0;
}

/* 已选原料卡 */
.selected-ing-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.selected-ing-emoji { font-size: 48rpx; flex-shrink: 0; line-height: 1; }
.selected-ing-info  { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.selected-ing-name  { font-size: 28rpx; font-weight: 700; color: #f0ede8; display: block; }
.selected-ing-stock { font-size: 22rpx; color: #9a98a0; display: block; }
.selected-ing-change {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  background: #2a2d38;
  font-size: 22rpx;
  color: #c9a96e;
  flex-shrink: 0;
}

/* 原料搜索选择器 */
.ing-picker { margin-bottom: 24rpx; }

.ing-picker-search {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 20rpx;
  padding: 0 20rpx;
  margin-bottom: 12rpx;
}
.search-icon-sm { font-size: 26rpx; }
.ing-picker-input {
  flex: 1;
  font-size: 26rpx;
  color: #f0ede8;
  padding: 18rpx 0;
  background: none;
}
.picker-ph { color: #5c5b65; }

.ing-picker-list {
  max-height: 320rpx;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 20rpx;
  overflow: hidden;
}

.picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 24rpx;
  gap: 16rpx;
  border-bottom: 2rpx solid #2a2d38;
}
.picker-item-emoji { font-size: 36rpx; flex-shrink: 0; line-height: 1; }
.picker-item-info  { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.picker-item-name  { font-size: 26rpx; color: #f0ede8; font-weight: 600; display: block; }
.picker-item-stock { font-size: 22rpx; color: #9a98a0; display: block; }
.stock-warn        { color: #e09a3a; }

/* 数量区 */
.qty-section { margin-bottom: 24rpx; }

.field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #9a98a0;
  display: block;
  margin-bottom: 14rpx;
  letter-spacing: 1rpx;
}

.qty-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.qty-btn {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 40rpx; font-weight: 300; line-height: 1;
  flex-shrink: 0;
}
.qty-minus { background: rgba(224,92,92,0.1);  color: #e05c5c; }
.qty-plus  { background: rgba(76,175,132,0.1); color: #4caf84; }

.qty-input {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  height: 72rpx;
  font-weight: 800;
  color: #f0ede8;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 16rpx;
}

.qty-unit {
  font-size: 26rpx;
  color: #9a98a0;
  flex-shrink: 0;
  min-width: 48rpx;
}

.qty-preview {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
  margin-top: 14rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(42,45,56,0.5);
}
.qty-preview.danger { background: rgba(224,92,92,0.08); }
.qty-preview.warn   { background: rgba(224,154,58,0.08); }

.qty-preview-label { font-size: 22rpx; color: #9a98a0; }
.qty-preview-val   { font-size: 24rpx; font-weight: 700; color: #f0ede8; }
.qty-preview-warn  { font-size: 22rpx; color: #e05c5c; margin-left: 16rpx; }
.qty-preview-warn.warn { color: #e09a3a; }

/* 原因选择 */
.reason-section { margin-bottom: 24rpx; }

.reason-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.reason-chip {
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  border: 2rpx solid #2a2d38;
  color: #9a98a0;
  background: #1e2029;
}
.reason-chip-on {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.4);
  color: #c9a96e;
}

.reason-custom-input {
  width: 100%;
  height: auto;
  background: #1e2029;
  border: 2rpx solid #2a2d38;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #f0ede8;
  box-sizing: border-box;
}

/* 错误 & 确认按钮 */
.out-error {
  padding: 14rpx 18rpx;
  background: rgba(224,92,92,0.08);
  border: 2rpx solid rgba(224,92,92,0.25);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #e05c5c;
  margin-bottom: 16rpx;
}

.out-confirm-btn {
  background: linear-gradient(135deg,#e05c5c,#b03a3a);
  border-radius: 24rpx;
  padding: 12rpx;
  text-align: center;
  font-size: 30rpx;
  /* font-weight: 700; */
  color: #fff;
}
.out-confirm-disabled {
  background: #2a2d38;
  color: #5c5b65;
}
