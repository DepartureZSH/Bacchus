/* pages/admin-import/admin-import.wxss */

.import-root {
  background: #0d0e12;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── 空状态 ── */
.import-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  gap: 20rpx;
}
.import-empty-icon { font-size: 96rpx; }
.import-empty-hint {
  font-size: 30rpx;
  font-weight: 600;
  color: #f0ede8;
  text-align: center;
}
.import-empty-sub {
  font-size: 24rpx;
  color: #5c5b65;
  text-align: center;
  line-height: 1.6;
}
.import-file-btn {
  margin-top: 16rpx;
  background: linear-gradient(90deg, #c9a96e, #e8c07a);
  color: #0d0e12;
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 72rpx;
  border-radius: 20rpx;
}

/* ── 解析中 loading ── */
.import-loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}
.import-loading-dots { display: flex; gap: 14rpx; }
.import-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: #c9a96e;
  animation: importBounce 1.4s ease-in-out infinite;
}
.import-dot-1 { animation-delay: 0s; }
.import-dot-2 { animation-delay: 0.2s; }
.import-dot-3 { animation-delay: 0.4s; }
@keyframes importBounce {
  0%,80%,100% { transform: scale(0.6); opacity: 0.4; }
  40%          { transform: scale(1.0); opacity: 1; }
}
.import-loading-txt { font-size: 26rpx; color: #7a7988; }

/* ── 顶栏 ── */
.import-topbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx 16rpx;
  background: #0d0e12;
  border-bottom: 2rpx solid rgba(255,255,255,0.06);
  flex-shrink: 0;
}
.import-topbar-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}
.import-count-txt { font-size: 26rpx; color: #9a99a3; }
.import-count-num { color: #c9a96e; font-weight: 700; }

.import-reselect { padding: 10rpx 0; }
.import-reselect-txt {
  font-size: 24rpx;
  color: #c9a96e;
  border-bottom: 2rpx solid rgba(201,169,110,0.4);
}

/* ── 文件名提示栏 ── */
.import-filename-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.03);
  flex-shrink: 0;
}
.import-filename-icon { font-size: 24rpx; }
.import-filename-txt {
  font-size: 22rpx;
  color: #5c5b65;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* ── 勾选框 ── */
.import-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 3rpx solid rgba(255,255,255,0.2);
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
}
.checkbox-on {
  border-color: #c9a96e;
  background: rgba(201,169,110,0.2);
}
.checkbox-partial {
  border-color: rgba(201,169,110,0.6);
  background: rgba(201,169,110,0.1);
}
.checkbox-tick {
  font-size: 22rpx;
  color: #c9a96e;
  font-weight: 700;
  line-height: 1;
}

/* ── 滚动区 ── */
.import-scroll {
  flex: 1;
  height: 0;  /* flex + height:0 使 scroll-view 可滚动 */
}
.import-card-list {
  padding: 16rpx 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

/* ── 配方卡片 ── */
.import-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  background: #16181f;
  border-radius: 20rpx;
  border: 2rpx solid rgba(255,255,255,0.05);
  border-left: 6rpx solid rgba(255,255,255,0.05);
  transition: border-color 0.15s, background 0.15s;
}
.import-card-on {
  border-left-color: rgba(201,169,110,0.6);
  background: #1a1c24;
}

.import-cb-wrap {
  padding-top: 4rpx;
  flex-shrink: 0;
}

.import-card-body { flex: 1; min-width: 0; }

/* 标题行 */
.import-rc-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.import-rc-emoji {
  font-size: 48rpx;
  flex-shrink: 0;
  line-height: 1;
}
.import-rc-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.import-rc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #f0ede8;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.import-rc-tags {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  flex-wrap: wrap;
}
.import-rc-tag {
  font-size: 20rpx;
  color: #c9a96e;
  background: rgba(201,169,110,0.12);
  border: 2rpx solid rgba(201,169,110,0.25);
  border-radius: 10rpx;
  padding: 3rpx 12rpx;
}
.import-rc-tag-dim {
  color: #7a7988;
  background: rgba(255,255,255,0.05);
  border-color: rgba(255,255,255,0.08);
}

/* 描述 */
.import-rc-desc {
  font-size: 24rpx;
  color: #7a7888;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 原料预览 */
.import-rc-ings {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.import-rc-ing {
  font-size: 22rpx;
  color: #9a99a3;
}
.import-rc-more {
  font-size: 22rpx;
  color: #5c5b65;
}

/* 来源 + 公开标记 */
.import-rc-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}
.import-src-tag {
  font-size: 20rpx;
  color: #5c5b65;
  background: rgba(255,255,255,0.04);
  border: 2rpx solid rgba(255,255,255,0.07);
  border-radius: 8rpx;
  padding: 3rpx 10rpx;
}
.import-pub-badge {
  font-size: 20rpx;
  color: #6cc68a;
  background: rgba(108,198,138,0.1);
  border: 2rpx solid rgba(108,198,138,0.25);
  border-radius: 8rpx;
  padding: 3rpx 10rpx;
}

/* ── 底部操作栏 ── */
.import-action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: rgba(13,14,18,0.96);
  border-top: 2rpx solid rgba(255,255,255,0.06);
  backdrop-filter: blur(16px);
  z-index: 50;
  flex-shrink: 0;
}
.import-action-btn {
  background: linear-gradient(90deg, #c9a96e, #e8c07a);
  color: #0d0e12;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 28rpx;
  border-radius: 20rpx;
}
.import-btn-disabled {
  background: rgba(255,255,255,0.08);
  color: #5c5b65;
}
