/* pages/subscription/subscription.wxss */
.sub-scroll { height: 100vh; background: var(--bg-base); }

/* ════════════════════════════
   当前状态卡
   ════════════════════════════ */
.current-card {
  margin: 24rpx var(--page-x) 20rpx;
  padding: 32rpx;
  position: relative;
  overflow: hidden;
}

/* 金色顶部装饰线 */
.sub-hero-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, var(--gold-bright), var(--gold-dim), transparent);
}

.current-badge {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 24rpx;
  border-radius: var(--r-full);
  margin-bottom: 24rpx;
}
.badge-pro  {
  background: linear-gradient(135deg, var(--gold-bright), var(--gold-dim));
  box-shadow: var(--shadow-gold);
}
.badge-free {
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
}
.current-badge-icon { font-size: 24rpx; color: var(--bg-base); font-weight: 800; }
.current-badge-text { font-size: 26rpx; font-weight: 700; color: var(--bg-base); }
.badge-free .current-badge-icon,
.badge-free .current-badge-text { color: var(--text-secondary); }

.current-expiry {
  font-size: 28rpx; font-weight: 600; color: var(--text-primary);
  display: block; margin-bottom: 16rpx;
}
.free-hint { color: var(--text-secondary); font-weight: 400; font-size: 26rpx; }
.current-sub { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 10rpx; }

/* ── Free 用户三大亮点 ── */
.sub-benefits-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.sub-benefit-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 8rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-md);
}
.sub-benefit-icon {
  font-size: 30rpx;
  color: var(--gold-main);
  font-weight: 700;
  line-height: 1;
  display: block;
}
.sub-benefit-txt {
  font-size: 20rpx;
  color: var(--gold-main);
  text-align: center;
  line-height: 1.4;
  display: block;
}

/* ── 进度条（10rpx）── */
.expiry-bar-bg {
  height: 10rpx;
  background: var(--border-sub);
  border-radius: var(--r-full);
  overflow: hidden;
}
.expiry-bar {
  height: 10rpx;
  background: linear-gradient(90deg, var(--gold-dim), var(--gold-main), var(--clr-success));
  border-radius: var(--r-full);
  transition: width var(--dur-slow) var(--ease-out);
}

.ai-quota-bar { margin-top: 12rpx; }
.ai-quota-label {
  display: flex; flex-direction: row; justify-content: space-between;
  font-size: 22rpx; color: var(--text-secondary); margin-bottom: 10rpx;
}
.ai-quota-bg {
  height: 10rpx;
  background: var(--border-sub);
  border-radius: var(--r-full);
  overflow: hidden;
}
.ai-quota-fill {
  height: 10rpx;
  background: linear-gradient(90deg, var(--gold-dim), var(--gold-main));
  border-radius: var(--r-full);
  transition: width var(--dur-slow) var(--ease-out);
}

/* ════════════════════════════
   Section label
   ════════════════════════════ */
.section-label {
  font-size: 20rpx; font-weight: 700; color: var(--text-disabled);
  letter-spacing: 3rpx; text-transform: uppercase;
  padding: 24rpx var(--page-x) 14rpx; display: block;
}

/* ════════════════════════════
   对比表
   ════════════════════════════ */
.compare-card { margin: 0 var(--page-x) 24rpx; overflow: hidden; }

/* Header：align-items:stretch 让 Pro 列能撑满高度加顶部描边 */
.compare-header {
  display: flex; flex-direction: row; align-items: stretch;
  background: var(--bg-raised);
}
.compare-header .compare-feature-col { padding: 20rpx 28rpx; }
.compare-header .compare-plan-col    { padding: 20rpx 0; }
.compare-header .compare-plan-col-pro {
  background: var(--gold-tint);
  border-top: 3rpx solid var(--gold-main);
}

.compare-divider { height: 1.5rpx; background: var(--border-sub); }

.compare-feature-col { flex: 1; min-width: 0; }
.compare-plan-col {
  width: 140rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 4rpx; flex-shrink: 0;
}
.compare-plan-col-pro { background: var(--gold-tint); }

.plan-name       { font-size: 26rpx; font-weight: 700; color: var(--text-muted); display: block; }
.plan-pro        { color: var(--gold-main); }
.plan-free       { color: var(--text-disabled); }
.plan-price      { font-size: 22rpx; color: var(--text-muted); display: block; }
.plan-price-pro  { color: var(--gold-main); }

.compare-row {
  display: flex; flex-direction: row; align-items: stretch;
}
.compare-row-border { border-bottom: 1.5rpx solid var(--border-sub); }

.compare-row .compare-feature-col { padding: 18rpx 28rpx; }
.compare-row .compare-plan-col    {
  padding: 18rpx 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}

.feature-name { font-size: 26rpx; color: var(--text-primary); display: block; }
.feature-hint { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.compare-val    { font-size: 24rpx; font-weight: 600; text-align: center; display: block; }
.val-ok         { color: var(--clr-success); font-size: 28rpx; }
.val-no         { color: var(--clr-danger); font-size: 28rpx; }
.val-text       { color: var(--text-secondary); font-size: 22rpx; }
.val-text-pro   { color: var(--gold-main); }

/* ════════════════════════════
   套餐卡
   ════════════════════════════ */
.plan-list { padding: 0 var(--page-x); display: flex; flex-direction: column; gap: 16rpx; }

.plan-card {
  padding: 26rpx 28rpx;
  overflow: hidden;
  transition: border-color var(--dur-base) var(--ease-smooth),
              background  var(--dur-base) var(--ease-smooth);
}
.plan-card-selected {
  border-color: var(--gold-main) !important;
  background: var(--gold-tint);
  box-shadow: 0 0 0 1rpx var(--gold-border), var(--shadow-card);
}

/* Header 行：radio + name/tag + price */
.plan-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}
.plan-card-left {
  flex: 1;
  display: flex; flex-direction: row; align-items: center; gap: 12rpx;
}
.plan-card-name { font-size: 30rpx; font-weight: 700; color: var(--text-primary); }

.plan-tag {
  padding: 4rpx 14rpx; border-radius: var(--r-full); font-size: 20rpx; font-weight: 700;
  background: var(--gold-tint); color: var(--gold-main); border: 1.5rpx solid var(--gold-border);
}

.plan-card-price { text-align: right; flex-shrink: 0; }
.plan-orig-price {
  font-size: 22rpx; color: var(--text-disabled);
  text-decoration: line-through; display: block;
}
.plan-card-num   { font-size: 44rpx; font-weight: 800; color: var(--gold-main); display: block; line-height: 1.1; }
.plan-card-period{ font-size: 22rpx; color: var(--text-secondary); display: block; }

.plan-saving {
  margin-top: 12rpx;
  font-size: 22rpx; color: var(--clr-success);
  padding-left: 56rpx; /* indent: radio(40) + gap(16) */
}

/* Inline radio（不再 position:absolute）*/
.plan-radio {
  width: 40rpx; height: 40rpx;
  border-radius: var(--r-full);
  border: 2rpx solid var(--border-mid);
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: border-color var(--dur-base) var(--ease-smooth),
              background  var(--dur-base) var(--ease-smooth);
}
.plan-radio-on  { border-color: var(--gold-main); background: var(--gold-tint); }
.plan-radio-dot { width: 20rpx; height: 20rpx; border-radius: var(--r-full); background: var(--gold-main); }

/* ════════════════════════════
   首单优惠横幅
   ════════════════════════════ */
.promo-banner {
  display: flex; flex-direction: row; align-items: center; gap: 20rpx;
  margin: 16rpx var(--page-x) 0;
  background: rgba(76,175,132,0.07);
  border: 1.5rpx solid rgba(76,175,132,0.20);
  border-radius: var(--r-xl);
  padding: 20rpx 28rpx;
}
.promo-icon  { font-size: 40rpx; flex-shrink: 0; }
.promo-body  { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.promo-title { font-size: 26rpx; font-weight: 700; color: var(--clr-success); display: block; }
.promo-sub   { font-size: 22rpx; color: var(--text-secondary); display: block; }

/* ════════════════════════════
   订阅按钮
   ════════════════════════════ */
.subscribe-area { padding: 24rpx var(--page-x) 0; }
.subscribe-btn {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-full);
  padding: 12rpx 4rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  box-shadow: var(--shadow-gold);
}
.subscribe-btn-text {
  font-size: 34rpx; font-weight: 700; color: var(--bg-base);
  display: block; letter-spacing: 2rpx;
}
.subscribe-btn-sub  { font-size: 22rpx; color: rgba(12,13,16,0.55); display: block; }
.subscribe-hint {
  display: block; text-align: center; font-size: 22rpx;
  color: var(--text-muted); margin-top: 16rpx;
}
.subscribe-btn-disabled { opacity: 0.5; }

.sub-cancel-renew {
  margin-top: 20rpx;
  text-align: center;
  padding: 16rpx;
}
.sub-cancel-renew-txt {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* ════════════════════════════
   Pro 管理区
   ════════════════════════════ */
.manage-card { margin: 0 var(--page-x) 24rpx; overflow: hidden; }
.manage-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 28rpx 28rpx; gap: 16rpx;
}
.manage-divider { height: 1.5rpx; background: var(--border-sub); margin: 0 28rpx; }
.manage-icon  { font-size: 32rpx; flex-shrink: 0; }
.manage-label { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.manage-arrow { font-size: 32rpx; color: var(--text-muted); }
.cancel-text  { color: var(--clr-danger); }
.manage-row-loading { opacity: 0.6; }

.cancel-note {
  display: block; text-align: center; font-size: 22rpx;
  color: var(--text-muted); margin: -8rpx var(--page-x) 24rpx;
}

/* ════════════════════════════
   FAQ
   ════════════════════════════ */
.faq-list { padding: 0 var(--page-x); display: flex; flex-direction: column; gap: 12rpx; }
.faq-card { padding: 0; overflow: hidden; }
.faq-row  {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; padding: 24rpx 28rpx; gap: 16rpx;
}
.faq-q { flex: 1; font-size: 26rpx; color: var(--text-primary); line-height: 1.5; font-weight: 500; }
.faq-arrow {
  font-size: 32rpx; color: var(--text-muted); flex-shrink: 0;
  display: inline-block;
  transition: transform var(--dur-base) var(--ease-smooth),
              color     var(--dur-base) var(--ease-smooth);
}
.faq-open { transform: rotate(90deg); color: var(--gold-main); }
.faq-a {
  font-size: 24rpx; color: var(--text-secondary); line-height: 1.8;
  padding: 16rpx 28rpx 24rpx; display: block;
  border-top: 1.5rpx solid var(--border-sub);
}

/* ════════════════════════════
   离线横幅
   ════════════════════════════ */
.offline-banner {
  margin: 20rpx var(--page-x) 0;
  background: rgba(92,143,214,0.09);
  border: 1.5rpx solid rgba(92,143,214,0.22);
  border-radius: var(--r-md);
  padding: 18rpx 24rpx;
  display: flex; align-items: center; gap: 12rpx;
}
.offline-icon { font-size: 30rpx; }
.offline-text { font-size: 24rpx; color: var(--clr-blue); }

/* ── 有效期行 ── */
.expiry-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12rpx;
}
.days-left-chip {
  font-size: 22rpx; font-weight: 700; color: var(--gold-main);
  background: var(--gold-tint);
  border: 1rpx solid var(--gold-border);
  border-radius: var(--r-full); padding: 4rpx 16rpx;
}
.renew-status-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 12rpx;
}
.auto-renew-chip {
  font-size: 22rpx; border-radius: var(--r-full); padding: 4rpx 14rpx;
}
.chip-on  { color: var(--clr-success); background: rgba(76,175,132,0.12); }
.chip-off { color: var(--text-secondary); background: var(--border-sub); }

.quota-warn { color: var(--clr-danger) !important; font-weight: 700; }
