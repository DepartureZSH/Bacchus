<!-- pages/subscription/subscription.wxml -->
<scroll-view class="sub-scroll" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- 离线提示 -->
  <view wx:if="{{isOffline}}" class="offline-banner">
    <text class="offline-icon">📡</text>
    <text class="offline-text">当前离线，订阅操作需联网</text>
  </view>

  <!-- 当前状态卡 -->
  <view class="current-card card">
    <view class="current-badge badge-{{isPro ? 'pro' : 'free'}}">
      <text class="current-badge-icon">{{isPro ? '✦' : '○'}}</text>
      <text class="current-badge-text">{{isPro ? 'Pro 版' : 'Free 版'}}</text>
    </view>
    <view class="current-info">
      <!-- Pro 状态 -->
      <view wx:if="{{isPro}}">
        <view class="expiry-row">
          <text class="current-expiry">有效期至 {{shopInfo.planExpiry}}</text>
          <text class="days-left-chip">剩 {{daysLeft}} 天</text>
        </view>
        <view class="expiry-bar-bg">
          <view class="expiry-bar" style="width:{{expiryPct}}%"></view>
        </view>
        <view class="renew-status-row">
          <text class="current-sub">本期已使用 {{usedDays}} 天 / 共 {{totalDays}} 天</text>
          <text class="auto-renew-chip {{isAutoRenew ? 'chip-on' : 'chip-off'}}">
            {{isAutoRenew ? '● 续订中' : '○ 已取消续订'}}
          </text>
        </view>
      </view>
      <!-- Free 状态 -->
      <view wx:else>
        <text class="current-expiry free-hint">升级 Pro 解锁无限 AI 生成 · AI 经营建议 · 云端同步</text>
        <view class="ai-quota-bar">
          <view class="ai-quota-label">
            <text>本月 AI 配额</text>
            <text class="{{aiQuotaRemain <= 2 ? 'quota-warn' : ''}}">{{aiUsed}}/{{aiQuotaLimit}} 次</text>
          </view>
          <view class="ai-quota-bg">
            <view class="ai-quota-fill" style="width:{{aiQuotaLimit > 0 ? (aiUsed/aiQuotaLimit*100) : 0}}%"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 对比表格 -->
  <view class="section-label">版本对比</view>
  <view class="compare-card card">
    <view class="compare-header">
      <view class="compare-feature-col"></view>
      <view class="compare-plan-col">
        <text class="plan-name plan-free">Free</text>
        <text class="plan-price">免费</text>
      </view>
      <view class="compare-plan-col compare-plan-col-pro">
        <text class="plan-name plan-pro">✦ Pro</text>
        <text class="plan-price plan-price-pro">¥{{monthlyPrice}}/月起</text>
      </view>
    </view>
    <view class="compare-divider"></view>
    <view wx:for="{{features}}" wx:key="name" class="compare-row {{index < features.length-1 ? 'compare-row-border' : ''}}">
      <view class="compare-feature-col">
        <text class="feature-name">{{item.name}}</text>
        <text wx:if="{{item.hint}}" class="feature-hint">{{item.hint}}</text>
      </view>
      <view class="compare-plan-col">
        <text class="compare-val {{item.free === '✓' ? 'val-ok' : item.free === '✗' ? 'val-no' : 'val-text'}}">{{item.free}}</text>
      </view>
      <view class="compare-plan-col compare-plan-col-pro">
        <text class="compare-val {{item.pro === '✓' ? 'val-ok' : item.pro === '✗' ? 'val-no' : 'val-text val-text-pro'}}">{{item.pro}}</text>
      </view>
    </view>
  </view>

  <!-- 套餐选择（Free 用户 / 续费状态）-->
  <view wx:if="{{!isPro || !isAutoRenew}}">
    <view class="section-label">{{isPro ? '续费套餐' : '选择套餐'}}</view>
    <view class="plan-list">
      <view
        wx:for="{{plans}}" wx:key="id"
        class="plan-card card {{selectedPlan === item.id ? 'plan-card-selected' : ''}}"
        data-id="{{item.id}}" bindtap="onSelectPlan"
      >
        <view class="plan-card-header">
          <view class="plan-card-left">
            <text class="plan-card-name">{{item.name}}</text>
            <view wx:if="{{item.tag}}" class="plan-tag">{{item.tag}}</view>
          </view>
          <view class="plan-card-price">
            <text wx:if="{{item.origPrice && item.origPrice !== item.price}}" class="plan-orig-price">¥{{item.origPrice}}</text>
            <text class="plan-card-num">¥{{item.price}}</text>
            <text class="plan-card-period">/{{item.period}}</text>
          </view>
        </view>
        <view wx:if="{{item.saving}}" class="plan-saving">
          <text>较月付节省 ¥{{item.saving}}</text>
        </view>
        <view class="plan-radio {{selectedPlan === item.id ? 'plan-radio-on' : ''}}">
          <view wx:if="{{selectedPlan === item.id}}" class="plan-radio-dot"></view>
        </view>
      </view>
    </view>

    <view class="promo-banner">
      <text class="promo-icon">🎉</text>
      <view class="promo-body">
        <text class="promo-title">首月 5 折优惠</text>
        <text class="promo-sub">新用户首次订阅立享 5 折，优惠已自动应用</text>
      </view>
    </view>

    <view class="subscribe-area">
      <view class="subscribe-btn {{isSubscribing || isOffline ? 'subscribe-btn-disabled' : ''}}" bindtap="onSubscribe">
        <text wx:if="{{isSubscribing}}" class="subscribe-btn-text">处理中…</text>
        <block wx:else>
          <text class="subscribe-btn-text">{{isPro ? '立即续费' : '立即订阅 Pro'}}</text>
          <text class="subscribe-btn-sub">¥{{selectedPlanObj.price}}/{{selectedPlanObj.period}}</text>
        </block>
      </view>
      <text class="subscribe-hint">{{isOffline ? '⚠ 请联网后操作' : '订阅后可在此页面管理，随时取消'}}</text>
    </view>
  </view>

  <!-- Pro 管理区（已订阅且自动续订中）-->
  <view wx:if="{{isPro && isAutoRenew}}">
    <view class="section-label">管理订阅</view>
    <view class="manage-card card">
      <view class="manage-row" bindtap="onRenew">
        <text class="manage-icon">🔄</text>
        <text class="manage-label">续费 / 升级套餐</text>
        <text class="manage-arrow">›</text>
      </view>
      <view class="manage-divider"></view>
      <view class="manage-row {{isCancelling ? 'manage-row-loading' : ''}}" bindtap="onCancelSub">
        <text class="manage-icon">⏸</text>
        <text class="manage-label">{{isCancelling ? '处理中…' : '取消续订'}}</text>
        <text class="manage-arrow cancel-text">›</text>
      </view>
    </view>
    <text class="cancel-note">取消后当前套餐到期前仍可使用 Pro 功能</text>
  </view>

  <!-- FAQ -->
  <view class="section-label">常见问题</view>
  <view class="faq-list">
    <view wx:for="{{faqs}}" wx:key="id" class="faq-card card" data-id="{{item.id}}" bindtap="onFaq">
      <view class="faq-row">
        <text class="faq-q">{{item.q}}</text>
        <text class="faq-arrow {{expandedFaq === item.id ? 'faq-open' : ''}}">›</text>
      </view>
      <text wx:if="{{expandedFaq === item.id}}" class="faq-a">{{item.a}}</text>
    </view>
  </view>

  <view style="height:80rpx"></view>
</scroll-view>
