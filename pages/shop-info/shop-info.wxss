/* pages/shop-info/shop-info.wxss */
.page-scroll { height: 100vh; background: var(--bg-base); }

/* ── 头像区 ── */
.shop-avatar-area {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0 36rpx;
}
.shop-avatar {
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-2xl);
  background: linear-gradient(135deg, var(--gold-bright), var(--gold-dim));
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 80rpx; margin-bottom: 16rpx;
  box-shadow: var(--shadow-gold);
}
.shop-avatar-hint { font-size: 22rpx; color: var(--text-disabled); }

/* ── 表单 ── */
.form-section { margin: 0 var(--page-x) 20rpx; overflow: hidden; }
.form-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 28rpx 28rpx; gap: 16rpx; min-height: 96rpx;
}
.form-divider { height: 1.5rpx; background: var(--border-sub); margin: 0 28rpx; }
.form-label {
  font-size: 26rpx; color: var(--text-secondary);
  min-width: 140rpx; flex-shrink: 0; display: block;
}
.form-label-required::before { content: '* '; color: var(--clr-danger); }
.form-input {
  flex: 1; font-size: 28rpx; color: var(--text-primary);
  text-align: right; background: none;
}
.form-placeholder { color: var(--text-disabled); }

/* ── Section label ── */
.section-label {
  font-size: 20rpx; font-weight: 700; color: var(--text-disabled);
  letter-spacing: 3rpx; text-transform: uppercase;
  padding: 24rpx var(--page-x) 12rpx; display: block;
}

/* ── 信息只读区 ── */
.info-section { margin: 0 var(--page-x) 20rpx; overflow: hidden; }
.info-row {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; padding: 28rpx 28rpx;
}
.info-divider { height: 1.5rpx; background: var(--border-sub); margin: 0 28rpx; }
.info-key  { font-size: 28rpx; color: var(--text-secondary); }
.info-val  { font-size: 28rpx; color: var(--text-primary); font-weight: 600; }
.info-link { font-size: 26rpx; color: var(--gold-main); }

/* ── 错误提示 ── */
.error-bar {
  margin: 0 var(--page-x) 16rpx; padding: 16rpx 24rpx;
  border-radius: var(--r-md);
  background: rgba(224,92,92,0.08); border: 1.5rpx solid rgba(224,92,92,0.25);
  font-size: 26rpx; color: var(--clr-danger);
}

.submit-area { padding: 8rpx var(--page-x) 0; }
