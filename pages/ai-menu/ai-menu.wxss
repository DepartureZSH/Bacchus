/* ══════════════════════════════════════════════
   历史图片区
══════════════════════════════════════════════ */

.mktg-history-header {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; margin-bottom: 16rpx;
}
.mktg-history-loading-txt { font-size: 22rpx; color: #5c5b65; }

.mktg-history-empty { padding: 8rpx 0; }
.mktg-history-empty text { font-size: 24rpx; color: #5c5b65; }

/* 横向滚动容器 */
/* .mktg-history-scroll { overflow: hidden; } */
.mktg-history-row {
  display: flex; flex-direction: column;
  gap: 16rpx; width: 100%; padding-bottom: 4rpx;
}

/* 单张图片容器 */
.mktg-history-item {
  width: 100%; 
  height: auto;
  flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.mktg-history-item-cover .mktg-history-img-wrap {
  border-color: #c9a96e;
}

/* 图片外框 */
.mktg-history-img-wrap {
  /* width: 100%;  */
  height: auto;
  border-radius: 16rpx; 
  /* overflow: hidden; */
  /* border: 3rpx solid #2a2d38; 
  background: #1e2029; */
  position: relative;
}

/* 图片本体 */
.mktg-history-img {
  border-radius: 16rpx;
  border: 3rpx solid #2a2d38; 
} 
/* 海报图（3:4）：让竖图在方形容器里居中显示 */
/* .mktg-history-img-poster {
  border: 3rpx solid #2a2d38; 
} */

/* 加载占位 */
.mktg-history-loading-img {
  display: flex; align-items: center; justify-content: center;
}
.mktg-history-loading-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #c9a96e; opacity: 0.5;
  animation: mlBounce 1.4s ease-in-out infinite;
}

/* 角标 */
.mktg-history-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  background: rgba(201,169,110,0.9); color: #0d0e12;
  font-size: 18rpx; font-weight: 700;
  border-radius: 8rpx; padding: 3rpx 10rpx;
}
.mktg-history-badge-poster {
  background: rgba(154,100,214,0.85); color: #fff;
}

/* 放大提示（右下角） */
.mktg-history-zoom {
  position: absolute; bottom: 6rpx; right: 6rpx;
  font-size: 20rpx; opacity: 0.7;
}

/* 风格标签 */
.mktg-history-style {
  font-size: 20rpx; color: #5c5b65; text-align: center; display: block;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  width: 100%;
}

/* 操作按钮行 */
.mktg-history-actions {
  display: flex; flex-direction: row; gap: 8rpx; width: 100%;
}
.mktg-history-act {
  flex: 1; text-align: center; font-size: 20rpx; font-weight: 600;
  padding: 8rpx 0; border-radius: 10rpx;
  border: 2rpx solid #2a2d38; background: #1e2029; color: #9a98a0;
}
.mktg-history-act-cover {
  background: rgba(201,169,110,0.1);
  border-color: rgba(201,169,110,0.35); color: #c9a96e;
}
.mktg-history-act-save {
  background: rgba(92,143,214,0.1);
  border-color: rgba(92,143,214,0.3); color: #5c8fd6;
}
.mktg-history-act-del {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.25); color: #e05c5c;
}

/* ── Bug2: Canvas 完全隐藏（仅用于导出）── */
.mktg-canvas-hidden {
  position: absolute; opacity: 0; pointer-events: none;
  width: 375px; height: 500px; top: -9999rpx; left: -9999rpx;
}

/* ── Bug3: 编辑面板新增样式 ── */

/* 单品/封面图：风格快选 */
.edit-style-row {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 12rpx; margin-bottom: 4rpx;
}
.edit-style-chip {
  padding: 10rpx 20rpx; border-radius: 20rpx;
  background: #1e2029; border: 2rpx solid #2a2d38;
  font-size: 22rpx; color: #9a98a0; font-weight: 500;
}
.edit-style-chip-on {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.45); color: #c9a96e;
}

/* 重新生成按钮 */
.edit-regen-btn {
  margin-top: 20rpx;
  background: rgba(201,169,110,0.1);
  border: 2rpx solid rgba(201,169,110,0.4);
  border-radius: 18rpx; padding: 20rpx 0;
  text-align: center; font-size: 28rpx;
  color: #c9a96e; font-weight: 700;
}

/* ── 历史图：编辑按钮 ── */
.mktg-history-act-edit {
  background: rgba(154,100,214,0.1);
  border-color: rgba(154,100,214,0.3); color: #9a64d6;
}
.mktg-history-act-edit-on {
  background: rgba(154,100,214,0.22);
  border-color: rgba(154,100,214,0.6); color: #b882ff;
}

/* ── 编辑面板：正在编辑哪张图的提示条 ── */
.edit-target-hint {
  display: flex; flex-direction: row; align-items: center; gap: 12rpx;
  background: rgba(154,100,214,0.08);
  border: 2rpx solid rgba(154,100,214,0.25);
  border-radius: 14rpx; padding: 14rpx 18rpx; margin-bottom: 20rpx;
}
.edit-target-icon { font-size: 28rpx; flex-shrink: 0; }
.edit-target-txt  { font-size: 22rpx; color: #b882ff; line-height: 1.5; }

