/* pages/ai-menu/ai-menu.wxss — AI创作页全量样式 */

/* ══ 根容器 ══ */
.page-root {
  display: flex; flex-direction: column;
  background: var(--bg-base); overflow: hidden;
}

/* ══ 顶部 Tab 栏 ══ */
.top-tab-bar {
  display: flex; flex-direction: row;
  background: var(--bg-base);
  border-bottom: 1.5rpx solid var(--border-sub);
  flex-shrink: 0; padding: 0 16rpx;
}
.top-tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx;
  padding: 0rpx 0 12rpx;
  position: relative;
}
.top-tab-icon  { font-size: 32rpx; line-height: 1; }
.top-tab-label { font-size: 20rpx; color: var(--text-muted); margin-top: 6rpx; font-weight: 600; }
.top-tab-active .top-tab-label { color: var(--gold-main); }
.top-tab-line  {
  position: absolute; bottom: 0; left: 25%; right: 25%;
  height: 3rpx;
  background: linear-gradient(to right, transparent, var(--gold-main), transparent);
  border-radius: var(--r-full);
}

/* ══ Tab 内容区 ══ */
.tab-scroll { flex: 1; overflow: hidden; }

/* ══════════════════════════════════════════════
   Tab1: AI 酒单
══════════════════════════════════════════════ */

.ai-form-card { margin: 24rpx 32rpx 28rpx; padding: 32rpx; }
.ai-form-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); margin-bottom: 28rpx; display: block; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 24rpx; color: var(--text-secondary); font-weight: 600; margin-bottom: 16rpx; display: block; }
.option-row { display: flex; flex-direction: row; flex-wrap: wrap; gap: 14rpx; }
.option-chip {
  padding: 14rpx 28rpx; border-radius: var(--r-full); font-size: 26rpx; font-weight: 500;
  border: 1.5rpx solid var(--border-mid); color: var(--text-secondary); background: var(--bg-raised);
}
.option-chip-active {
  background: var(--gold-tint);
  border-color: var(--gold-border); color: var(--gold-main);
}
.ai-gen-btn { margin-top: 8rpx; }
.quota-bar { margin-top: 24rpx; }
.quota-bar-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.quota-label { font-size: 22rpx; color: var(--text-muted); }
.quota-num   { font-size: 22rpx; color: var(--gold-main); font-weight: 600; }
.quota-num-warn { color: var(--clr-danger); }
.quota-track { height: 6rpx; background: var(--border-mid); border-radius: var(--r-full); overflow: hidden; }
.quota-fill { height: 100%; background: var(--gold-main); border-radius: var(--r-full); }
.quota-fill-warn { background: var(--clr-danger); }
.quota-pro { display: flex; justify-content: center; }
.quota-pro-text { font-size: 22rpx; color: var(--gold-main); }
.btn-loading { opacity: 0.75; }
.skeleton-wrap { padding: 0 32rpx; }
.skeleton-card { padding: 32rpx; margin-bottom: 24rpx; }
.sk-line {
  background: linear-gradient(90deg, var(--bg-overlay) 25%, var(--border-str) 50%, var(--bg-overlay) 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
  border-radius: var(--r-xs); margin-bottom: 16rpx;
}
.sk-line-title { height: 32rpx; width: 55%; }
.sk-line-tags  { height: 24rpx; width: 35%; }
.sk-price-row  { display: flex; gap: 16rpx; margin-top: 20rpx; }
.sk-price-block {
  flex: 1; height: 60rpx; border-radius: var(--r-xs);
  background: linear-gradient(90deg, var(--bg-overlay) 25%, var(--border-str) 50%, var(--bg-overlay) 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
}

.section-header { display: flex; align-items: center; justify-content: space-between; padding: 8rpx 32rpx 16rpx; }
.section-title  { font-size: 28rpx; font-weight: 700; color: var(--text-primary); }
.section-link   { font-size: 24rpx; color: var(--gold-main); }
.section-header-right { display: flex; align-items: center; gap: 16rpx; }
.cache-badge { font-size: 20rpx; color: var(--text-secondary); background: var(--bg-overlay); padding: 4rpx 12rpx; border-radius: var(--r-full); }
.cocktail-card { margin: 0 32rpx 20rpx; overflow: hidden; }
.cocktail-header { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; }
.cocktail-header-left { display: flex; flex-direction: row; align-items: center; gap: 20rpx; flex: 1; }
.cocktail-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }
.cocktail-name  { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 10rpx; }
.cocktail-tags  { display: flex; flex-direction: row; gap: 10rpx; flex-wrap: wrap; }
.expand-arrow   { font-size: 28rpx; color: var(--text-muted); flex-shrink: 0; padding-left: 12rpx; }
.price-row { display: flex; flex-direction: row; align-items: center; padding: 0 32rpx 28rpx; border-bottom: 1.5rpx solid var(--border-mid); }
.price-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.price-divider { width: 1.5rpx; height: 48rpx; background: var(--border-mid); }
.price-label { font-size: 22rpx; color: var(--text-muted); display: block; }
.price-val   { font-size: 32rpx; font-weight: 700; color: var(--text-primary); display: block; }
.price-val-accent { color: var(--gold-main); }
.price-val-ok     { color: var(--clr-success); }
.cocktail-detail  { padding: 24rpx 32rpx 32rpx; border-top: 1.5rpx solid var(--border-mid); display: flex; flex-direction: column; gap: 28rpx; }
.detail-block     { display: flex; flex-direction: column; gap: 14rpx; }
.detail-block-title { font-size: 24rpx; font-weight: 700; color: var(--text-secondary); display: block; }
.ing-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 8rpx 0; }
.ing-row-left { display: flex; flex-direction: row; align-items: center; gap: 14rpx; }
.ing-status-dot { width: 12rpx; height: 12rpx; border-radius: var(--r-full); flex-shrink: 0; }
.dot-ok      { background: var(--clr-success); }
.dot-missing { background: var(--clr-danger); }
.ing-row-name   { font-size: 26rpx; color: var(--text-primary); }
.ing-row-amount { font-size: 26rpx; color: var(--text-secondary); flex-shrink: 0; }
.substitute-hint {
  display: flex; flex-direction: row; align-items: flex-start; gap: 12rpx;
  background: var(--gold-tint); border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-md); padding: 16rpx 20rpx; margin-top: 8rpx;
}
.sub-icon { font-size: 26rpx; flex-shrink: 0; }
.sub-text { font-size: 24rpx; color: var(--gold-main); line-height: 1.6; }

/* step-row / step-num / step-text — 继承自 app.wxss */
/* notes-text — 继承自 app.wxss */
.notes-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  background: rgba(76,175,132,0.06);
  border: 1.5rpx solid rgba(76,175,132,0.2);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
}

.ai-empty   { display: flex; flex-direction: column; align-items: center; padding: 120rpx 60rpx; gap: 20rpx; }
.ai-empty-icon  { font-size: 100rpx; display: block; }
.ai-empty-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); display: block; text-align: center; }
.ai-empty-sub   { font-size: 26rpx; color: var(--text-secondary); text-align: center; line-height: 1.8; display: block; }
.card-action-row { display: flex; flex-direction: row; gap: 16rpx; margin-top: 28rpx; padding-top: 24rpx; border-top: 1.5rpx solid var(--border-mid); }
.card-action-btn { flex: 1; display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 10rpx; padding: 20rpx 0; border-radius: var(--r-lg); border: 1.5rpx solid transparent; }
.card-action-save { background: var(--gold-tint); border-color: var(--gold-border); }
.card-action-save .card-action-icon  { color: var(--gold-main); font-size: 28rpx; font-weight: 700; }
.card-action-save .card-action-label { color: var(--gold-main); font-size: 24rpx; font-weight: 600; }
.card-action-done { background: rgba(76,175,132,0.08); border-color: rgba(76,175,132,0.3); }
.card-action-done .card-action-icon  { color: var(--clr-success); font-size: 28rpx; font-weight: 700; }
.card-action-done .card-action-label { color: var(--clr-success); font-size: 24rpx; font-weight: 600; }
.card-action-loading { opacity: 0.5; }
.card-action-coll { background: rgba(92,143,214,0.08); border-color: rgba(92,143,214,0.3); }
.card-action-coll .card-action-icon  { font-size: 26rpx; }
.card-action-coll .card-action-label { color: var(--clr-blue); font-size: 24rpx; font-weight: 600; }
.card-action-icon  { flex-shrink: 0; }
.card-action-label { flex-shrink: 0; }

/* ══════════════════════════════════════════════
   Tab2: AI 营销
══════════════════════════════════════════════ */

.mktg-root   { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
.mktg-scroll { flex: 1; }

/* 模式切换 */
.mktg-mode-bar {
  display: flex; flex-direction: row; gap: 12rpx;
  margin: 20rpx 28rpx 4rpx; flex-shrink: 0;
}
.mktg-mode-btn {
  flex: 1; text-align: center; padding: 18rpx 0;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md); font-size: 26rpx; color: var(--text-secondary); font-weight: 600;
}
.mktg-mode-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.45); color: var(--gold-main);
}

/* Section 标题 */
.mktg-section       { padding: 24rpx 28rpx 4rpx; }
.mktg-section-title { font-size: 24rpx; font-weight: 700; color: var(--text-secondary); display: block; margin-bottom: 16rpx; }

/* 加载 / 空态 */
.mktg-list-loading     { padding: 20rpx 0; }
.mktg-list-loading-txt { font-size: 24rpx; color: var(--text-muted); }
.mktg-empty-hint       { padding: 12rpx 0; }
.mktg-empty-hint text  { font-size: 24rpx; color: var(--text-muted); }

/* 搜索栏 */
.mktg-search-bar {
  display: flex; flex-direction: row; align-items: center;
  gap: 12rpx; margin-bottom: 16rpx;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full); padding: 16rpx 20rpx;
}
.mktg-search-icon { font-size: 28rpx; flex-shrink: 0; opacity: 0.6; }
.mktg-search-input {
  flex: 1; font-size: 26rpx; color: var(--text-primary); background: transparent;
  min-height: 40rpx; line-height: 40rpx;
}
.mktg-search-ph { color: var(--text-disabled); font-size: 26rpx; }

/* 快速筛选 */
.mktg-filter-scroll { overflow: hidden; margin-bottom: 16rpx; }
.mktg-filter-row {
  display: flex; flex-direction: row; gap: 12rpx;
  width: max-content; padding-bottom: 2rpx;
}
.mktg-filter-chip {
  padding: 10rpx 24rpx; border-radius: var(--r-full); flex-shrink: 0;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  font-size: 24rpx; color: var(--text-secondary); font-weight: 500;
}
.mktg-filter-chip-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.45); color: var(--gold-main);
}
.mktg-filter-empty { margin-top: 4rpx; margin-bottom: 8rpx; }

/* 目标选择器（横向滚动卡片） */
.mktg-pick-scroll { overflow: hidden; }
.mktg-pick-row    { display: flex; flex-direction: row; gap: 16rpx; width: max-content; padding-bottom: 4rpx; }
.mktg-pick-card   {
  width: 180rpx; flex-shrink: 0;
  background: var(--bg-raised); border: 2rpx solid var(--border-mid);
  border-radius: var(--r-xl); overflow: hidden;
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 16rpx; position: relative;
}
.mktg-pick-on { border-color: var(--gold-main); background: var(--gold-tint); }
.mktg-pick-img-wrap { width: 100%; height: 160rpx; overflow: hidden; }
.mktg-pick-img      { width: 100%; height: 100%; display: block; }
.mktg-pick-emoji-wrap {
  width: 100%; height: 160rpx;
  background: var(--bg-base); display: flex; align-items: center; justify-content: center;
}
.mktg-pick-emoji { font-size: 56rpx; }
.mktg-pick-name  { font-size: 24rpx; color: var(--text-primary); font-weight: 600; text-align: center; margin-top: 12rpx; padding: 0 12rpx; line-height: 1.3; }
.mktg-pick-sub   { font-size: 20rpx; color: var(--text-muted); margin-top: 4rpx; }
.mktg-pick-check {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 36rpx; height: 36rpx; border-radius: var(--r-full);
  background: var(--gold-main); color: var(--bg-base);
  font-size: 22rpx; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}

/* 已选目标简介 */
.mktg-target-preview {
  display: flex; flex-direction: row; align-items: center;
  gap: 20rpx; margin: 12rpx 28rpx; padding: 20rpx 24rpx;
}
.mktg-target-emoji { font-size: 52rpx; flex-shrink: 0; }
.mktg-target-info  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.mktg-target-name  { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.mktg-target-desc  { font-size: 22rpx; color: var(--text-muted); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* 营销图类型 */
.mktg-type-row { display: flex; flex-direction: row; gap: 14rpx; }
.mktg-type-card {
  flex: 1; background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg); padding: 20rpx 12rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.mktg-type-on  { background: var(--gold-tint); border-color: rgba(201,164,90,0.5); }
.mktg-type-emoji { font-size: 36rpx; }
.mktg-type-label { font-size: 24rpx; font-weight: 700; color: var(--text-primary); }
.mktg-type-desc  { font-size: 19rpx; color: var(--text-muted); text-align: center; }

/* 风格横向滑动 */
.mktg-style-scroll { overflow: hidden; }
.mktg-style-row    { display: flex; flex-direction: row; gap: 16rpx; width: max-content; padding-bottom: 4rpx; }
.mktg-style-card   {
  width: 160rpx; flex-shrink: 0;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xl); padding: 20rpx 16rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx; position: relative;
}
.mktg-style-on { background: var(--gold-tint); border-color: rgba(201,164,90,0.55); }
.mktg-style-emoji  { font-size: 40rpx; line-height: 1; }
.mktg-style-label  { font-size: 24rpx; font-weight: 700; color: var(--text-primary); text-align: center; display: block; }
.mktg-style-desc   { font-size: 20rpx; color: var(--text-muted); text-align: center; display: block; }
.mktg-style-check  {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 32rpx; height: 32rpx; border-radius: var(--r-full);
  background: var(--gold-main); font-size: 20rpx; color: var(--bg-base); font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}

/* 补充描述输入 */
.mktg-custom-input {
  width: 100%; min-height: 80rpx;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md); padding: 18rpx 20rpx;
  font-size: 26rpx; color: var(--text-primary); line-height: 1.6;
  box-sizing: border-box; display: block;
}
.mktg-custom-ph { color: var(--text-disabled); font-size: 26rpx; }

/* 生成按钮 */
.mktg-gen-btn {
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  gap: 12rpx; margin-top: 20rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-lg); padding: 28rpx 0;
  box-shadow: var(--shadow-gold);
}
.mktg-gen-disabled { opacity: 0.5; }
.mktg-gen-icon  { font-size: 30rpx; color: var(--bg-base); }
.mktg-gen-label { font-size: 30rpx; font-weight: 700; color: var(--bg-base); }

/* 查看/编辑历史图入口 */
.mktg-view-edit-btn {
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  gap: 10rpx; margin-top: 16rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-lg); padding: 22rpx 0;
}
.mktg-view-edit-icon  { font-size: 28rpx; }
.mktg-view-edit-label { font-size: 26rpx; font-weight: 600; color: var(--gold-main); }

/* 生成中动画 */
.mktg-loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 40rpx 40rpx; gap: 20rpx;
}
.mktg-loading-dots { display: flex; flex-direction: row; gap: 14rpx; align-items: center; }
.ml-dot {
  width: 16rpx; height: 16rpx; border-radius: var(--r-full);
  background: var(--gold-main); animation: mlBounce 1.4s ease-in-out infinite;
}
.ml-dot-1 { animation-delay: 0s; }
.ml-dot-2 { animation-delay: 0.2s; }
.ml-dot-3 { animation-delay: 0.4s; }
@keyframes mlBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%           { transform: scale(1.2); opacity: 1; }
}
.mktg-loading-step { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; text-align: center; }
.mktg-loading-hint { font-size: 22rpx; color: var(--text-muted); display: block; text-align: center; }

/* Canvas */
.mktg-canvas        { display: block; width: 100%; border-radius: var(--r-md); }
.mktg-canvas-square { aspect-ratio: 1 / 1; }
.mktg-canvas-poster { aspect-ratio: 3 / 4; }

/* 结果区 */
.mktg-result-wrap { display: flex; flex-direction: column; padding: 0 28rpx; gap: 16rpx; }

.mktg-img-wrap        { align-self: center; position: relative; width: fit-content; border-radius: var(--r-md); overflow: hidden; aspect-ratio: 1 / 1; }
.mktg-img-wrap-poster { aspect-ratio: 3 / 4; }

/* 放大提示 */
.mktg-img-zoom-hint {
  position: absolute; bottom: 16rpx; right: 16rpx;
  display: flex; flex-direction: row; align-items: center; gap: 6rpx;
  background: rgba(0,0,0,0.45); border-radius: var(--r-full); padding: 6rpx 16rpx;
}
.mktg-img-zoom-icon { font-size: 22rpx; }
.mktg-img-zoom-txt  { font-size: 20rpx; color: rgba(255,255,255,0.8); }

/* 操作栏 */
.mktg-action-bar {
  display: flex; flex-direction: row; gap: 12rpx;
}
.mktg-action-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx; padding: 20rpx 0;
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
}
.mktg-action-icon  { font-size: 32rpx; }
.mktg-action-label { font-size: 20rpx; color: var(--text-secondary); }

.mktg-action-save  { background: var(--gold-tint); border-color: var(--gold-border); }
.mktg-action-save .mktg-action-icon  { color: var(--gold-main); }
.mktg-action-save .mktg-action-label { color: var(--gold-main); }

.mktg-action-share { background: rgba(92,143,214,0.1); border-color: rgba(92,143,214,0.35); }
.mktg-action-share .mktg-action-icon  { color: var(--clr-blue); }
.mktg-action-share .mktg-action-label { color: var(--clr-blue); }

.mktg-action-edit  { background: rgba(154,100,214,0.1); border-color: rgba(154,100,214,0.3); }
.mktg-action-edit .mktg-action-icon  { color: #9a64d6; font-size: 28rpx; }
.mktg-action-edit .mktg-action-label { color: #9a64d6; }

.mktg-action-regen .mktg-action-icon  { color: var(--text-secondary); }

/* 在线编辑面板 */
.edit-panel       { padding: 28rpx; display: flex; flex-direction: column; gap: 0; }
.edit-panel-title { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; margin-bottom: 6rpx; }
.edit-hint        { font-size: 20rpx; color: var(--text-muted); display: block; margin-bottom: 20rpx; }

.edit-field-row   {
  display: flex; flex-direction: row; align-items: center;
  padding: 16rpx 0; border-bottom: 1.5rpx solid var(--bg-raised);
}
.edit-field-label { font-size: 24rpx; color: var(--text-secondary); width: 96rpx; flex-shrink: 0; }
.edit-field-input { flex: 1; font-size: 26rpx; color: var(--text-primary); background: transparent; }

.edit-section-label { font-size: 22rpx; color: var(--text-secondary); display: block; margin: 20rpx 0 10rpx; }
.edit-cocktail-row  { display: flex; flex-direction: row; align-items: center; gap: 12rpx; padding: 10rpx 0; border-bottom: 1.5rpx solid var(--bg-raised); }
.edit-cocktail-num  { font-size: 22rpx; color: var(--text-muted); width: 28rpx; flex-shrink: 0; }
.edit-cocktail-name { flex: 1; font-size: 24rpx; color: var(--text-primary); background: transparent; }
.edit-cocktail-price{ width: 100rpx; font-size: 24rpx; color: var(--gold-main); background: transparent; text-align: right; }

/* 错误态 */
.mktg-error-wrap  { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 60rpx 40rpx; }
.mktg-error-icon  { font-size: 64rpx; }
.mktg-error-msg   { font-size: 26rpx; color: var(--text-secondary); text-align: center; line-height: 1.6; display: block; }
.mktg-error-retry {
  background: var(--gold-tint); border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-md); padding: 18rpx 48rpx;
  font-size: 26rpx; color: var(--gold-main); font-weight: 600;
}

/* ══════════════════════════════════════════════
   历史图片区
══════════════════════════════════════════════ */

.mktg-history-header {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; margin-bottom: 16rpx;
}
.mktg-history-loading-txt { font-size: 22rpx; color: var(--text-muted); }
.mktg-history-empty { padding: 8rpx 0; }
.mktg-history-empty text { font-size: 24rpx; color: var(--text-muted); }

.mktg-history-row {
  display: flex; flex-direction: column;
  gap: 16rpx; width: 100%; padding-bottom: 4rpx;
}

/* 单张图片容器 */
.mktg-history-item {
  width: 100%;
  height: auto;
  flex-shrink: 0;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.mktg-history-item-cover .mktg-history-img-wrap {
  border-color: var(--gold-main);
}

/* 图片外框 */
.mktg-history-img-wrap {
  height: auto;
  border-radius: var(--r-md);
  position: relative;
}

/* 图片本体 */
.mktg-history-img {
  border-radius: var(--r-md);
  border: 2rpx solid var(--border-mid);
}

/* 加载占位 */
.mktg-history-loading-img {
  display: flex; align-items: center; justify-content: center;
}
.mktg-history-loading-dot {
  width: 16rpx; height: 16rpx; border-radius: var(--r-full);
  background: var(--gold-main); opacity: 0.5;
  animation: mlBounce 1.4s ease-in-out infinite;
}

/* 角标 */
.mktg-history-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  background: rgba(201,164,90,0.9); color: var(--bg-base);
  font-size: 18rpx; font-weight: 700;
  border-radius: var(--r-xs); padding: 3rpx 10rpx;
}
.mktg-history-badge-poster {
  background: rgba(154,100,214,0.85); color: #fff;
}

/* 放大提示（右下角） */
.mktg-history-zoom {
  position: absolute; bottom: 6rpx; right: 6rpx;
  font-size: 20rpx; opacity: 0.7;
}

/* 风格标签 */
.mktg-history-style {
  font-size: 20rpx; color: var(--text-muted); text-align: center; display: block;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  width: 100%;
}

/* 操作按钮行 */
.mktg-history-actions {
  display: flex; flex-direction: row; gap: 8rpx; width: 100%;
}
.mktg-history-act {
  flex: 1; text-align: center; font-size: 20rpx; font-weight: 600;
  padding: 8rpx 0; border-radius: var(--r-xs);
  border: 1.5rpx solid var(--border-mid); background: var(--bg-raised); color: var(--text-secondary);
}
.mktg-history-act-cover {
  background: var(--gold-tint);
  border-color: var(--gold-border); color: var(--gold-main);
}
.mktg-history-act-save {
  background: rgba(92,143,214,0.1);
  border-color: rgba(92,143,214,0.3); color: var(--clr-blue);
}
.mktg-history-act-del {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.25); color: var(--clr-danger);
}

/* Canvas 隐藏容器（仅用于导出） */
.mktg-canvas-hidden {
  position: absolute; opacity: 0; pointer-events: none;
  width: 375px; height: 500px; top: -9999rpx; left: -9999rpx;
}

/* 单品/封面图：风格快选 */
.edit-style-row {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 12rpx; margin-bottom: 4rpx;
}
.edit-style-chip {
  padding: 10rpx 20rpx; border-radius: var(--r-full);
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  font-size: 22rpx; color: var(--text-secondary); font-weight: 500;
}
.edit-style-chip-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.45); color: var(--gold-main);
}

/* 重新生成按钮 */
.edit-regen-btn {
  margin-top: 20rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-lg); padding: 20rpx 0;
  text-align: center; font-size: 28rpx;
  color: var(--gold-main); font-weight: 700;
}

/* 历史图：编辑按钮 */
.mktg-history-act-edit {
  background: rgba(154,100,214,0.1);
  border-color: rgba(154,100,214,0.3); color: #9a64d6;
}
.mktg-history-act-edit-on {
  background: rgba(154,100,214,0.22);
  border-color: rgba(154,100,214,0.6); color: #b882ff;
}

/* 编辑面板：正在编辑哪张图的提示条 */
.edit-target-hint {
  display: flex; flex-direction: row; align-items: center; gap: 12rpx;
  background: rgba(154,100,214,0.08);
  border: 1.5rpx solid rgba(154,100,214,0.25);
  border-radius: var(--r-sm); padding: 14rpx 18rpx; margin-bottom: 20rpx;
}
.edit-target-icon { font-size: 28rpx; flex-shrink: 0; }
.edit-target-txt  { font-size: 22rpx; color: #b882ff; line-height: 1.5; }

/* ══ Tab3: AI采购 ══ */
.purch-summary { /* extends .card — margin + padding set via inline style on element */ }
.purch-summary-row { display:flex;flex-direction:row;align-items:center; }
.purch-summary-item { flex:1;display:flex;flex-direction:column;align-items:center;gap:8rpx; }
.purch-summary-divider { width:1.5rpx;height:48rpx;background:var(--border-mid); }
.purch-summary-num { font-size:46rpx;font-weight:800;color:var(--text-primary);display:block;line-height:1; }
.purch-num-warn   { color:#e09a3a; }
.purch-num-accent { color:var(--gold-main);font-size:34rpx; }
.purch-summary-label { font-size:22rpx;color:var(--text-muted);display:block; }
.purch-summary-meta { margin-top:20rpx;padding-top:16rpx;border-top:1.5rpx solid var(--border-mid); }
.purch-summary-meta-txt { font-size:22rpx;color:var(--text-muted);display:block; }
.purch-action-bar { display:flex;flex-direction:row;gap:16rpx;margin:0 28rpx 16rpx; }
.purch-btn { flex:1;padding:22rpx;border-radius:var(--r-lg);font-size:26rpx;font-weight:600;text-align:center; }
.purch-btn-copy { background:linear-gradient(145deg,var(--gold-bright),var(--gold-dim));color:var(--bg-base); box-shadow:var(--shadow-gold); }
.purch-btn-refresh { background:var(--bg-raised);color:var(--text-secondary);border:1.5rpx solid var(--border-mid); }
.purch-filter-row { display:flex;flex-direction:row;gap:14rpx;padding:0 28rpx 16rpx;flex-wrap:wrap; }
.purch-filter-chip { padding:10rpx 24rpx;border-radius:var(--r-full);font-size:24rpx;font-weight:500;border:1.5rpx solid var(--border-mid);color:var(--text-secondary);background:var(--bg-surface); }
.purch-filter-chip-on { background:var(--gold-tint);border-color:var(--gold-border);color:var(--gold-main); }
.purch-loading { padding:40rpx 28rpx;text-align:center; }
.purch-loading-txt { font-size:24rpx;color:var(--text-muted); }
.purch-empty { display:flex;flex-direction:column;align-items:center;padding:100rpx 0;gap:16rpx; }
.purch-empty-icon  { font-size:80rpx;display:block; }
.purch-empty-title { font-size:30rpx;font-weight:600;color:var(--text-primary);display:block; }
.purch-empty-sub   { font-size:24rpx;color:var(--text-muted);display:block; }
.purch-list { padding:0 28rpx; }
.purch-item { display:flex;flex-direction:row;align-items:center;gap:16rpx;padding:20rpx 20rpx;margin-bottom:14rpx;border-left-width:4rpx;border-left-color:var(--border-mid); }
.purch-item-urgent { border-left-color:var(--clr-danger); }
.purch-item-left { flex:1;display:flex;flex-direction:column;gap:8rpx;min-width:0; }
.purch-item-top  { display:flex;flex-direction:row;align-items:center;gap:14rpx; }
.purch-emoji { font-size:44rpx;flex-shrink:0;line-height:1; }
.purch-info  { flex:1;display:flex;flex-direction:column;gap:4rpx; }
.purch-name-row { display:flex;flex-direction:row;align-items:center;gap:10rpx;flex-wrap:wrap; }
.purch-name  { font-size:28rpx;font-weight:700;color:var(--text-primary); }
.purch-brand { font-size:22rpx;color:var(--text-muted);display:block; }
.purch-urgent-badge { background:rgba(224,92,92,0.15);color:var(--clr-danger);border:1.5rpx solid rgba(224,92,92,0.3);border-radius:var(--r-xs);padding:2rpx 10rpx;font-size:20rpx;font-weight:700;flex-shrink:0; }
.purch-stock-hint { padding-left:4rpx; }
.purch-stock-txt  { font-size:20rpx;color:var(--text-disabled);display:block; }
.purch-source-tags { display:flex;flex-direction:row;gap:10rpx;flex-wrap:wrap;margin-top:8rpx; }
.purch-source-tag  { padding:3rpx 12rpx;border-radius:var(--r-xs);font-size:19rpx;font-weight:600; }
.purch-source-warn { background:rgba(224,92,92,0.1);color:var(--clr-danger); }
.purch-source-ai   { background:var(--gold-tint);color:var(--gold-main); }
.purch-source-new  { background:rgba(76,175,132,0.1);color:var(--clr-success); }
.purch-item-right { display:flex;flex-direction:row;align-items:center;gap:20rpx;flex-shrink:0; }
.purch-amount-col { display:flex;flex-direction:column;align-items:center;gap:4rpx; }
.purch-amount-row { display:flex;flex-direction:row;align-items:center;gap:10rpx; }
.purch-minus,.purch-plus { width:44rpx;height:44rpx;background:var(--bg-raised);border:1.5rpx solid var(--border-mid);border-radius:var(--r-xs);display:flex;align-items:center;justify-content:center;font-size:28rpx;color:var(--text-secondary); }
.purch-amount-wrap { text-align:center;min-width:72rpx; }
.purch-amount { font-size:28rpx;font-weight:700;color:var(--text-primary);display:block; }
.purch-unit   { font-size:20rpx;color:var(--text-muted);display:block; }
.purch-cost   { font-size:22rpx;color:var(--gold-main);display:block; }
.purch-check { width:44rpx;height:44rpx;border-radius:var(--r-full);border:2rpx solid var(--border-str);display:flex;align-items:center;justify-content:center;font-size:24rpx;color:transparent; }
.purch-check-done { background:var(--clr-success);border-color:var(--clr-success);color:white; }
.purch-checked-section { margin:8rpx 28rpx 0; }
.purch-checked-header { display:flex;flex-direction:row;align-items:center;justify-content:space-between;padding:16rpx 0; }
.purch-checked-title { font-size:26rpx;font-weight:600;color:var(--text-muted); }
.purch-checked-arrow { font-size:24rpx;color:var(--text-muted); }
.purch-item-done { opacity:0.5;border-left-color:var(--clr-success); }
.purch-name-done { text-decoration:line-through;color:var(--text-muted); }
.purch-amount-done { font-size:24rpx;color:var(--text-muted);flex:1;text-align:right; }

/* 模式切换 */
.purch-mode-bar { display:flex;flex-direction:row;gap:16rpx;padding:20rpx 28rpx 8rpx; }
.purch-mode-chip { flex:1;text-align:center;padding:14rpx 0;border-radius:var(--r-full);font-size:26rpx;font-weight:600;border:1.5rpx solid var(--border-mid);color:var(--text-secondary);background:var(--bg-surface); }
.purch-mode-chip-on { background:var(--gold-tint);border-color:var(--gold-border);color:var(--gold-main); }

/* 按酒单模式：合集选择 */
.purch-coll-label { font-size:22rpx;font-weight:600;color:var(--text-secondary);letter-spacing:2rpx;padding:16rpx 28rpx 10rpx;text-transform:uppercase; }
.purch-coll-empty { margin:0 28rpx;padding:24rpx;background:var(--bg-surface);border-radius:var(--r-md);border:1.5rpx dashed var(--border-mid); }
.purch-coll-empty-txt { font-size:24rpx;color:var(--text-muted);text-align:center;display:block; }
.purch-coll-scroll { padding-left:20rpx; }
.purch-coll-row { display:flex;flex-direction:row;gap:16rpx;padding:4rpx 8rpx 12rpx; }
.purch-coll-card { display:flex;flex-direction:column;align-items:center;gap:8rpx;padding:20rpx 24rpx;background:var(--bg-raised);border-radius:var(--r-xl);border:1.5rpx solid var(--border-mid);min-width:160rpx;flex-shrink:0; }
.purch-coll-card-on { background:var(--gold-tint);border-color:var(--gold-border); }
.purch-coll-emoji { font-size:40rpx; }
.purch-coll-name { font-size:24rpx;font-weight:600;color:var(--text-primary);max-width:160rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block; }
.purch-coll-count { font-size:20rpx;color:var(--text-secondary); }
.purch-coll-hint { padding:32rpx 28rpx;text-align:center; }
.purch-coll-hint-txt { font-size:26rpx;color:var(--text-muted); }

/* 按钮：去清单 */
.purch-btn-list { background:rgba(76,175,132,0.12);color:var(--clr-success);border:1.5rpx solid rgba(76,175,132,0.3); }
.purch-list-badge { font-weight:700; }

/* 角标：新原料 */
.purch-new-badge { background:rgba(76,175,132,0.15);color:var(--clr-success);font-size:19rpx;font-weight:600;padding:2rpx 10rpx;border-radius:var(--r-xs); }

/* 购物车图标按钮 */
.cart-btn-svg { width:45rpx;height:45rpx; }

/* ══ AI 酒单：自定义提示词输入 ══ */
.form-label-hint { font-size:22rpx;color:var(--text-muted);font-weight:400;margin-left:8rpx; }
.menu-custom-prompt {
  width:100%; min-height:80rpx;
  background:var(--bg-raised); border:1.5rpx solid var(--border-mid);
  border-radius:var(--r-sm); padding:18rpx 20rpx;
  font-size:26rpx; color:var(--text-primary);
  box-sizing:border-box; line-height:1.6;
}
.menu-custom-ph { color:var(--text-disabled); }

/* ══════════════════════════════════════════════
   Tab4: 经营分析
══════════════════════════════════════════════ */

/* 时间切换 */
.anal-period-row { display:flex;flex-direction:row;gap:12rpx;padding:20rpx 28rpx 16rpx;flex-wrap:wrap; }
.anal-period-chip { padding:12rpx 32rpx;border-radius:var(--r-full);font-size:26rpx;font-weight:600;border:1.5rpx solid var(--border-mid);color:var(--text-secondary);background:var(--bg-raised); }
.anal-period-chip-on { background:var(--gold-tint);border-color:var(--gold-border);color:var(--gold-main); }

/* 加载条 */
.anal-loading-bar { margin:0 28rpx 16rpx;background:var(--gold-tint);border-radius:var(--r-md);padding:14rpx 24rpx;text-align:center; }
.anal-loading-bar-txt { font-size:24rpx;color:var(--gold-main); }

/* 核心指标 2×2 网格 */
.anal-metric-grid { display:flex;flex-direction:row;flex-wrap:wrap;gap:12rpx;margin:0 28rpx 20rpx; }
.anal-metric-card { width:calc(50% - 6rpx);padding:24rpx;box-sizing:border-box; }
.anal-metric-label { font-size:22rpx;color:var(--text-secondary);display:block;margin-bottom:10rpx; }
.anal-metric-value { font-size:44rpx;font-weight:800;color:var(--text-primary);line-height:1;display:block; }
.anal-metric-unit  { font-size:22rpx;font-weight:400;color:var(--text-secondary);margin-left:4rpx; }
.anal-metric-trend { font-size:22rpx;margin-top:10rpx;display:block; }
.anal-trend-up   { color:var(--clr-success); }
.anal-trend-down { color:var(--clr-danger); }

/* Section 标题行 */
.anal-section-header { display:flex;flex-direction:row;align-items:center;justify-content:space-between;padding:8rpx 28rpx 16rpx; }
.anal-section-title  { font-size:22rpx;font-weight:700;color:var(--text-secondary);letter-spacing:2rpx;text-transform:uppercase; }

/* 图表卡片 */
.anal-chart-card { margin:0 28rpx 20rpx;padding:24rpx;overflow:hidden; }
.anal-chart-legend { display:flex;flex-direction:row;justify-content:center;gap:32rpx;padding-top:16rpx; }
.anal-legend-item  { display:flex;flex-direction:row;align-items:center;gap:8rpx; }
.anal-legend-dot   { width:16rpx;height:16rpx;border-radius:var(--r-full); }
.anal-legend-label { font-size:22rpx;color:var(--text-secondary); }
.anal-chart-empty  { margin-top:-20rpx;text-align:center;padding-bottom:16rpx; }
.anal-chart-empty-txt { font-size:22rpx;color:var(--text-disabled); }

/* 原料排行榜 */
.anal-rank-card { margin:0 28rpx 20rpx;padding:0 28rpx; }
.anal-rank-item { display:flex;flex-direction:row;align-items:center;padding:24rpx 0;gap:16rpx; }
.anal-rank-item-border { border-bottom:1.5rpx solid var(--border-sub); }
.anal-rank-num { width:44rpx;height:44rpx;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:22rpx;font-weight:800;flex-shrink:0; }
.anal-rank-num-1 { background:rgba(201,164,90,0.2);color:var(--gold-main); }
.anal-rank-num-2 { background:rgba(76,175,132,0.15);color:var(--clr-success); }
.anal-rank-num-3 { background:rgba(154,152,160,0.12);color:var(--text-secondary); }
.anal-rank-info { flex:1;display:flex;flex-direction:column;gap:4rpx;min-width:0; }
.anal-rank-name { font-size:26rpx;font-weight:700;color:var(--text-primary);display:block; }
.anal-rank-sub  { font-size:22rpx;color:var(--text-muted);display:block; }
.anal-rank-bar-wrap { width:80rpx;height:8rpx;background:var(--border-mid);border-radius:var(--r-full);flex-shrink:0;overflow:hidden; }
.anal-rank-bar { height:8rpx;border-radius:var(--r-full); }

/* 空态 */
.anal-empty-hint { padding:36rpx 0;display:flex;flex-direction:column;align-items:center;gap:12rpx;color:var(--text-muted);font-size:26rpx; }
.anal-empty-sub  { font-size:22rpx;color:var(--text-disabled);text-align:center;line-height:1.6; }

/* 骨架屏动画 */
.anal-skeleton-pulse { animation:skPulse 1.4s ease-in-out infinite; }
@keyframes skPulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.anal-skeleton-list { padding:16rpx 0;display:flex;flex-direction:column;gap:20rpx; }
.anal-skeleton-row { height:40rpx;border-radius:var(--r-xs);background:linear-gradient(90deg,var(--bg-raised) 25%,var(--bg-overlay) 50%,var(--bg-raised) 75%);background-size:200% 100%;animation:shimmer 1.4s infinite; }

/* AI经营建议区 */
.anal-advice-header { align-items:center; }
.anal-advice-refresh { width:52rpx;height:52rpx;border-radius:var(--r-full);background:var(--gold-tint);display:flex;align-items:center;justify-content:center;font-size:30rpx;color:var(--gold-main); }
.anal-advice-refresh-loading { animation:spin 1s linear infinite; }
@keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
.anal-pro-badge { font-size:20rpx;font-weight:700;color:var(--gold-main);background:var(--gold-tint);border:1.5rpx solid var(--gold-border);border-radius:var(--r-xs);padding:4rpx 10rpx; }

/* AI建议触发器卡片 */
.anal-advice-trigger { margin:0 28rpx 20rpx;display:flex;align-items:center;gap:20rpx;padding:28rpx; }
.anal-advice-trigger-icon  { font-size:36rpx;flex-shrink:0;color:var(--gold-main); }
.anal-advice-trigger-body  { flex:1; }
.anal-advice-trigger-title { font-size:26rpx;font-weight:700;color:var(--text-primary);display:block; }
.anal-advice-trigger-sub   { font-size:22rpx;color:var(--text-secondary);display:block;margin-top:6rpx; }
.anal-advice-trigger-arrow { font-size:32rpx;color:var(--text-muted); }
.anal-advice-sk-list { margin-top:12rpx;display:flex;flex-direction:column;gap:12rpx; }

/* AI建议列表 */
.anal-advice-list { padding:0 28rpx;display:flex;flex-direction:column;gap:16rpx;margin-bottom:4rpx; }
.anal-advice-card { display:flex;flex-direction:row;align-items:flex-start;gap:20rpx;padding:28rpx; }
.anal-advice-warn { border-left:3rpx solid var(--clr-danger); }
.anal-advice-icon  { font-size:40rpx;flex-shrink:0;line-height:1.2; }
.anal-advice-body  { flex:1;display:flex;flex-direction:column;gap:8rpx; }
.anal-advice-title { font-size:26rpx;font-weight:700;color:var(--text-primary);display:block; }
.anal-advice-text  { font-size:24rpx;color:var(--text-secondary);line-height:1.7;display:block; }

/* 错误态 */
.anal-advice-error { margin:0 28rpx 20rpx;padding:24rpx 28rpx;display:flex;align-items:center;justify-content:space-between; }
.anal-advice-error-txt { font-size:24rpx;color:var(--text-secondary); }
.anal-advice-retry { font-size:24rpx;color:var(--gold-main);background:var(--gold-tint);border-radius:var(--r-xs);padding:8rpx 20rpx; }

/* Pro升级 upsell */
.anal-upsell { margin:0 28rpx 20rpx;display:flex;align-items:center;justify-content:space-between;padding:24rpx 28rpx;border:1.5rpx solid var(--gold-border); }
.anal-upsell-left  { display:flex;align-items:center;gap:16rpx;flex:1; }
.anal-upsell-icon  { font-size:36rpx;flex-shrink:0; }
.anal-upsell-body  { flex:1;display:flex;flex-direction:column;gap:6rpx; }
.anal-upsell-title { font-size:26rpx;font-weight:700;color:var(--text-primary);display:block; }
.anal-upsell-sub   { font-size:22rpx;color:var(--text-secondary);display:block; }
.anal-upsell-cta   { font-size:24rpx;font-weight:700;color:var(--bg-base);background:var(--gold-main);border-radius:var(--r-md);padding:10rpx 24rpx;flex-shrink:0; }
