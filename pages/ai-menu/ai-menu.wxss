/* pages/ai-menu/ai-menu.wxss — AI创作页全量样式 */

/* ══ 根容器 ══ */
.page-root {
  display: flex; flex-direction: column;
  background: #0d0e12; overflow: hidden;
}

/* ══ 顶部 Tab 栏 ══ */
.top-tab-bar {
  display: flex; flex-direction: row;
  background: #0d0e12;
  border-bottom: 2rpx solid #1e2029;
  flex-shrink: 0; padding: 0 16rpx;
}
.top-tab-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx;
  padding: 0rpx 0 12rpx;
  position: relative;
}
.top-tab-icon  { font-size: 32rpx; line-height: 1; }
.top-tab-label { font-size: 20rpx; color: #5c5b65; margin-top: 6rpx; font-weight: 600; }
.top-tab-active .top-tab-label { color: #c9a96e; }
.top-tab-line  {
  position: absolute; bottom: 0; left: 25%; right: 25%;
  height: 4rpx; background: #c9a96e; border-radius: 2rpx;
}

/* ══ Tab 内容区 ══ */
.tab-scroll { flex: 1; overflow: hidden; }

/* ══════════════════════════════════════════════
   Tab1: AI 酒单（保留原有样式）
══════════════════════════════════════════════ */

.ai-form-card { margin: 24rpx 32rpx 28rpx; padding: 32rpx; }
.ai-form-title { font-size: 30rpx; font-weight: 700; color: #f0ede8; margin-bottom: 28rpx; display: block; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 24rpx; color: #9a98a0; font-weight: 600; margin-bottom: 16rpx; display: block; }
.option-row { display: flex; flex-direction: row; flex-wrap: wrap; gap: 14rpx; }
.option-chip {
  padding: 14rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; font-weight: 500;
  border: 2rpx solid #2a2d38; color: #9a98a0; background: #1e2029;
}
.option-chip-active { background: rgba(201,169,110,0.12); border-color: rgba(201,169,110,0.4); color: #c9a96e; }
.ai-gen-btn { margin-top: 8rpx; }
.quota-bar { margin-top: 24rpx; }
.quota-bar-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.quota-label { font-size: 22rpx; color: #6b6a74; }
.quota-num   { font-size: 22rpx; color: #c9a96e; font-weight: 600; }
.quota-num-warn { color: #e05c5c; }
.quota-track { height: 6rpx; background: #2a2d38; border-radius: 3rpx; overflow: hidden; }
.quota-fill { height: 100%; background: #c9a96e; border-radius: 3rpx; }
.quota-fill-warn { background: #e05c5c; }
.quota-pro { display: flex; justify-content: center; }
.quota-pro-text { font-size: 22rpx; color: #c9a96e; }
.btn-loading { opacity: 0.75; }
.skeleton-wrap { padding: 0 32rpx; }
.skeleton-card { padding: 32rpx; margin-bottom: 24rpx; }
.sk-line {
  background: linear-gradient(90deg, #2a2d38 25%, #32354a 50%, #2a2d38 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
  border-radius: 8rpx; margin-bottom: 16rpx;
}
.sk-line-title { height: 32rpx; width: 55%; }
.sk-line-tags  { height: 24rpx; width: 35%; }
.sk-price-row  { display: flex; gap: 16rpx; margin-top: 20rpx; }
.sk-price-block {
  flex: 1; height: 60rpx; border-radius: 8rpx;
  background: linear-gradient(90deg, #2a2d38 25%, #32354a 50%, #2a2d38 75%);
  background-size: 200% 100%; animation: shimmer 1.4s infinite;
}
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
.section-header { display: flex; align-items: center; justify-content: space-between; padding: 8rpx 32rpx 16rpx; }
.section-title  { font-size: 28rpx; font-weight: 700; color: #f0ede8; }
.section-link   { font-size: 24rpx; color: #c9a96e; }
.section-header-right { display: flex; align-items: center; gap: 16rpx; }
.cache-badge { font-size: 20rpx; color: #9a98a0; background: #2a2d38; padding: 4rpx 12rpx; border-radius: 20rpx; }
.cocktail-card { margin: 0 32rpx 20rpx; overflow: hidden; }
.cocktail-header { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; }
.cocktail-header-left { display: flex; flex-direction: row; align-items: center; gap: 20rpx; flex: 1; }
.cocktail-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }
.cocktail-name  { font-size: 32rpx; font-weight: 700; color: #f0ede8; display: block; margin-bottom: 10rpx; }
.cocktail-tags  { display: flex; flex-direction: row; gap: 10rpx; flex-wrap: wrap; }
.expand-arrow   { font-size: 28rpx; color: #5c5b65; flex-shrink: 0; padding-left: 12rpx; }
.price-row { display: flex; flex-direction: row; align-items: center; padding: 0 32rpx 28rpx; border-bottom: 2rpx solid #2a2d38; }
.price-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.price-divider { width: 2rpx; height: 48rpx; background: #2a2d38; }
.price-label { font-size: 22rpx; color: #5c5b65; display: block; }
.price-val   { font-size: 32rpx; font-weight: 700; color: #f0ede8; display: block; }
.price-val-accent { color: #c9a96e; }
.price-val-ok     { color: #4caf84; }
.cocktail-detail  { padding: 24rpx 32rpx 32rpx; border-top: 2rpx solid #2a2d38; display: flex; flex-direction: column; gap: 28rpx; }
.detail-block     { display: flex; flex-direction: column; gap: 14rpx; }
.detail-block-title { font-size: 24rpx; font-weight: 700; color: #9a98a0; display: block; }
.ing-row { display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 8rpx 0; }
.ing-row-left { display: flex; flex-direction: row; align-items: center; gap: 14rpx; }
.ing-status-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.dot-ok      { background: #4caf84; }
.dot-missing { background: #e05c5c; }
.ing-row-name   { font-size: 26rpx; color: #f0ede8; }
.ing-row-amount { font-size: 26rpx; color: #9a98a0; flex-shrink: 0; }
.substitute-hint { display: flex; flex-direction: row; align-items: flex-start; gap: 12rpx; background: rgba(201,169,110,0.07); border: 2rpx solid rgba(201,169,110,0.2); border-radius: 16rpx; padding: 16rpx 20rpx; margin-top: 8rpx; }
.sub-icon { font-size: 26rpx; flex-shrink: 0; }
.sub-text { font-size: 24rpx; color: #c9a96e; line-height: 1.6; }
.step-row { display: flex; flex-direction: row; align-items: flex-start; gap: 16rpx; }
.step-num { width: 40rpx; height: 40rpx; background: #1e2029; border-radius: 50%; display: flex; flex-direction: row; align-items: center; justify-content: center; font-size: 22rpx; color: #c9a96e; font-weight: 700; flex-shrink: 0; margin-top: 2rpx; }
.step-text { font-size: 26rpx; color: #f0ede8; line-height: 1.6; }
.notes-row  { background: rgba(76,175,132,0.06); border: 2rpx solid rgba(76,175,132,0.2); border-radius: 16rpx; padding: 16rpx 20rpx; }
.notes-text { font-size: 24rpx; color: #4caf84; line-height: 1.6; }
.ai-empty   { display: flex; flex-direction: column; align-items: center; padding: 120rpx 60rpx; gap: 20rpx; }
.ai-empty-icon  { font-size: 100rpx; display: block; }
.ai-empty-title { font-size: 32rpx; font-weight: 600; color: #f0ede8; display: block; text-align: center; }
.ai-empty-sub   { font-size: 26rpx; color: #9a98a0; text-align: center; line-height: 1.8; display: block; }
.card-action-row { display: flex; flex-direction: row; gap: 16rpx; margin-top: 28rpx; padding-top: 24rpx; border-top: 2rpx solid #2a2d38; }
.card-action-btn { flex: 1; display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 10rpx; padding: 20rpx 0; border-radius: 20rpx; border: 2rpx solid transparent; }
.card-action-save { background: rgba(201,169,110,0.09); border-color: rgba(201,169,110,0.35); }
.card-action-save .card-action-icon  { color: #c9a96e; font-size: 28rpx; font-weight: 700; }
.card-action-save .card-action-label { color: #c9a96e; font-size: 24rpx; font-weight: 600; }
.card-action-done { background: rgba(76,175,132,0.08); border-color: rgba(76,175,132,0.3); }
.card-action-done .card-action-icon  { color: #4caf84; font-size: 28rpx; font-weight: 700; }
.card-action-done .card-action-label { color: #4caf84; font-size: 24rpx; font-weight: 600; }
.card-action-loading { opacity: 0.5; }
.card-action-coll { background: rgba(92,143,214,0.08); border-color: rgba(92,143,214,0.3); }
.card-action-coll .card-action-icon  { font-size: 26rpx; }
.card-action-coll .card-action-label { color: #5c8fd6; font-size: 24rpx; font-weight: 600; }
.card-action-icon  { flex-shrink: 0; }
.card-action-label { flex-shrink: 0; }

/* ══════════════════════════════════════════════
   Tab2: AI 营销
══════════════════════════════════════════════ */

.mktg-root   { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
.mktg-scroll { flex: 1; }

/* 模式切换 */
.mktg-mode-bar {
  display: flex; flex-direction: row; gap: 12rpx;
  margin: 20rpx 28rpx 4rpx; flex-shrink: 0;
}
.mktg-mode-btn {
  flex: 1; text-align: center; padding: 18rpx 0;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 16rpx; font-size: 26rpx; color: #9a98a0; font-weight: 600;
}
.mktg-mode-on {
  background: rgba(201,169,110,0.1);
  border-color: rgba(201,169,110,0.45); color: #c9a96e;
}

/* Section 标题 */
.mktg-section       { padding: 24rpx 28rpx 4rpx; }
.mktg-section-title { font-size: 24rpx; font-weight: 700; color: #9a98a0; display: block; margin-bottom: 16rpx; }

/* 加载 / 空态 */
.mktg-list-loading     { padding: 20rpx 0; }
.mktg-list-loading-txt { font-size: 24rpx; color: #5c5b65; }
.mktg-empty-hint       { padding: 12rpx 0; }
.mktg-empty-hint text  { font-size: 24rpx; color: #5c5b65; }

/* 搜索栏 */
.mktg-search-bar {
  display: flex; flex-direction: row; align-items: center;
  gap: 12rpx; margin-bottom: 16rpx;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 16rpx; padding: 16rpx 20rpx;
}
.mktg-search-icon { font-size: 28rpx; flex-shrink: 0; opacity: 0.6; }
.mktg-search-input {
  flex: 1; font-size: 26rpx; color: #f0ede8; background: transparent;
  min-height: 40rpx; line-height: 40rpx;
}
.mktg-search-ph { color: #3e3d46; font-size: 26rpx; }

/* 快速筛选 */
.mktg-filter-scroll { overflow: hidden; margin-bottom: 16rpx; }
.mktg-filter-row {
  display: flex; flex-direction: row; gap: 12rpx;
  width: max-content; padding-bottom: 2rpx;
}
.mktg-filter-chip {
  padding: 10rpx 24rpx; border-radius: 30rpx; flex-shrink: 0;
  background: #1e2029; border: 2rpx solid #2a2d38;
  font-size: 24rpx; color: #9a98a0; font-weight: 500;
}
.mktg-filter-chip-on {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.45); color: #c9a96e;
}
.mktg-filter-empty { margin-top: 4rpx; margin-bottom: 8rpx; }

/* 目标选择器（横向滚动卡片） */
.mktg-pick-scroll { overflow: hidden; }
.mktg-pick-row    { display: flex; flex-direction: row; gap: 16rpx; width: max-content; padding-bottom: 4rpx; }
.mktg-pick-card   {
  width: 180rpx; flex-shrink: 0;
  background: #1e2029; border: 3rpx solid #2a2d38;
  border-radius: 20rpx; overflow: hidden;
  display: flex; flex-direction: column; align-items: center;
  padding-bottom: 16rpx; position: relative;
}
.mktg-pick-on { border-color: #c9a96e; background: rgba(201,169,110,0.07); }
.mktg-pick-img-wrap { width: 100%; height: 160rpx; overflow: hidden; }
.mktg-pick-img      { width: 100%; height: 100%; display: block; }
.mktg-pick-emoji-wrap {
  width: 100%; height: 160rpx;
  background: #141519; display: flex; align-items: center; justify-content: center;
}
.mktg-pick-emoji { font-size: 56rpx; }
.mktg-pick-name  { font-size: 24rpx; color: #f0ede8; font-weight: 600; text-align: center; margin-top: 12rpx; padding: 0 12rpx; line-height: 1.3; }
.mktg-pick-sub   { font-size: 20rpx; color: #5c5b65; margin-top: 4rpx; }
.mktg-pick-check {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #c9a96e; color: #0d0e12;
  font-size: 22rpx; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}

/* 已选目标简介 */
.mktg-target-preview {
  display: flex; flex-direction: row; align-items: center;
  gap: 20rpx; margin: 12rpx 28rpx; padding: 20rpx 24rpx;
}
.mktg-target-emoji { font-size: 52rpx; flex-shrink: 0; }
.mktg-target-info  { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6rpx; }
.mktg-target-name  { font-size: 28rpx; font-weight: 700; color: #f0ede8; display: block; }
.mktg-target-desc  { font-size: 22rpx; color: #5c5b65; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* 营销图类型 */
.mktg-type-row { display: flex; flex-direction: row; gap: 14rpx; }
.mktg-type-card {
  flex: 1; background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 18rpx; padding: 20rpx 12rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.mktg-type-on  { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.5); }
.mktg-type-emoji { font-size: 36rpx; }
.mktg-type-label { font-size: 24rpx; font-weight: 700; color: #f0ede8; }
.mktg-type-desc  { font-size: 19rpx; color: #5c5b65; text-align: center; }

/* 风格横向滑动 */
.mktg-style-scroll { overflow: hidden; }
.mktg-style-row    { display: flex; flex-direction: row; gap: 16rpx; width: max-content; padding-bottom: 4rpx; }
.mktg-style-card   {
  width: 160rpx; flex-shrink: 0;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 20rpx; padding: 20rpx 16rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx; position: relative;
}
.mktg-style-on { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.55); }
.mktg-style-emoji  { font-size: 40rpx; line-height: 1; }
.mktg-style-label  { font-size: 24rpx; font-weight: 700; color: #f0ede8; text-align: center; display: block; }
.mktg-style-desc   { font-size: 20rpx; color: #5c5b65; text-align: center; display: block; }
.mktg-style-check  {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: #c9a96e; font-size: 20rpx; color: #0d0e12; font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}

/* 补充描述输入 */
.mktg-custom-input {
  width: 100%; min-height: 80rpx;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 16rpx; padding: 18rpx 20rpx;
  font-size: 26rpx; color: #f0ede8; line-height: 1.6;
  box-sizing: border-box; display: block;
}
.mktg-custom-ph { color: #3e3d46; font-size: 26rpx; }

/* 生成按钮 */
.mktg-gen-btn {
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  gap: 12rpx; margin-top: 20rpx;
  background: linear-gradient(135deg, #c9a96e 0%, #b8954e 100%);
  border-radius: 24rpx; padding: 28rpx 0;
}
.mktg-gen-disabled { opacity: 0.5; }
.mktg-gen-icon  { font-size: 30rpx; color: #0d0e12; }
.mktg-gen-label { font-size: 30rpx; font-weight: 700; color: #0d0e12; }

/* 查看/编辑历史图入口 */
.mktg-view-edit-btn {
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  gap: 10rpx; margin-top: 16rpx;
  background: rgba(201,169,110,0.08);
  border: 2rpx solid rgba(201,169,110,0.3);
  border-radius: 24rpx; padding: 22rpx 0;
}
.mktg-view-edit-icon  { font-size: 28rpx; }
.mktg-view-edit-label { font-size: 26rpx; font-weight: 600; color: #c9a96e; }

/* 生成中动画 */
.mktg-loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 40rpx 40rpx; gap: 20rpx;
}
.mktg-loading-dots { display: flex; flex-direction: row; gap: 14rpx; align-items: center; }
.ml-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #c9a96e; animation: mlBounce 1.4s ease-in-out infinite;
}
.ml-dot-1 { animation-delay: 0s; }
.ml-dot-2 { animation-delay: 0.2s; }
.ml-dot-3 { animation-delay: 0.4s; }
@keyframes mlBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%           { transform: scale(1.2); opacity: 1; }
}
.mktg-loading-step { font-size: 28rpx; font-weight: 600; color: #f0ede8; display: block; text-align: center; }
.mktg-loading-hint { font-size: 22rpx; color: #5c5b65; display: block; text-align: center; }

/* Canvas */
.mktg-canvas        { display: block; width: 100%; border-radius: 16rpx; }
.mktg-canvas-square { aspect-ratio: 1 / 1; }
.mktg-canvas-poster { aspect-ratio: 3 / 4; }

/* 结果区 */
.mktg-result-wrap { display: flex; flex-direction: column; padding: 0 28rpx; gap: 16rpx; }

.mktg-img-wrap       { align-self: center; position: relative; width: fit-content; border-radius: 16rpx; overflow: hidden; aspect-ratio: 1 / 1; }
.mktg-img-wrap-poster{ aspect-ratio: 3 / 4; }
/* .mktg-result-img     { width: 100%; height: 100%; display: block; } */

/* 放大提示 */
.mktg-img-zoom-hint {
  position: absolute; bottom: 16rpx; right: 16rpx;
  display: flex; flex-direction: row; align-items: center; gap: 6rpx;
  background: rgba(0,0,0,0.45); border-radius: 20rpx; padding: 6rpx 16rpx;
}
.mktg-img-zoom-icon { font-size: 22rpx; }
.mktg-img-zoom-txt  { font-size: 20rpx; color: rgba(255,255,255,0.8); }

/* 操作栏 */
.mktg-action-bar {
  display: flex; flex-direction: row; gap: 12rpx;
}
.mktg-action-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx; padding: 20rpx 0;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 18rpx;
}
.mktg-action-icon  { font-size: 32rpx; }
.mktg-action-label { font-size: 20rpx; color: #9a98a0; }

.mktg-action-save  { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.4); }
.mktg-action-save .mktg-action-icon  { color: #c9a96e; }
.mktg-action-save .mktg-action-label { color: #c9a96e; }

.mktg-action-share { background: rgba(92,143,214,0.1); border-color: rgba(92,143,214,0.35); }
.mktg-action-share .mktg-action-icon  { color: #5c8fd6; }
.mktg-action-share .mktg-action-label { color: #5c8fd6; }

.mktg-action-edit  { background: rgba(154,100,214,0.1); border-color: rgba(154,100,214,0.3); }
.mktg-action-edit .mktg-action-icon  { color: #9a64d6; font-size: 28rpx; }
.mktg-action-edit .mktg-action-label { color: #9a64d6; }

.mktg-action-regen .mktg-action-icon  { color: #9a98a0; }

/* 在线编辑面板 */
.edit-panel       { padding: 28rpx; display: flex; flex-direction: column; gap: 0; }
.edit-panel-title { font-size: 26rpx; font-weight: 700; color: #f0ede8; display: block; margin-bottom: 6rpx; }
.edit-hint        { font-size: 20rpx; color: #5c5b65; display: block; margin-bottom: 20rpx; }

.edit-field-row   {
  display: flex; flex-direction: row; align-items: center;
  padding: 16rpx 0; border-bottom: 2rpx solid #1e2029;
}
.edit-field-label { font-size: 24rpx; color: #9a98a0; width: 96rpx; flex-shrink: 0; }
.edit-field-input { flex: 1; font-size: 26rpx; color: #f0ede8; background: transparent; }

.edit-section-label { font-size: 22rpx; color: #9a98a0; display: block; margin: 20rpx 0 10rpx; }
.edit-cocktail-row  { display: flex; flex-direction: row; align-items: center; gap: 12rpx; padding: 10rpx 0; border-bottom: 2rpx solid #1e2029; }
.edit-cocktail-num  { font-size: 22rpx; color: #5c5b65; width: 28rpx; flex-shrink: 0; }
.edit-cocktail-name { flex: 1; font-size: 24rpx; color: #f0ede8; background: transparent; }
.edit-cocktail-price{ width: 100rpx; font-size: 24rpx; color: #c9a96e; background: transparent; text-align: right; }

/* 错误态 */
