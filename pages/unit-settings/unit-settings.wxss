/* pages/unit-settings/unit-settings.wxss */
.page-scroll { height: 100vh; background: var(--bg-base); }

/* ── 提示卡 ── */
.intro-card {
  margin: 24rpx var(--page-x) 0;
  padding: 28rpx 28rpx;
}
.intro-text { font-size: 24rpx; color: var(--text-secondary); line-height: 1.75; display: block; }

/* ── Section label ── */
.section-label {
  font-size: 20rpx; font-weight: 700; color: var(--text-disabled);
  letter-spacing: 3rpx; text-transform: uppercase;
  padding: 24rpx var(--page-x) 12rpx; display: block;
}

/* ── 选项卡 ── */
.options-card { margin: 0 var(--page-x); overflow: hidden; }

.option-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 28rpx 28rpx; gap: 20rpx;
}
.option-row-border { border-bottom: 1.5rpx solid var(--border-sub); }

.option-left { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.option-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.option-desc { font-size: 22rpx; color: var(--text-muted); display: block; }

.option-check {
  width: 44rpx; height: 44rpx; border-radius: var(--r-full);
  border: 2rpx solid var(--border-mid);
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 24rpx; color: transparent; flex-shrink: 0;
}
.option-check-on {
  background: var(--gold-main); border-color: var(--gold-main); color: var(--bg-base);
}

/* ── 预览卡（金色调）── */
.preview-card {
  margin: 24rpx var(--page-x) 0;
  padding: 28rpx 28rpx;
  background: var(--gold-tint) !important;
  border-color: var(--gold-border) !important;
}
.preview-title {
  font-size: 20rpx; font-weight: 700; color: var(--gold-main);
  letter-spacing: 2rpx; text-transform: uppercase;
  display: block; margin-bottom: 20rpx;
}
.preview-row {
  display: flex; flex-direction: row; justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1.5rpx solid var(--gold-border);
}
.preview-row:last-child { border-bottom: none; padding-bottom: 0; }
.preview-label { font-size: 26rpx; color: var(--text-secondary); }
.preview-val   { font-size: 26rpx; font-weight: 700; color: var(--gold-main); }
