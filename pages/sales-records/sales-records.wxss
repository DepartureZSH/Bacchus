/* pages/sales-records/sales-records.wxss */

.sr-scroll {
  height: 100vh;
  background: #0d0e12;
}

/* ── Card ── */
.card {
  background: #16181f;
  border: 2rpx solid #2a2d38;
  border-radius: 28rpx;
}

/* ── 汇总 ── */
.sr-summary {
  margin: 24rpx 32rpx 20rpx;
  padding: 32rpx 24rpx;
}

.sr-stat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.sr-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.sr-stat-div {
  width: 2rpx;
  height: 48rpx;
  background: #2a2d38;
}

.sr-stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #f0ede8;
}

.sr-stat-num.sr-accent {
  color: #c9a96e;
}

.sr-stat-label {
  font-size: 22rpx;
  color: #9a98a0;
}

/* ── 操作 ── */
.sr-action-bar {
  margin: 0 32rpx 20rpx;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
}

.sr-btn-add {
  background: #c9a96e;
  color: #12141a;
  font-size: 26rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 18rpx;
}

/* ── Loading / Empty ── */
.sr-loading,
.sr-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  gap: 16rpx;
}

.sr-loading-txt {
  font-size: 26rpx;
  color: #5c5b65;
}

.sr-empty-icon {
  font-size: 72rpx;
}

.sr-empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #9a98a0;
}

.sr-empty-sub {
  font-size: 24rpx;
  color: #5c5b65;
  text-align: center;
  line-height: 1.6;
}

/* ── 记录列表 ── */
.sr-list {
  margin: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sr-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 12rpx;
}

.sr-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sr-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #f0ede8;
}

.sr-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.sr-meta {
  font-size: 22rpx;
  color: #9a98a0;
}

.sr-note {
  font-size: 22rpx;
  color: #5c5b65;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sr-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.sr-revenue {
  font-size: 32rpx;
  font-weight: 700;
  color: #c9a96e;
}

.sr-btns {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
}

.sr-btn-edit,
.sr-btn-del {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
}

.sr-btn-edit {
  color: #c9a96e;
  border: 1rpx solid rgba(201,169,110,0.35);
}

.sr-btn-del {
  color: #e05c5c;
  border: 1rpx solid rgba(224,92,92,0.35);
}

/* ── 弹窗 ── */
.sr-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sr-sheet {
  background: #1a1c23;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
}

.sr-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f0ede8;
  text-align: center;
  margin-bottom: 4rpx;
}

.sr-sheet-date {
  font-size: 22rpx;
  color: #9a98a0;
  text-align: center;
  margin-bottom: 32rpx;
}

.sr-field {
  margin-bottom: 24rpx;
}

.sr-label {
  font-size: 22rpx;
  color: #9a98a0;
  display: block;
  margin-bottom: 10rpx;
}

.sr-input {
  display: inline-table;
  background: #12141a;
  border: 2rpx solid #2a2d38;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #f0ede8;
  width: 100%;
  box-sizing: border-box;
}

.sr-modal-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 32rpx;
}

.sr-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #16181f;
  border: 2rpx solid #2a2d38;
  color: #9a98a0;
}

.sr-btn-save {
  flex: 2;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  background: #c9a96e;
  color: #12141a;
}

.sr-btn-disabled {
  opacity: 0.5;
}
