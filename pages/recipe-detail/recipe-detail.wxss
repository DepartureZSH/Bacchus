/* pages/recipe-detail/recipe-detail.wxss */

.rd-root {
  background: var(--bg-base);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ── 滚动区 ── */
.rd-scroll {
  flex: 1;
  height: calc(100vh - 120rpx);
}

/* ── 全局 loading ── */
.rd-loading {
  display: flex; gap: 16rpx;
  justify-content: center; align-items: center;
  padding: 120rpx 0;
}
.rd-dot {
  width: 18rpx; height: 18rpx;
  border-radius: var(--r-full); background: var(--gold-main);
  animation: rdBounce 1.4s ease-in-out infinite;
}
.rd-dot-1 { animation-delay: 0s; }
.rd-dot-2 { animation-delay: 0.2s; }
.rd-dot-3 { animation-delay: 0.4s; }
@keyframes rdBounce {
  0%,80%,100% { transform: scale(0.6); opacity: 0.5; }
  40%          { transform: scale(1.0); opacity: 1; }
}

/* ── 图片轮播 ── */
.rd-hero {
  position: relative;
  width: 100%;
  background: var(--bg-base);
}
.rd-swiper {
  width: 100%;
  height: 100%;
}
.rd-hero-img {
  width: 100%;
  height: 100%;
  background-color: var(--bg-base);
}
.rd-hero-gradient {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 240rpx;
  background: linear-gradient(to bottom, transparent, var(--bg-base));
  pointer-events: none;
}
.rd-swiper-dots {
  position: absolute;
  bottom: 28rpx;
  left: 0; right: 0;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}
.rd-dot-indicator {
  width: 12rpx; height: 12rpx;
  border-radius: var(--r-full);
  background: rgba(255,255,255,0.35);
  transition: background var(--dur-base) var(--ease-smooth);
}
.rd-dot-on {
  background: var(--gold-main);
  width: 28rpx;
  border-radius: var(--r-full);
}

/* ── Emoji 占位 ── */
.rd-emoji-hero {
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, var(--bg-raised), var(--bg-base));
}
.rd-hero-emoji { font-size: 160rpx; }

/* ── 配方卡片 ── */
.rd-card {
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  margin-top: -40rpx;
  padding: 44rpx 36rpx 40rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 32rpx rgba(0,0,0,0.4);
}

.rd-title-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.rd-title {
  flex: 1;
  font-size: 46rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}
.rd-rating-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-full);
  padding: 6rpx 16rpx;
  flex-shrink: 0;
}
.rd-rating-star { font-size: 24rpx; color: var(--gold-main); }
.rd-rating-num  { font-size: 26rpx; font-weight: 700; color: var(--gold-main); }

.rd-author-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.rd-author { font-size: 24rpx; color: var(--text-muted); }
.rd-likes  { font-size: 24rpx; color: var(--text-muted); }

.rd-tags-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.rd-tag-chip {
  font-size: 22rpx;
  color: var(--gold-main);
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-full);
  padding: 6rpx 18rpx;
}

.rd-base-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.rd-base-label {
  font-size: 22rpx;
  color: var(--text-muted);
  background: var(--bg-raised);
  padding: 4rpx 14rpx;
  border-radius: var(--r-xs);
}
.rd-base-val { font-size: 24rpx; color: var(--text-secondary); }

.rd-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 24rpx;
  display: block;
}

.rd-divider {
  height: 1.5rpx;
  background: var(--border-sub);
  margin: 24rpx 0 28rpx;
}

.rd-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gold-main);
  display: block;
  margin-bottom: 20rpx;
}

/* 原料 */
.rd-ing-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.rd-ing-dot {
  width: 10rpx; height: 10rpx;
  border-radius: var(--r-full);
  background: var(--gold-main);
  margin-right: 18rpx;
  flex-shrink: 0;
}
.rd-ing-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}
.rd-ing-amt {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 步骤 */
.rd-step-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.rd-step-num {
  width: 44rpx; height: 44rpx;
  border-radius: var(--r-full);
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rd-step-num text { font-size: 22rpx; color: var(--gold-bright); font-weight: 700; }
.rd-step-txt {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.65;
  padding-top: 8rpx;
}

/* 备注 */
.rd-notes {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 24rpx;
  background: rgba(76,175,132,0.06);
  border: 1.5rpx solid rgba(76,175,132,0.22);
  border-radius: var(--r-sm);
  padding: 20rpx;
}
.rd-notes-icon { font-size: 28rpx; flex-shrink: 0; }
.rd-notes-txt  { font-size: 26rpx; color: var(--clr-success); line-height: 1.65; flex: 1; }

/* ── 分区卡片（评分 / 标签云 / 评论）── */
.rd-section-card {
  background: var(--bg-surface);
  margin: 16rpx 0 0;
  padding: 36rpx;
}

/* 评分分布 */
.rd-rating-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}
.rd-rating-big {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.rd-rating-big-num    { font-size: 72rpx; font-weight: 800; color: var(--gold-main); line-height: 1; }
.rd-rating-big-outof  { font-size: 30rpx; color: var(--text-muted); }
.rd-rating-cnt-label  { font-size: 24rpx; color: var(--text-muted); }

.rd-bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.rd-bar-star  { font-size: 24rpx; color: var(--text-muted); width: 44rpx; text-align: right; }
.rd-bar-track {
  flex: 1;
  height: 12rpx;
  background: var(--border-sub);
  border-radius: var(--r-full);
  overflow: hidden;
}
.rd-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold-main), var(--gold-bright));
  border-radius: var(--r-full);
  transition: width var(--dur-base) var(--ease-smooth);
  min-width: 0;
}
.rd-bar-pct { font-size: 22rpx; color: var(--text-muted); width: 60rpx; }

.rd-my-rating-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1.5rpx solid var(--border-sub);
}
.rd-my-rating-label  { font-size: 24rpx; color: var(--text-muted); }
.rd-my-rating-stars  { display: flex; gap: 4rpx; }
.rd-my-star          { font-size: 28rpx; color: var(--border-str); }
.rd-my-star-on       { color: var(--gold-main); }

/* ── 标签云 ── */
.rd-tag-cloud {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}
.rd-cloud-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--border-sub);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 12rpx 24rpx;
  transition: all var(--dur-base) var(--ease-smooth);
}
.rd-cloud-on {
  background: var(--gold-tint);
  border-color: var(--gold-border);
}
.rd-cloud-name { font-size: 26rpx; color: var(--text-secondary); }
.rd-cloud-on .rd-cloud-name { color: var(--gold-main); }
.rd-cloud-cnt  {
  font-size: 20rpx;
  color: var(--text-muted);
  background: var(--border-sub);
  border-radius: var(--r-full);
  padding: 2rpx 10rpx;
}

/* ── 评论区 ── */
.rd-comments-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.rd-comment-cnt { font-size: 24rpx; color: var(--text-muted); }

.rd-comments-empty {
  padding: 40rpx 0;
  text-align: center;
}
.rd-comments-empty-txt { font-size: 26rpx; color: var(--text-disabled); }

.rd-comment-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.rd-comment-avatar {
  width: 64rpx; height: 64rpx;
  border-radius: var(--r-full);
  background: linear-gradient(135deg, var(--bg-overlay), var(--bg-raised));
  border: 1.5rpx solid var(--gold-border);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rd-comment-avatar-txt { font-size: 28rpx; color: var(--gold-main); font-weight: 600; }
.rd-comment-body { flex: 1; }
.rd-comment-author {
  font-size: 24rpx;
  color: var(--gold-main);
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}
.rd-comment-content {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}
.rd-comment-time { font-size: 22rpx; color: var(--text-disabled); display: block; }

.rd-comment-loading, .rd-load-more {
  text-align: center;
  padding: 24rpx;
}
.rd-comment-loading-txt { font-size: 26rpx; color: var(--text-muted); }
.rd-load-more { cursor: pointer; }
.rd-load-more-txt { font-size: 26rpx; color: var(--gold-main); }

/* ── 底部操作栏 ── */
.rd-action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: rgba(21,23,30,0.96);
  border-top: 1.5rpx solid var(--border-sub);
  backdrop-filter: blur(16px);
  padding: 20rpx 16rpx calc(env(safe-area-inset-bottom) + 20rpx);
  z-index: 50;
}
.rd-preview-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
}
.rd-preview-tip-txt { font-size: 24rpx; color: var(--text-muted); }

.rd-action-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
}
.rd-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 12rpx;
  border-radius: var(--r-md);
  min-width: 80rpx;
}
.rd-action-on .rd-action-icon { color: var(--gold-main); }
.rd-action-icon { font-size: 40rpx; color: var(--text-muted); transition: color var(--dur-fast) var(--ease-smooth); }
.rd-action-label { font-size: 20rpx; color: var(--text-muted); }
.rd-action-on .rd-action-label { color: var(--gold-main); }

/* ── 弹窗通用 ── */
.rd-popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.rd-popup {
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  width: 100%;
  padding: 24rpx 40rpx calc(env(safe-area-inset-bottom) + 48rpx);
}
.rd-popup-handle {
  width: 64rpx; height: 6rpx;
  background: var(--border-str);
  border-radius: var(--r-full);
  margin: 0 auto 28rpx;
}
.rd-popup-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}
.rd-popup-sub {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}
.rd-popup-confirm {
  margin-top: 36rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-lg);
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--bg-base);
  box-shadow: var(--shadow-gold);
}

/* 打分星 */
.rd-star-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 28rpx 0 8rpx;
}
.rd-star-btn {
  font-size: 80rpx;
  color: var(--border-str);
  transition: color var(--dur-fast) var(--ease-spring), transform var(--dur-fast) var(--ease-spring);
}
.rd-star-on { color: var(--gold-main); transform: scale(1.1); }
.rd-rating-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--gold-main);
  margin-top: 8rpx;
}

/* 标签选项 */
.rd-tag-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 0 16rpx;
}
.rd-tag-opt {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--border-sub);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 12rpx 28rpx;
}
.rd-tag-opt-on {
  color: var(--gold-main);
  background: var(--gold-tint);
  border-color: var(--gold-border);
}

/* 评论输入 */
.rd-comment-popup { padding-bottom: calc(env(safe-area-inset-bottom) + 36rpx); }
.rd-comment-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--border-sub);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  margin: 16rpx 0;
}
.rd-comment-ph { color: var(--text-disabled); }
.rd-comment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.rd-comment-len { font-size: 22rpx; color: var(--text-disabled); }
.rd-comment-send {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-md);
  padding: 14rpx 36rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--bg-base);
  box-shadow: var(--shadow-gold);
}
