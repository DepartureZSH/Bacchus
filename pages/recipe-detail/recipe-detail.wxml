<!-- pages/recipe-detail/recipe-detail.wxml -->
<view class="rd-root">

  <!-- ── 顶部导航栏 ── -->
  <view class="rd-nav">
    <view class="rd-back" bindtap="onBack">
      <text class="rd-back-arrow">‹</text>
    </view>
    <text class="rd-nav-title">{{recipe.name || '配方详情'}}</text>
    <view wx:if="{{mode === 'preview'}}" class="rd-preview-badge">预览</view>
    <view wx:else class="rd-nav-placeholder"></view>
  </view>

  <!-- ── 主滚动区 ── -->
  <scroll-view class="rd-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 全局加载 -->
    <view wx:if="{{isLoading}}" class="rd-loading">
      <view class="rd-dot rd-dot-1"></view>
      <view class="rd-dot rd-dot-2"></view>
      <view class="rd-dot rd-dot-3"></view>
    </view>

    <block wx:if="{{!isLoading && recipe}}">

      <!-- ①  图片轮播 -->
      <view wx:if="{{images.length > 0}}" class="rd-hero">
        <swiper class="rd-swiper" bindchange="onSwiperChange" circular autoplay="{{false}}">
          <swiper-item wx:for="{{images}}" wx:key="fileID">
            <image class="rd-hero-img" src="{{item.tempUrl}}" mode="aspectFill" />
          </swiper-item>
        </swiper>
        <!-- 指示点 -->
        <view wx:if="{{images.length > 1}}" class="rd-swiper-dots">
          <view wx:for="{{images}}" wx:key="index"
            class="rd-dot-indicator {{imageIdx === index ? 'rd-dot-on' : ''}}"></view>
        </view>
        <!-- 封面渐变蒙层：底部渐入背景 -->
        <view class="rd-hero-gradient"></view>
      </view>

      <!-- ② Emoji 占位（无配图时） -->
      <view wx:else class="rd-emoji-hero">
        <text class="rd-hero-emoji">{{recipe.emoji || '🍹'}}</text>
      </view>

      <!-- ③ 配方信息卡片 -->
      <view class="rd-card">

        <!-- 标题行 -->
        <view class="rd-title-row">
          <text class="rd-title">{{recipe.name}}</text>
          <view wx:if="{{ratingCount > 0}}" class="rd-rating-badge">
            <text class="rd-rating-star">★</text>
            <text class="rd-rating-num">{{ratingAvg}}</text>
          </view>
        </view>

        <!-- 作者 + 点赞数（公开模式） -->
        <view wx:if="{{type === 'public'}}" class="rd-author-row">
          <text class="rd-author">🏪 {{authorName}}</text>
          <text class="rd-likes">♥ {{likeCount}}</text>
        </view>

        <!-- 标签行 -->
        <view wx:if="{{recipe.tags && recipe.tags.length}}" class="rd-tags-row">
          <view wx:for="{{recipe.tags}}" wx:key="*this" wx:for-item="tag" class="rd-tag-chip">{{tag}}</view>
        </view>

        <!-- 基酒标记 -->
        <view wx:if="{{recipe.base}}" class="rd-base-row">
          <text class="rd-base-label">基酒</text>
          <text class="rd-base-val">{{recipe.base}}</text>
        </view>

        <!-- 简介 -->
        <text wx:if="{{recipe.desc}}" class="rd-desc">{{recipe.desc}}</text>

        <!-- 分割线 -->
        <view class="rd-divider"></view>

        <!-- 原料 -->
        <text class="rd-section-title">🧪 原料</text>
        <view wx:for="{{recipe.ingredients}}" wx:key="name" wx:for-item="ing" class="rd-ing-row">
          <view class="rd-ing-dot"></view>
          <text class="rd-ing-name">{{ing.name}}</text>
          <text class="rd-ing-amt">{{ing.amount}}</text>
        </view>

        <!-- 步骤 -->
        <text class="rd-section-title" style="margin-top:36rpx">📋 步骤</text>
        <view wx:for="{{recipe.steps}}" wx:key="index" wx:for-item="step" class="rd-step-row">
          <view class="rd-step-num"><text>{{index+1}}</text></view>
          <text class="rd-step-txt">{{step}}</text>
        </view>

        <!-- 备注 -->
        <view wx:if="{{recipe.notes}}" class="rd-notes">
          <text class="rd-notes-icon">📌</text>
          <text class="rd-notes-txt">{{recipe.notes}}</text>
        </view>

      </view>

      <!-- ④ 评分分布图（≥ 5 人评分后显示） -->
      <view wx:if="{{showRatingChart}}" class="rd-section-card">
        <text class="rd-section-title">⭐ 评分</text>
        <view class="rd-rating-summary">
          <view class="rd-rating-big">
            <text class="rd-rating-big-num">{{ratingAvg}}</text>
            <text class="rd-rating-big-outof">/ 5</text>
          </view>
          <text class="rd-rating-cnt-label">{{ratingCount}} 人评分</text>
        </view>
        <view wx:for="{{ratingBars}}" wx:key="star" wx:for-item="bar" class="rd-bar-row">
          <text class="rd-bar-star">{{bar.star}}★</text>
          <view class="rd-bar-track">
            <view class="rd-bar-fill" style="width:{{bar.pct}}%"></view>
          </view>
          <text class="rd-bar-pct">{{bar.pct}}%</text>
        </view>
        <!-- 我的评分展示 -->
        <view wx:if="{{myRating > 0}}" class="rd-my-rating-row">
          <text class="rd-my-rating-label">我的评分：</text>
          <view class="rd-my-rating-stars">
            <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
              class="rd-my-star {{myRating >= item ? 'rd-my-star-on' : ''}}">★</text>
          </view>
          <text class="rd-my-rating-label">{{ratingLabels[myRating-1]}}</text>
        </view>
      </view>

      <!-- ⑤ 标签云（≥ 3 个标签后显示） -->
      <view wx:if="{{showTagCloud}}" class="rd-section-card">
        <text class="rd-section-title">🏷️ 大家觉得</text>
        <view class="rd-tag-cloud">
          <view wx:for="{{tagCloudItems}}" wx:key="tag" wx:for-item="tc"
            class="rd-cloud-item {{myTags.indexOf(tc.tag) >= 0 ? 'rd-cloud-on' : ''}}"
            data-tag="{{tc.tag}}" catchtap="onTagCloudTap">
            <text class="rd-cloud-name">{{tc.tag}}</text>
            <text class="rd-cloud-cnt">{{tc.count}}</text>
          </view>
        </view>
      </view>

      <!-- ⑥ 评论区 -->
      <view wx:if="{{type === 'public'}}" class="rd-section-card">
        <view class="rd-comments-header">
          <text class="rd-section-title">💬 评论</text>
          <text class="rd-comment-cnt">{{commentCount}} 条</text>
        </view>

        <view wx:if="{{comments.length === 0}}" class="rd-comments-empty">
          <text class="rd-comments-empty-txt">还没有评论，快来说第一句吧</text>
        </view>

        <view wx:for="{{comments}}" wx:key="_id" wx:for-item="c" class="rd-comment-item">
          <view class="rd-comment-avatar">
            <text class="rd-comment-avatar-txt">{{c.authorName.substring(0,1)}}</text>
          </view>
          <view class="rd-comment-body">
            <text class="rd-comment-author">{{c.authorName}}</text>
            <text class="rd-comment-content">{{c.content}}</text>
            <text class="rd-comment-time">{{c.createdAtStr}}</text>
          </view>
        </view>

        <view wx:if="{{commentLoading}}" class="rd-comment-loading">
          <text class="rd-comment-loading-txt">加载中…</text>
        </view>
        <view wx:elif="{{commentHasMore}}" class="rd-load-more" bindtap="onLoadMoreComments">
          <text class="rd-load-more-txt">查看更多评论</text>
        </view>
      </view>

    </block>

    <view style="height:180rpx"></view>
  </scroll-view>

  <!-- ── 底部操作栏 ── -->
  <view wx:if="{{!isLoading && recipe}}" class="rd-action-bar">
    <!-- 预览模式提示 -->
    <view wx:if="{{mode === 'preview'}}" class="rd-preview-tip">
      <text class="rd-preview-tip-txt">预览模式 · 互动功能不可用</text>
    </view>

    <!-- 正常操作行 -->
    <view wx:else class="rd-action-row">
      <!-- 点赞 -->
      <view class="rd-action-item {{isLiked ? 'rd-action-on' : ''}}" catchtap="onLike">
        <text class="rd-action-icon">{{isLiked ? '♥' : '♡'}}</text>
        <text class="rd-action-label">{{likeCount}}</text>
      </view>
      <!-- 收藏 -->
      <view class="rd-action-item {{isFav ? 'rd-action-on' : ''}}" catchtap="onToggleFav">
        <text class="rd-action-icon">{{isFav ? '★' : '☆'}}</text>
        <text class="rd-action-label">收藏</text>
      </view>
      <!-- 复制 -->
      <view class="rd-action-item" catchtap="onClone">
        <text class="rd-action-icon">📋</text>
        <text class="rd-action-label">复制</text>
      </view>
      <!-- 打分 -->
      <view class="rd-action-item {{myRating > 0 ? 'rd-action-on' : ''}}" catchtap="onShowRatingPicker">
        <text class="rd-action-icon">⭐</text>
        <text class="rd-action-label">{{myRating > 0 ? myRating + '★' : '打分'}}</text>
      </view>
      <!-- 贴标签 -->
      <view class="rd-action-item {{myTags.length > 0 ? 'rd-action-on' : ''}}" catchtap="onShowTagPicker">
        <text class="rd-action-icon">🏷️</text>
        <text class="rd-action-label">标签</text>
      </view>
      <!-- 评论 -->
      <view class="rd-action-item" catchtap="onShowCommentInput">
        <text class="rd-action-icon">💬</text>
        <text class="rd-action-label">评论</text>
      </view>
    </view>
  </view>

  <!-- ── 打分弹窗 ── -->
  <view wx:if="{{showRatingInput}}" class="rd-popup-mask" catchtap="onCloseRating">
    <view class="rd-popup" catchtap="stopProp">
      <view class="rd-popup-handle"></view>
      <text class="rd-popup-title">给这款配方打分</text>
      <view class="rd-star-row">
        <view wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
          class="rd-star-btn {{pendingRating >= item ? 'rd-star-on' : ''}}"
          data-score="{{item}}" catchtap="onRateStar">★</view>
      </view>
      <text wx:if="{{pendingRating > 0}}" class="rd-rating-hint">{{ratingLabels[pendingRating-1]}}</text>
      <view class="rd-popup-confirm" catchtap="onSubmitRating">
        <text>确认评分</text>
      </view>
    </view>
  </view>

  <!-- ── 贴标签弹窗 ── -->
  <view wx:if="{{showTagInput}}" class="rd-popup-mask" catchtap="onCloseTagPicker">
    <view class="rd-popup" catchtap="stopProp">
      <view class="rd-popup-handle"></view>
      <text class="rd-popup-title">贴标签（最多 5 个）</text>
      <text class="rd-popup-sub">帮助其他人了解这款配方的风格</text>
      <view class="rd-tag-options">
        <view wx:for="{{tagOptions}}" wx:key="*this"
          class="rd-tag-opt {{pendingTags.indexOf(item) >= 0 ? 'rd-tag-opt-on' : ''}}"
          data-tag="{{item}}" catchtap="onToggleTagOption">{{item}}</view>
      </view>
      <view class="rd-popup-confirm" catchtap="onSubmitTags">
        <text>确认（已选 {{pendingTags.length}}/5）</text>
      </view>
    </view>
  </view>

  <!-- ── 评论输入弹窗 ── -->
  <view wx:if="{{showCommentInput}}" class="rd-popup-mask" catchtap="onCloseCommentInput">
    <view class="rd-popup rd-comment-popup" catchtap="stopProp">
      <view class="rd-popup-handle"></view>
      <text class="rd-popup-title">写评论</text>
      <textarea
        class="rd-comment-textarea"
        placeholder="说说你对这款配方的感受…"
        placeholder-class="rd-comment-ph"
        value="{{newComment}}"
        bindinput="onCommentInput"
        maxlength="200"
        auto-height
        focus="{{showCommentInput}}"
      />
      <view class="rd-comment-footer">
        <text class="rd-comment-len">{{newComment.length}}/200</text>
        <view class="rd-comment-send" catchtap="onSubmitComment">
          <text>发送</text>
        </view>
      </view>
    </view>
  </view>

</view>
