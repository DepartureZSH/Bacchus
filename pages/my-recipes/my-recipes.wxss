/* pages/my-recipes/my-recipes.wxss */

/* ══ 批量选择 ══ */
.top-select-btn {
  font-size: 24rpx;
  color: var(--gold-main);
  padding: 8rpx 16rpx;
  border-radius: var(--r-xs);
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
}
.top-select-btn-on {
  color: var(--text-secondary);
  background: var(--border-sub);
  border-color: var(--border-mid);
}

.batch-cb-wrap {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 5;
}
.batch-cb {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--r-full);
  border: 2rpx solid var(--border-str);
  background: rgba(12,13,16,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--dur-fast) var(--ease-smooth);
}
.batch-cb-on {
  border-color: var(--gold-main);
  background: rgba(201,164,90,0.25);
}
.batch-cb-partial {
  border-color: rgba(201,164,90,0.5);
  background: var(--gold-tint);
}
.batch-cb-tick {
  font-size: 22rpx;
  color: var(--gold-main);
  font-weight: 700;
  line-height: 1;
}
.batch-card-on {
  border-color: var(--gold-border) !important;
  background: var(--bg-raised) !important;
}

/* ══ 批量底部操作栏 ══ */
.batch-action-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  padding: 16rpx 28rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: rgba(12,13,16,0.96);
  border-top: 1.5rpx solid var(--border-sub);
  backdrop-filter: blur(16px);
  z-index: 60;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}
.batch-bar-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}
.batch-bar-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.batch-bar-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.batch-bar-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--bg-base);
  background: linear-gradient(90deg, var(--gold-main), var(--gold-bright));
  padding: 18rpx 36rpx;
  border-radius: var(--r-md);
}
.batch-bar-btn-danger {
  background: linear-gradient(90deg, var(--clr-danger), #e87777);
}
.batch-bar-btn-dim {
  background: var(--border-sub) !important;
  color: var(--text-muted) !important;
}

/* ══ 合集选择器抽屉 ══ */
.coll-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.coll-picker-sheet {
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 24rpx);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.coll-picker-handle {
  width: 72rpx; height: 6rpx;
  background: var(--border-str);
  border-radius: var(--r-full);
  margin: 20rpx auto 0;
  flex-shrink: 0;
}
.coll-picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  padding: 24rpx 0 16rpx;
  flex-shrink: 0;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.coll-picker-scroll {
  flex: 1;
}
.coll-picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  gap: 20rpx;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.coll-picker-emoji {
  font-size: 44rpx;
  flex-shrink: 0;
}
.coll-picker-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.coll-picker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.coll-picker-sub {
  font-size: 22rpx;
  color: var(--text-muted);
}
.coll-picker-arrow {
  font-size: 36rpx;
  color: var(--text-muted);
}

/* ══ 根容器 ══ */
.recipes-root {
  background: var(--bg-base);
  min-height: 100vh;
}

/* ══ 顶部 Tab ══ */
.top-tabs {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-base);
  padding: 0 20rpx;
  border-bottom: 1.5rpx solid var(--border-sub);
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.3);
  position: sticky;
  top: 0;
  z-index: 10;
}

.top-tab {
  padding: 24rpx 16rpx 20rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 4rpx;
}

.top-tab-label {
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 500;
  transition: color var(--dur-fast) var(--ease-smooth);
}

.top-tab-active .top-tab-label {
  color: var(--text-primary);
  font-weight: 700;
  letter-spacing: 0.3rpx;
}

.top-tab-line {
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 3rpx;
  background: linear-gradient(to right, transparent, var(--gold-bright), var(--gold-main), transparent);
  border-radius: var(--r-full);
  box-shadow: 0 0 10rpx rgba(226,184,106,0.55);
}

.top-actions {
  margin-left: auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.top-search-btn,
.top-add-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--bg-raised);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--gold-main);
}

.top-add-btn {
  font-size: 36rpx;
  font-weight: 300;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
}

/* ══ 搜索栏 ══ */
.search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--bg-raised);
  margin: 10rpx var(--page-x);
  border-radius: var(--r-full);
  border: 1.5rpx solid var(--border-mid);
  padding: 18rpx 24rpx;
  gap: 12rpx;
}

.search-icon-txt { font-size: 24rpx; color: var(--text-muted); }

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  background: none;
}

.search-ph { color: var(--text-disabled); }

.search-clear {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 6rpx 8rpx;
}

/* ══ 分类筛选 ══ */
/* 带标签的一行过滤组：标签 + 横向 scroll */
.filter-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 20rpx;
}
.filter-label {
  flex-shrink: 0;
  width: 64rpx;
  font-size: 20rpx;
  color: var(--text-disabled);
  letter-spacing: 1rpx;
}
.filter-group .filter-scroll { flex: 1; overflow: hidden; }

.filter-scroll { width: 100%; }

.filter-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  padding: 10rpx 20rpx 10rpx 0;
}

.filter-chip {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  font-size: 23rpx;
  font-weight: 500;
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-muted);
  background: var(--bg-raised);
  white-space: nowrap;
  transition: color var(--dur-fast) var(--ease-smooth),
              background var(--dur-fast) var(--ease-smooth),
              border-color var(--dur-fast) var(--ease-smooth);
}

.chip-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.45);
  color: var(--gold-bright);
  box-shadow: inset 0 1rpx 0 rgba(226,184,106,0.15);
}

/* ══ 滚动区 ══ */
.tab-scroll {
  /* plain content container — page itself scrolls */
}

/* ══ 配方卡片 ══ */
.card-list { padding: 16rpx 24rpx 0; display: flex; flex-direction: column; gap: 20rpx; }

.recipe-card { padding: 24rpx 24rpx 20rpx; overflow: hidden; position: relative; }

/* 替代粗 border-left：精致左侧渐变竖线 */
.user-card-border::before {
  content: '';
  position: absolute;
  top: 20rpx; left: 0;
  width: 3rpx;
  height: 50%;
  background: linear-gradient(to bottom, var(--gold-bright), var(--gold-main), transparent);
  border-radius: 0 var(--r-xs) var(--r-xs) 0;
  opacity: 0.85;
}

.rc-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 14rpx;
  margin-bottom: 14rpx;
}

.rc-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }

.rc-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.rc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  letter-spacing: 0.8rpx;
  line-height: 1.3;
}

.rc-tags {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: var(--r-full);
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.tag-base     { background: var(--gold-tint); color: var(--gold-main); border: 1rpx solid var(--gold-border); }
.tag-style    { background: rgba(154,152,160,0.10); color: var(--text-secondary); border: 1rpx solid var(--border-mid); }
.tag-user     { background: rgba(76,175,132,0.10); color: var(--clr-success); border: 1rpx solid rgba(76,175,132,0.25); }
.tag-ai       { background: rgba(143,168,248,0.12); color: var(--clr-ai); border: 1rpx solid rgba(143,168,248,0.28); }
.tag-original { background: rgba(226,184,106,0.15); color: var(--gold-bright); border: 1rpx solid rgba(226,184,106,0.35); }

.rc-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.rc-abv { font-size: 22rpx; color: var(--text-muted); display: block; text-align: center; }

.fav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--text-muted);
  line-height: 1;
  padding: 0;
  flex-shrink: 0;
  transition: all var(--dur-fast) var(--ease-smooth);
}
.fav-on {
  color: var(--clr-danger);
  background: rgba(224,92,92,0.10);
  border-color: rgba(224,92,92,0.28);
}
.fav-coll-on {
  color: var(--gold-main);
  background: var(--gold-tint);
  border-color: var(--gold-border);
}

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  padding: 0;
  flex-shrink: 0;
}

.rc-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
  opacity: 0.88;
}

/* 原料胶囊 */
.rc-ing-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.ing-pill {
  padding: 6rpx 18rpx;
  border-radius: var(--r-full);
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  letter-spacing: 0.3rpx;
}

.ing-more {
  color: var(--gold-main);
  border-color: var(--gold-border);
  background: var(--gold-tint);
}

/* ══ 展开详情 ══ */
.rc-detail { margin-top: 18rpx; }

.detail-divider {
  height: 1.5rpx;
  background: var(--border-sub);
  margin-bottom: 18rpx;
}

.detail-sec {
  font-size: 21rpx;
  font-weight: 700;
  color: var(--text-muted);
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2.5rpx;
  text-transform: uppercase;
}

/* detail-ing-row / ing-dot / detail-ing-name / detail-ing-amt — 从 app.wxss 继承 */

/* step-row / step-num / step-text — 从 app.wxss 继承 */

/* notes-box / notes-text — 从 app.wxss 继承 */

/* 展开详情底部操作行 */
.detail-actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.detail-action-btn {
  padding: 14rpx 22rpx;
  border-radius: var(--r-md);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 0.3rpx;
  display: flex;
  align-items: center;
}
.detail-action-btn text { color: inherit; }

.danger-btn {
  background: rgba(224,92,92,0.06);
  border-color: rgba(224,92,92,0.28);
  color: var(--clr-danger);
}
.danger-btn text { color: var(--clr-danger); }

/* ── 语义动作按钮变体 ── */

/* 导航主按钮（详情 / 预览）：金色，视觉权重最高 */
.detail-action-nav {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
  font-weight: 600;
}
.detail-action-nav text { color: var(--gold-main); }

/* 社交已激活状态（已收藏 / 取消收藏）：红色心形 */
.detail-action-social-on {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.28);
  color: var(--clr-danger);
}
.detail-action-social-on text { color: var(--clr-danger); }

/* 整理按钮（加入合集）：蓝色，偏内容管理 */
.detail-action-coll {
  background: rgba(92,143,214,0.08);
  border-color: rgba(92,143,214,0.25);
  color: var(--clr-blue);
}
.detail-action-coll text { color: var(--clr-blue); }

/* 收藏合集已激活（★ 已收藏合集）：金色 */
.detail-action-coll-on {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}
.detail-action-coll-on text { color: var(--gold-main); }

/* 展开/收起按钮 */
.rc-toggle {
  margin-top: 18rpx;
  padding: 14rpx 0 2rpx;
  border-top: 1.5rpx solid var(--border-sub);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.rc-toggle > view {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}
.rc-toggle-txt {
  font-size: 23rpx;
  color: var(--gold-main);
  letter-spacing: 0.5rpx;
}

.arrow-btn-svg {
  margin-left: 4rpx;
  width: 22rpx;
  height: 22rpx;
  opacity: 0.8;
}

/* ══ 空状态 — 从 app.wxss 继承 ══ */

.empty-ai-btn {
  margin-top: 20rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  color: var(--bg-base);
  font-size: 26rpx;
  font-weight: 700;
  padding: 22rpx 52rpx;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-gold), 0 4rpx 24rpx rgba(0,0,0,0.3);
  letter-spacing: 0.5rpx;
}

/* ══ AI 浮动按钮（我的 tab 非空时） ══ */
.ai-fab {
  position: fixed;
  right: 36rpx;
  bottom: 168rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-full);
  padding: 20rpx 36rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 36rpx rgba(201,164,90,0.45), 0 2rpx 8rpx rgba(0,0,0,0.4);
  z-index: 20;
}
.ai-fab-icon  { font-size: 26rpx; color: var(--bg-base); }
.ai-fab-label { font-size: 27rpx; font-weight: 700; color: var(--bg-base); letter-spacing: 0.5rpx; }

/* ══ 合集 Tab ══ */
.coll-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 20rpx; }

.coll-card { padding: 0; overflow: hidden; }

.coll-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 16rpx;
}

.coll-emoji { font-size: 48rpx; flex-shrink: 0; line-height: 1; }

.coll-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.coll-name { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.coll-sub  { font-size: 22rpx; color: var(--text-muted); display: block; }

.coll-actions {
  display: flex;
  flex-direction: row;
  gap: 4rpx;
  flex-shrink: 0;
}
.coll-edit,
.coll-del {
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--r-sm);
  background: var(--bg-raised);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.coll-del {
  font-size: 32rpx;
}

.coll-recipes {
  padding: 0 28rpx 16rpx;
}

.coll-divider {
  height: 1.5rpx;
  background: var(--border-sub);
  margin-bottom: 16rpx;
}

.coll-empty { font-size: 24rpx; color: var(--text-muted); padding: 8rpx 0; }

.coll-recipe-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 0;
  gap: 14rpx;
  border-bottom: 1.5rpx solid var(--border-sub);
}

.coll-rc-emoji { font-size: 36rpx; flex-shrink: 0; line-height: 1; }

.coll-rc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.coll-rc-name { font-size: 26rpx; color: var(--text-primary); font-weight: 600; display: block; }
.coll-rc-base { font-size: 22rpx; color: var(--text-muted); display: block; }

.coll-rc-remove {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--r-full);
  background: var(--bg-raised);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.coll-toggle {
  padding: 14rpx 28rpx;
  border-top: 1.5rpx solid var(--border-sub);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.coll-toggle > view {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}
.coll-toggle-txt { font-size: 23rpx; color: var(--gold-main); letter-spacing: 0.5rpx; }

/* ══ 底部蒙层 ══ */
.ai-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 100;
  pointer-events: none;
  transition: background 0.25s ease;
}
.ai-mask-show {
  background: rgba(0,0,0,0.55);
  pointer-events: auto;
}

/* ══ AI 抽屉 ══ */
.ai-drawer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  padding: 0 32rpx 60rpx;
  max-height: 88vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform var(--dur-slow) var(--ease-out);
}
.ai-drawer-show { transform: translateY(0); }

.ai-drawer-handle {
  width: 64rpx;
  height: 6rpx;
  border-radius: var(--r-full);
  background: var(--border-str);
  margin: 20rpx auto 24rpx;
}

.ai-drawer-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}
.ai-drawer-title { font-size: 32rpx; font-weight: 700; color: var(--text-primary); }
.ai-drawer-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--r-full);
  background: var(--bg-raised);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* AI 输入区 */
.ai-field { margin-bottom: 28rpx; }

.ai-field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 14rpx;
}
.ai-field-hint { font-size: 22rpx; color: var(--text-muted); font-weight: 400; margin-left: 6rpx; }

.ai-chips {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
}

.ai-chip {
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  font-size: 24rpx;
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-secondary);
  background: var(--bg-raised);
}
.ai-chip-on {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}

.ai-textarea {
  width: 100%;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md);
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
  min-height: 100rpx;
}
.ai-ph { color: var(--text-disabled); }

.ai-submit-btn {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-lg);
  padding: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: var(--shadow-gold);
}
.ai-submit-icon { font-size: 28rpx; color: var(--bg-base); }
.ai-submit-text { font-size: 30rpx; font-weight: 700; color: var(--bg-base); }

/* AI 加载中 */
.ai-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 28rpx;
}
.ai-loading-dots {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  align-items: center;
}
.ai-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: var(--r-full);
  background: var(--gold-main);
  animation: dotBounce 1.2s ease-in-out infinite;
}
.ai-dot-2 { animation-delay: 0.2s; }
.ai-dot-3 { animation-delay: 0.4s; }
.ai-loading-text { font-size: 26rpx; color: var(--text-secondary); }

/* AI 结果 */
.ai-result { display: flex; flex-direction: column; gap: 20rpx; }

.ai-result-card {
  background: var(--bg-surface);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xl);
  padding: 28rpx 24rpx;
  position: relative;
  overflow: hidden;
}
/* 左侧渐变竖线 */
.ai-result-card::before {
  content: '';
  position: absolute;
  top: 20rpx; left: 0;
  width: 3rpx;
  height: 50%;
  background: linear-gradient(to bottom, var(--gold-main), transparent);
}

/* 标题行 */
.ai-rc-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.ai-rc-emoji { font-size: 52rpx; flex-shrink: 0; line-height: 1; }
.ai-rc-meta  { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.ai-rc-name  { font-size: 30rpx; font-weight: 700; color: var(--text-primary); display: block; }
.ai-rc-tags  { display: flex; flex-direction: row; gap: 8rpx; flex-wrap: wrap; }
.ai-rc-tag   {
  padding: 4rpx 14rpx;
  border-radius: var(--r-sm);
  font-size: 20rpx;
  background: var(--gold-tint);
  color: var(--gold-main);
  border: 1rpx solid var(--gold-border);
}

/* 描述 */
.ai-rc-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

/* 分区分割线 + 标题 */
.ai-rc-divider {
  height: 1.5rpx;
  background: var(--border-sub);
  margin: 18rpx 0 14rpx;
}
.ai-rc-section {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--gold-main);
  display: block;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.ai-result-ings  { margin-bottom: 4rpx; }
.ai-result-steps { margin-bottom: 4rpx; }

/* step-num 在 AI 结果卡片中 */
.ai-result-card .step-num {
  background: var(--bg-overlay);
  border-color: var(--border-str);
}

.ai-result-actions {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
}

.ai-result-save {
  flex: 1;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  color: var(--bg-base);
  font-size: 26rpx;
  font-weight: 700;
  padding: 24rpx;
  border-radius: var(--r-lg);
  text-align: center;
  display: block;
  box-shadow: var(--shadow-gold);
}
.ai-result-retry {
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-secondary);
  font-size: 26rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--r-lg);
  text-align: center;
  display: block;
}

/* AI 错误 */
.ai-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 20rpx;
}
.ai-error-text { font-size: 26rpx; color: var(--clr-danger); text-align: center; }
.ai-retry-btn  {
  padding: 18rpx 48rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg);
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ══ 配方表单抽屉 ══ */
.form-drawer { max-height: 92vh; }
.form-drawer-scroll { max-height: 70vh; }

.form-field { margin-bottom: 24rpx; }

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.form-label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.form-add-sub {
  font-size: 22rpx;
  color: var(--gold-main);
  padding: 4rpx 0;
}

.form-input {
  width: 100%;
  height: auto;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}
.form-ph { color: var(--text-disabled); }

.form-textarea {
  width: 100%;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 1.6;
}

/* 原料行 */
.ing-form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}
.ing-form-input {
  flex: 1;
  height: auto;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xs);
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}
.ing-form-amount {
  width: 140rpx;
  height: auto;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xs);
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}
.ing-form-del {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--r-full);
  background: rgba(224,92,92,0.1);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--clr-danger);
  flex-shrink: 0;
}

/* 步骤行 */
.step-form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}
.step-form-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--r-full);
  background: var(--bg-overlay);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--gold-main);
  font-weight: 700;
  flex-shrink: 0;
}
.step-form-input {
  flex: 1;
  height: auto;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xs);
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-primary);
}

.form-error {
  padding: 14rpx 18rpx;
  background: rgba(224,92,92,0.08);
  border: 1.5rpx solid rgba(224,92,92,0.25);
  border-radius: var(--r-xs);
  font-size: 24rpx;
  color: var(--clr-danger);
  margin-bottom: 16rpx;
}

.form-submit-btn {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-lg);
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--bg-base);
  margin-top: 8rpx;
  box-shadow: var(--shadow-gold);
}

/* ══ 合集表单底栏 ══ */
.coll-form-sheet {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-surface);
  border-radius: var(--r-2xl) var(--r-2xl) 0 0;
  padding: 0 32rpx 60rpx;
  transform: translateY(100%);
  transition: transform var(--dur-slow) var(--ease-out);
}
.coll-form-sheet-show { transform: translateY(0); }

/* ── 全局 loading 进度条 ── */
.global-loading-bar {
  height: 4rpx;
  background: var(--gold-tint);
  overflow: hidden;
  margin: 0 0 8rpx;
}
.global-loading-track {
  height: 100%;
  width: 40%;
  background: var(--gold-main);
  border-radius: var(--r-full);
  animation: loadingSlide 1s ease-in-out infinite;
}
@keyframes loadingSlide {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(350%); }
}

/* ════════════════════════════════════════
   Step 8: AI 图片生成抽屉 & 入口按钮
   ════════════════════════════════════════ */

/* ── 合集营销图入口按钮 ── */
.coll-mktg-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--r-sm);
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* ── 配方详情里的生成图片按钮 ── */
.detail-action-img {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}
.detail-action-img text { color: var(--gold-main); }

/* ── 抽屉尺寸：图片抽屉需要更高 ── */
.img-drawer { max-height: 88vh; }

/* 标题副标签 */
.img-drawer-title-wrap {
  display: flex; flex-direction: column; gap: 4rpx;
}
.img-drawer-subtitle {
  font-size: 22rpx; color: var(--text-muted);
}

/* ── 配置区滚动容器 ── */
.img-config-scroll {
  max-height: 65vh;
  padding: 0 32rpx;
}

/* Section 标签 */
.img-section-label {
  display: block;
  font-size: 24rpx; font-weight: 700; color: var(--text-secondary);
  margin-bottom: 16rpx;
}

/* ── 风格横向滚动 ── */
.img-style-scroll { overflow: hidden; }
.img-style-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding-bottom: 8rpx;
  width: max-content;
}

/* 风格卡片 */
.img-style-card {
  width: 150rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xl);
  padding: 20rpx 16rpx 16rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  position: relative;
  flex-shrink: 0;
}
.img-style-card-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.55);
}
.img-style-emoji { font-size: 40rpx; line-height: 1; }
.img-style-label {
  font-size: 24rpx; font-weight: 700; color: var(--text-primary);
  text-align: center; display: block;
}
.img-style-desc {
  font-size: 20rpx; color: var(--text-muted); text-align: center; display: block;
}
.img-style-check {
  position: absolute; top: 10rpx; right: 10rpx;
  width: 32rpx; height: 32rpx; border-radius: var(--r-full);
  background: var(--gold-main);
  font-size: 20rpx; color: var(--bg-base); font-weight: 900;
  display: flex; align-items: center; justify-content: center;
}

/* ── 自定义提示词输入 ── */
.img-custom-input {
  width: 100%; min-height: 80rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md);
  padding: 20rpx 24rpx;
  font-size: 26rpx; color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}
.img-custom-ph { color: var(--text-disabled); font-size: 26rpx; }

/* ── 生成按钮 ── */
.img-gen-btn {
  display: flex; flex-direction: row;
  align-items: center; justify-content: center;
  gap: 12rpx;
  margin-top: 32rpx;
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  border-radius: var(--r-lg);
  padding: 28rpx 0;
  box-shadow: var(--shadow-gold);
}
.img-gen-btn-icon  { font-size: 30rpx; color: var(--bg-base); }
.img-gen-btn-label { font-size: 30rpx; font-weight: 700; color: var(--bg-base); }

/* ── 生成中 loading ── */
.img-loading-wrap {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80rpx 40rpx 60rpx;
  gap: 24rpx;
}
.img-loading-dots {
  display: flex; flex-direction: row; gap: 14rpx; align-items: center;
}
.img-ld {
  width: 16rpx; height: 16rpx; border-radius: var(--r-full);
  background: var(--gold-main);
  animation: imgBounce 1.4s ease-in-out infinite;
}
.img-ld-1 { animation-delay: 0s;    }
.img-ld-2 { animation-delay: 0.2s;  }
.img-ld-3 { animation-delay: 0.4s;  }
.img-loading-step {
  font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; text-align: center;
}
.img-loading-hint {
  font-size: 22rpx; color: var(--text-muted); display: block; text-align: center;
}

/* ── 完成预览 ── */
.img-done-wrap {
  display: flex; flex-direction: column;
  align-items: center; gap: 20rpx;
  padding: 0 32rpx;
}
.img-preview {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: var(--r-xl);
  background: var(--bg-raised);
  display: block;
}
.img-prompt-chip {
  width: 100%;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: 14rpx 20rpx;
  display: flex; flex-direction: row; gap: 8rpx; align-items: flex-start;
}
.img-prompt-label { font-size: 22rpx; color: var(--text-muted); flex-shrink: 0; }
.img-prompt-text  { font-size: 22rpx; color: var(--text-secondary); line-height: 1.5; flex: 1; }

.img-done-actions {
  width: 100%;
  display: flex; flex-direction: row; gap: 16rpx;
}
.img-done-btn {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0;
  border-radius: var(--r-lg);
  font-size: 26rpx; font-weight: 600;
}
.img-done-save {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  color: var(--bg-base);
  box-shadow: var(--shadow-gold);
}
.img-done-save text { color: var(--bg-base); font-weight: 700; }
.img-done-retry {
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  color: var(--text-secondary);
}
.img-done-retry text { color: var(--text-secondary); }

/* ── 错误态 ── */
.img-error-wrap {
  display: flex; flex-direction: column;
  align-items: center; gap: 20rpx;
  padding: 60rpx 40rpx 40rpx;
}
.img-error-icon { font-size: 64rpx; }
.img-error-msg  { font-size: 26rpx; color: var(--text-secondary); text-align: center; line-height: 1.6; display: block; }
.img-error-retry {
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-md);
  padding: 18rpx 48rpx;
  font-size: 26rpx; color: var(--gold-main); font-weight: 600;
}

/* ════════════════════════════════════════
   封面图展示：配方卡片 + 合集卡片
   ════════════════════════════════════════ */

/* ── 配方卡片封面图 ── */
.rc-cover-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
  border-radius: 20rpx 20rpx 0 0;
  margin-bottom: -4rpx;   /* 与 rc-top 无缝衔接 */
}
.rc-cover {
  width: 100%;
  height: 100%;
  display: block;
}
/* 底部渐变遮罩，防止文字被图片淹没 */
.rc-cover-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, transparent 0%, rgba(13,14,18,0.6) 50%, rgba(13,14,18,0.92) 100%);
}
/* 封面上叠加 emoji + 名称 */
.rc-cover-meta {
  position: absolute;
  bottom: 20rpx; left: 24rpx; right: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}
.rc-cover-emoji { font-size: 36rpx; flex-shrink: 0; }
.rc-cover-name  {
  font-size: 30rpx; font-weight: 700; color: var(--text-primary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
  text-shadow: 0 1rpx 8rpx rgba(0,0,0,0.5);
}

/* ── 合集封面图 ── */
.coll-cover-wrap {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
  border-radius: 20rpx 20rpx 0 0;
}
.coll-cover {
  width: 100%;
  height: 100%;
  display: block;
}
.coll-cover-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 160rpx;
  background: linear-gradient(to bottom, transparent 0%, rgba(13,14,18,0.55) 45%, rgba(13,14,18,0.9) 100%);
}

/* ── 图片生成抽屉：「已有封面」提示条 ── */
.img-existing-hint {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  background: rgba(76,175,132,0.08);
  border: 1.5rpx solid rgba(76,175,132,0.22);
  border-radius: var(--r-md);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.img-existing-thumb {
  width: 72rpx; height: 72rpx;
  border-radius: var(--r-xs);
  flex-shrink: 0;
}
.img-existing-tip {
  font-size: 24rpx; color: var(--clr-success); line-height: 1.5; flex: 1;
}

/* ════════════════════════════════════════
   历史图列表（图片抽屉内）
   ════════════════════════════════════════ */

.img-history-section {
  margin-bottom: 28rpx;
}
.img-history-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16rpx;
}
.img-history-count { font-size: 22rpx; color: var(--text-muted); }

.img-history-scroll { overflow: hidden; }
.img-history-row {
  display: flex; flex-direction: row;
  gap: 14rpx;
  padding-bottom: 4rpx;
  width: max-content;
}

/* 单张缩略图容器 */
.img-history-thumb-wrap {
  position: relative;
  width: 160rpx; height: 160rpx;
  border-radius: var(--r-md);
  overflow: hidden;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}
.img-history-thumb-cover {
  border-color: var(--gold-main);
}
.img-history-thumb {
  width: 100%; height: 100%; display: block;
}
.img-history-loading {
  background: var(--bg-raised);
  display: flex; align-items: center; justify-content: center;
}
.img-history-loading-txt { font-size: 28rpx; color: var(--text-disabled); }

/* 封面标签 */
.img-history-cover-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  background: var(--gold-main); color: var(--bg-base);
  font-size: 18rpx; font-weight: 700;
  border-radius: var(--r-xs); padding: 3rpx 10rpx;
}

/* 操作遮罩：半透明常驻底部 */
.img-history-actions {
  position: absolute; bottom: 0; left: 0; right: 0;
  display: flex; flex-direction: row;
  background: rgba(12,13,16,0.65);
  padding: 6rpx 0;
}
.img-history-act {
  flex: 1; text-align: center;
  font-size: 20rpx; color: var(--text-primary);
  padding: 6rpx 0;
}
.img-history-del { color: var(--clr-danger); }

/* ════════════════════════════════════════
   发现页 — 云端公开配方
   ════════════════════════════════════════ */

/* 发现页外层容器（不用 scroll-view 包裹，因为内部 scroll-view 自己管滚动）*/
.discover-wrap,
.mine-wrap,
.fav-wrap {
  display: flex;
  flex-direction: column;
}

/* ── 粘性子栏头（过滤、搜索、子Tab）── */
.discover-sticky-hd,
.mine-sticky-hd,
.fav-sticky-hd {
  position: sticky;
  top: 88rpx;   /* 顶部 Tab 栏高度（约88rpx）*/
  z-index: 8;
  background: var(--bg-base);
}

/* ── 搜索栏 ── */
.discover-search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 0 24rpx 16rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 0 20rpx;
  height: 84rpx;
  flex-shrink: 0;
}

/* ── 发现页 loading 三点 ── */
.discover-loading {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}
.disc-dot {
  width: 16rpx; height: 16rpx;
  border-radius: var(--r-full);
  background: var(--gold-main);
  animation: imgBounce 1.4s ease-in-out infinite;
}
.disc-dot-1 { animation-delay: 0s; }
.disc-dot-2 { animation-delay: 0.2s; }
.disc-dot-3 { animation-delay: 0.4s; }

/* ── 发现卡片 ── */
.discover-card {
  padding: 20rpx 24rpx 18rpx;
  overflow: hidden;
  position: relative;
}

/* 作者行 */
.discover-author-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
}
.discover-author-name {
  font-size: 21rpx;
  color: var(--text-muted);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 3rpx 14rpx;
}
.discover-time { font-size: 19rpx; color: var(--text-disabled); margin-left: auto; }

/* 标签行 */
.discover-tags-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 10rpx 0 4rpx;
}
.discover-tag-chip {
  background: rgba(92,143,214,0.08);
  border: 1.5rpx solid rgba(92,143,214,0.22);
  border-radius: var(--r-full);
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  color: var(--clr-blue);
  letter-spacing: 0.3rpx;
}

/* 点赞按钮（卡片右上角） */
.discover-like {
  font-size: 30rpx;
  display: flex;
  flex-direction: row;
  /* align-items: center; */
  gap: 10rpx;
  padding: 8rpx 10rpx;
  border-radius: var(--r-md);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  min-width: 64rpx;
  flex-shrink: 0;
  transition: background var(--dur-fast) var(--ease-smooth),
              border-color var(--dur-fast) var(--ease-smooth);
}
.discover-like-icon  { font-size: 30rpx; color: var(--text-muted); line-height: 1; }
.discover-like-count { font-size: 19rpx; color: var(--text-muted); }
.discover-like-on {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.25);
}
.discover-like-on .discover-like-icon  { color: var(--clr-danger); }
.discover-like-on .discover-like-count { color: var(--clr-danger); }

/* 详情里的点赞按钮：未点赞时继承默认样式，已点赞时红色 */
.discover-like-on.discover-like-action {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.28);
  color: var(--clr-danger);
}
.discover-like-on.discover-like-action text { color: var(--clr-danger); }

/* 加载更多 */
.discover-load-more {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}
.discover-load-txt { font-size: 24rpx; color: var(--text-disabled); }

.load-more-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 22rpx 0;
  border-radius: var(--r-lg);
  border: 1.5rpx solid var(--gold-border);
  background: var(--gold-tint);
}
.load-more-txt {
  font-size: 26rpx;
  color: var(--gold-main);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* ════════════════════════════════════════
   「我的」Tab — 发布按钮
   ════════════════════════════════════════ */

.detail-action-publish {
  background: rgba(92,143,214,0.08);
  border-color: rgba(92,143,214,0.28);
  color: var(--clr-blue);
}
.detail-action-publish text { color: var(--clr-blue); }

.detail-action-published {
  background: rgba(76,175,132,0.08);
  border-color: rgba(76,175,132,0.28);
  color: var(--clr-success);
}
.detail-action-published text { color: var(--clr-success); font-size: 22rpx; }

/* ════════════════════════════════════════
   发布抽屉
   ════════════════════════════════════════ */

.publish-drawer { max-height: 88vh; }

/* 配方预览区 */
.publish-preview {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xl);
  padding: 20rpx;
  margin: 0 32rpx 28rpx;
}
.publish-cover-wrap {
  width: 100rpx; height: 100rpx;
  border-radius: var(--r-sm);
  overflow: hidden;
  flex-shrink: 0;
}
.publish-cover { width: 100%; height: 100%; display: block; }
.publish-info  { display: flex; flex-direction: row; gap: 14rpx; align-items: center; flex: 1; min-width: 0; }
.publish-emoji { font-size: 44rpx; flex-shrink: 0; }
.publish-name  { font-size: 28rpx; font-weight: 700; color: var(--text-primary); display: block; }
.publish-desc  { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx;
                 white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* 标签区 */
.publish-label {
  display: block;
  font-size: 24rpx; font-weight: 700; color: var(--text-secondary);
  margin: 0 32rpx 16rpx;
}
.publish-tag-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}
.publish-tag-chip {
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.publish-tag-on {
  background: rgba(92,143,214,0.12);
  border-color: rgba(92,143,214,0.45);
  color: var(--clr-blue);
}

/* 已选标签行 */
.publish-selected-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
  min-height: 20rpx;
}
.publish-selected-chip {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-xs);
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: var(--gold-main);
}
.publish-chip-del { font-size: 22rpx; color: var(--text-secondary); padding-left: 4rpx; }

/* 自定义标签输入行 */
.publish-input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin: 0 32rpx 28rpx;
}
.publish-custom-input {
  flex: 1;
  height: 72rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md);
  padding: 0 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}
.publish-add-btn {
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  border-radius: var(--r-md);
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--gold-main);
  font-weight: 600;
  white-space: nowrap;
}

/* 禁用态 */
.btn-disabled {
  opacity: 0.45;
}

/* ════════════════════════════════════════
   合集卡片重设计（Step 5a）
   ════════════════════════════════════════ */

/* 封面图叠加标题 */
.coll-cover-title-row {
  position: absolute;
  bottom: 16rpx; left: 20rpx; right: 20rpx;
  display: flex; flex-direction: row; align-items: center; gap: 12rpx;
}
.coll-cover-emoji      { font-size: 40rpx; flex-shrink: 0; }
.coll-cover-name-overlay {
  font-size: 30rpx; font-weight: 700; color: var(--text-primary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* 描述 */
.coll-desc-row { padding: 4rpx 28rpx 0; }
.coll-desc     { font-size: 24rpx; color: var(--text-secondary); line-height: 1.5; display: block; }

/* 合集标签 */
.coll-tags-row {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 10rpx; padding: 10rpx 28rpx 4rpx;
}
.coll-tag-chip {
  background: rgba(92,143,214,0.1);
  border: 1.5rpx solid rgba(92,143,214,0.25);
  border-radius: var(--r-sm); padding: 4rpx 14rpx;
  font-size: 20rpx; color: var(--clr-blue);
}

/* ── 配方缩略横排 ── */
.coll-thumbs-row {
  display: flex; flex-direction: row; gap: 12rpx;
  padding: 10rpx 28rpx 16rpx; overflow: hidden;
}
.coll-thumb-item {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  width: 116rpx; flex-shrink: 0;
}
.coll-thumb-img {
  width: 116rpx; height: 116rpx;
  border-radius: var(--r-md); display: block;
  border: 1.5rpx solid var(--border-sub);
}
.coll-thumb-emoji-wrap {
  width: 116rpx; height: 116rpx;
  border-radius: var(--r-md); background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  display: flex; align-items: center; justify-content: center;
}
.coll-thumb-emoji { font-size: 44rpx; }
.coll-thumb-name  {
  font-size: 19rpx; color: var(--text-muted); text-align: center;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  width: 100%; display: block;
  letter-spacing: 0.2rpx;
}
.coll-thumb-more {
  width: 116rpx; height: 116rpx; border-radius: var(--r-md);
  background: var(--bg-raised); border: 1.5rpx dashed var(--border-mid);
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: var(--text-muted); flex-shrink: 0;
  font-weight: 600;
}

/* 展开区：配方缩略图 */
.coll-rc-thumb {
  width: 64rpx; height: 64rpx;
  border-radius: var(--r-xs); flex-shrink: 0; display: block;
}

/* 发布/撤回按钮行 */
.coll-pub-row { display: flex; padding: 0 0 16rpx; }
.coll-pub-btn {
  flex: 1; text-align: center;
  background: rgba(92,143,214,0.08);
  border: 1.5rpx solid rgba(92,143,214,0.28);
  border-radius: var(--r-md); padding: 16rpx 0;
  font-size: 26rpx; color: var(--clr-blue); font-weight: 600;
}
.coll-pub-btn-on {
  background: rgba(76,175,132,0.08);
  border-color: rgba(76,175,132,0.28);
  color: var(--clr-success);
}
.coll-detail-btn {
  background: var(--gold-tint);
  border-color: var(--gold-border);
  color: var(--gold-main);
}


/* ════════════════════════════════════════
   海报生成抽屉（Step 5b）
   ════════════════════════════════════════ */

.poster-drawer { max-height: 92vh; }

/* 排版配置表单 */
.poster-layout-form {
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-lg); overflow: hidden; margin-bottom: 4rpx;
}
.poster-layout-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 18rpx 20rpx; border-bottom: 1.5rpx solid var(--bg-base);
}
.poster-layout-row:last-child { border-bottom: none; }
.poster-layout-label {
  font-size: 24rpx; color: var(--text-secondary); width: 100rpx; flex-shrink: 0;
}
.poster-layout-input {
  flex: 1; font-size: 26rpx; color: var(--text-primary); background: transparent;
}

/* Canvas 容器 */
.poster-canvas-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 0 32rpx; gap: 16rpx;
}
.poster-canvas {
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: var(--r-md);
  background: var(--bg-raised);
  display: block;
}
.poster-canvas-loading {
  position: absolute;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: var(--text-secondary);
}

/* ════════════════════════════════════════
   发现页：类型切换 + 合集角标（Step 5c）
   ════════════════════════════════════════ */

.discover-type-row {
  display: flex; flex-direction: row;
  margin: 0 24rpx 12rpx; gap: 12rpx;
  flex-shrink: 0;
}
.discover-type-btn {
  flex: 1; text-align: center;
  padding: 14rpx 0;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-sm);
  font-size: 26rpx; color: var(--text-secondary); font-weight: 600;
}
.discover-type-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.45);
  color: var(--gold-main);
}

/* 合集角标 */
.discover-coll-badge {
  position: absolute; top: 12rpx; right: 12rpx; z-index: 2;
  background: rgba(92,143,214,0.85);
  border-radius: var(--r-sm); padding: 4rpx 14rpx;
  font-size: 20rpx; color: #fff; font-weight: 700;
}

/* 配方角标（仅全部视图显示） */
.discover-recipe-badge {
  position: absolute; top: 12rpx; right: 12rpx; z-index: 2;
  background: rgba(201,164,90,0.75);
  border-radius: var(--r-sm); padding: 4rpx 14rpx;
  font-size: 20rpx; color: var(--bg-base); font-weight: 700;
}

/* 配方数量标签 */
.discover-recipe-count {
  font-size: 22rpx; color: var(--gold-main); margin-left: auto;
}

/* ── 发现页子 Tab（配方 / 合集）─────────────────────── */
.discover-sub-tabs {
  display: flex;
  flex-direction: row;
  padding: 12rpx 24rpx 0;
  gap: 0;
  border-bottom: 1.5rpx solid var(--border-sub);
}
.discover-sub-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0 18rpx;
  font-size: 28rpx;
  color: var(--text-muted);
  font-weight: 500;
  position: relative;
}
.discover-sub-tab-on {
  color: var(--text-primary);
  font-weight: 700;
}
.discover-sub-tab-on::after {
  content: '';
  position: absolute;
  bottom: 0; left: 25%; right: 25%;
  height: 3rpx;
  background: linear-gradient(to right, transparent, var(--gold-bright), var(--gold-main), transparent);
  border-radius: var(--r-full);
  box-shadow: 0 0 8rpx rgba(226,184,106,0.45);
}

/* ── 发现页筛选开关按钮 ── */
.discover-filter-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  margin: 10rpx 0 10rpx auto;
  border-radius: var(--r-full);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  flex-shrink: 0;
}
.discover-filter-btn-on {
  border-color: var(--gold-main);
  background: var(--gold-tint);
}
.discover-filter-btn-txt {
  font-size: 22rpx;
  color: var(--text-muted);
}
.discover-filter-btn-on .discover-filter-btn-txt {
  color: var(--gold-main);
}
.discover-filter-arrow {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}
.discover-filter-btn-on .discover-filter-arrow {
  opacity: 1;
}

/* ── 发现页：合集收藏按钮（★/☆）─────────────────── */
.discover-right-actions {
  display: flex; flex-direction: row; align-items: flex-start; gap: 8rpx;
}
.discover-fav-coll {
  font-size: 30rpx; color: var(--text-muted);
  padding: 8rpx 10rpx;
  border-radius: var(--r-md);
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  line-height: 1;
  transition: color var(--dur-fast) var(--ease-smooth),
              background var(--dur-fast) var(--ease-smooth);
}
.discover-fav-coll-on {
  color: var(--gold-main);
  background: var(--gold-tint);
  border-color: var(--gold-border);
}

/* ── 收藏 Tab：分区标题 ──────────────────────────── */
.fav-section-header {
  padding: 24rpx 32rpx 8rpx;
}
.fav-section-title {
  font-size: 22rpx; color: var(--text-muted); font-weight: 600; letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* ── 收藏合集卡片 ─────────────────────────────────── */
.coll-fav-card { padding: 24rpx; }
.coll-fav-header {
  display: flex; flex-direction: row; align-items: center; gap: 16rpx;
  margin-bottom: 10rpx;
}
.coll-fav-emoji { font-size: 40rpx; flex-shrink: 0; }
.coll-fav-meta  { flex: 1; min-width: 0; }
.coll-fav-name  { font-size: 28rpx; color: var(--text-primary); font-weight: 600; margin-right: 10rpx;}
.coll-fav-sub   { font-size: 22rpx; color: var(--text-muted); margin-top: 4rpx; }

/* ── 配方编辑表单：原创/AI标注 ───────────────────── */
.form-label-info {
  display: flex; flex-direction: row; align-items: center;
  gap: 14rpx;
  padding: 0 32rpx 24rpx;
}
.form-label-hint {
  font-size: 22rpx; color: var(--text-muted);
}
.form-toggle-row {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.form-toggle {
  font-size: 24rpx; color: var(--text-muted);
  background: var(--bg-raised); border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-xs); padding: 8rpx 20rpx;
}
.form-toggle-on {
  color: var(--gold-bright); background: var(--gold-tint);
  border-color: var(--gold-border);
}

/* ══ 合集营销图类型选择 ══ */
.coll-mktg-drawer { max-height: 92vh; }

.coll-mktg-type-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.coll-mktg-type-card {
  flex: 1;
  padding: 20rpx 12rpx;
  background: var(--bg-raised);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.coll-mktg-type-on {
  background: var(--gold-tint);
  border-color: rgba(201,164,90,0.4);
}
.coll-mktg-type-emoji { font-size: 36rpx; line-height: 1; }
.coll-mktg-type-label { font-size: 26rpx; color: var(--text-primary); font-weight: 600; }
.coll-mktg-type-desc  { font-size: 20rpx; color: var(--text-secondary); }
