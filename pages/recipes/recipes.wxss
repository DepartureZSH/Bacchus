/* pages/recipes/recipes.wxss */

.recipes-page { background: #0d0e12; min-height: 100vh; }

/* ── 搜索 ── */
.search-bar { padding: 20rpx 32rpx 12rpx; }
.search-wrap { position: relative; }
.search-icon {
  position: absolute; left: 24rpx; top: 50%; margin-top: -20rpx;
  font-size: 28rpx; z-index: 1; line-height: 1;
}
.search-input {
  display: inline-table;
  width: 100%; background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 24rpx; padding: 20rpx 24rpx 20rpx 68rpx;
  color: #f0ede8; font-size: 28rpx; box-sizing: border-box;
}
.search-placeholder { color: #5c5b65; }

/* ── 筛选 ── */
.filter-scroll { width: 100%; }
.filter-scroll-2 { margin-top: 0; }
.filter-row {
  display: flex; flex-direction: row;
  gap: 14rpx; padding: 10rpx 32rpx 14rpx;
}
.filter-chip {
  flex-shrink: 0; padding: 12rpx 28rpx;
  border-radius: 40rpx; font-size: 26rpx; font-weight: 500;
  border: 2rpx solid #2a2d38; color: #9a98a0; background: #16181f;
  white-space: nowrap;
}
.filter-chip-sm { padding: 10rpx 22rpx; font-size: 24rpx; }
.filter-chip-active {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.4); color: #c9a96e;
}

/* ── 结果数 ── */
.result-hint { padding: 6rpx 32rpx 16rpx; }
.result-text { font-size: 22rpx; color: #5c5b65; }

/* ── 配方卡 ── */
.recipe-list { padding: 0 32rpx; }

.recipe-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  overflow: hidden;
}

.card-header {
  display: flex; flex-direction: row; align-items: center; gap: 20rpx;
  margin-bottom: 16rpx;
}
.card-emoji { font-size: 56rpx; flex-shrink: 0; line-height: 1; }
.card-meta  { flex: 1; display: flex; flex-direction: column; gap: 10rpx; min-width: 0; }
.card-name  { font-size: 32rpx; font-weight: 700; color: #f0ede8; display: block; }
.card-tags  { display: flex; flex-direction: row; gap: 10rpx; flex-wrap: wrap; }

.tag {
  padding: 4rpx 14rpx; border-radius: 8rpx;
  font-size: 20rpx; font-weight: 600;
}
.tag-base  { background: rgba(201,169,110,0.12); color: #c9a96e; }
.tag-style { background: rgba(154,152,160,0.12); color: #9a98a0; }
.tag-zero  { background: rgba(76,175,132,0.12);  color: #4caf84; }

.card-abv { text-align: center; flex-shrink: 0; }
.abv-num  { font-size: 36rpx; font-weight: 800; color: #f0ede8; display: block; line-height: 1; }
.abv-unit { font-size: 20rpx; color: #5c5b65; display: block; }

.card-desc {
  font-size: 24rpx; color: #9a98a0; line-height: 1.7;
  display: block; margin-bottom: 18rpx;
}

/* 原料预览胶囊 */
.card-ings { display: flex; flex-direction: row; flex-wrap: wrap; gap: 10rpx; }
.ing-pill {
  padding: 6rpx 18rpx; border-radius: 40rpx;
  font-size: 22rpx; color: #9a98a0;
  background: #1e2029; border: 2rpx solid #2a2d38;
}
.ing-pill-more { color: #c9a96e; border-color: rgba(201,169,110,0.3); }

/* ── 展开详情 ── */
.card-detail { margin-top: 20rpx; }

.detail-divider { height: 2rpx; background: #2a2d38; margin-bottom: 20rpx; }

.detail-section-title {
  font-size: 24rpx; font-weight: 700; color: #9a98a0;
  display: block; margin-bottom: 14rpx; letter-spacing: 1rpx;
}

.detail-ing-list { display: flex; flex-direction: column; gap: 12rpx; }
.detail-ing-row  {
  display: flex; flex-direction: row; align-items: center; gap: 14rpx;
}
.detail-ing-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: #c9a96e; flex-shrink: 0;
}
.detail-ing-name   { flex: 1; font-size: 26rpx; color: #f0ede8; }
.detail-ing-amount { font-size: 24rpx; color: #9a98a0; flex-shrink: 0; }

.step-row {
  display: flex; flex-direction: row; align-items: flex-start;
  gap: 16rpx; margin-bottom: 14rpx;
}
.step-num {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: #1e2029; border: 2rpx solid #2a2d38;
  display: flex; flex-direction: row; align-items: center; justify-content: center;
  font-size: 22rpx; color: #c9a96e; font-weight: 700; flex-shrink: 0;
}
.step-text { font-size: 26rpx; color: #f0ede8; line-height: 1.6; padding-top: 4rpx; }

.notes-box {
  background: rgba(76,175,132,0.06); border: 2rpx solid rgba(76,175,132,0.2);
  border-radius: 16rpx; padding: 16rpx 20rpx; margin: 16rpx 0;
}
.notes-text { font-size: 24rpx; color: #4caf84; line-height: 1.6; }

.difficulty-row {
  display: flex; flex-direction: row; align-items: center; gap: 14rpx; margin-top: 16rpx;
}
.difficulty-label { font-size: 24rpx; color: #5c5b65; }
.difficulty-dots  { display: flex; flex-direction: row; gap: 8rpx; }
.diff-dot {
  width: 20rpx; height: 20rpx; border-radius: 50%;
  background: #2a2d38;
}
.diff-dot-on { background: #c9a96e; }
.difficulty-text { font-size: 24rpx; color: #9a98a0; }

/* ── 展开按钮 ── */
.card-toggle {
  margin-top: 20rpx; padding-top: 16rpx;
  border-top: 2rpx solid #2a2d38; text-align: center;
}
.card-toggle-text { font-size: 24rpx; color: #c9a96e; }

/* ── 空状态 ── */
.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 16rpx;
}
.empty-icon  { font-size: 80rpx; display: block; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #f0ede8; display: block; }
.empty-sub   { font-size: 24rpx; color: #5c5b65; display: block; }
