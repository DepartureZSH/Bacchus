/* pages/export/export.wxss */
.export-scroll { height: 100vh; background: var(--bg-base); }

/* ── Section label ── */
.section-label {
  font-size: 20rpx; font-weight: 700; color: var(--text-disabled);
  letter-spacing: 3rpx; text-transform: uppercase;
  padding: 20rpx var(--page-x) 12rpx; display: block;
}

/* ── 类型选择 ── */
.type-list { padding: 0 var(--page-x); display: flex; flex-direction: column; gap: 12rpx; }

.type-card {
  display: flex; flex-direction: row; align-items: center;
  padding: 24rpx 28rpx; gap: 20rpx;
}
.type-card-active {
  border-color: var(--gold-border) !important;
  background: var(--gold-tint);
}
.type-card-left {
  flex: 1; display: flex; flex-direction: row; align-items: center; gap: 20rpx;
}
.type-icon  { font-size: 44rpx; flex-shrink: 0; line-height: 1; }
.type-info  { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.type-name  { font-size: 28rpx; font-weight: 600; color: var(--text-primary); display: block; }
.type-desc  { font-size: 22rpx; color: var(--text-muted); display: block; }

.type-radio {
  width: 36rpx; height: 36rpx; border-radius: var(--r-full);
  border: 2rpx solid var(--border-mid); flex-shrink: 0;
  display: flex; flex-direction: row; align-items: center; justify-content: center;
}
.type-radio-on  { border-color: var(--gold-main); background: var(--gold-tint); }
.type-radio-dot { width: 18rpx; height: 18rpx; border-radius: var(--r-full); background: var(--gold-main); }

/* ── 数据预览卡 ── */
.preview-card { margin: 0 var(--page-x) 24rpx; padding: 24rpx; overflow: scroll; }

.preview-header {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; margin-bottom: 16rpx;
}
.preview-title { font-size: 26rpx; font-weight: 700; color: var(--text-primary); }
.preview-count { font-size: 22rpx; color: var(--text-secondary); }

/* ──
   表格核心：用 width:N% 给每列分配精确宽度
   行内 view 不能用 flex:N（小程序 flex 对百分比支持不稳定）
   改用 style="width:X%" + overflow:hidden + text-overflow:ellipsis
── */
.table-head {
  display: flex; flex-direction: row;
  background: var(--bg-raised);
  border-radius: var(--r-sm) var(--r-sm) 0 0;
  padding: 14rpx 0;
  width: 150%;
}

.th {
  display: flex; flex-direction: row; align-items: center;
  padding: 0 8rpx; overflow: hidden; flex-shrink: 0;
}
.th-text {
  font-size: 20rpx; font-weight: 700; color: var(--text-secondary);
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.table-row {
  display: flex; flex-direction: row;
  border-bottom: 1.5rpx solid var(--border-sub);
  padding: 14rpx 0;
  width: 150%;
}
.table-row-alt { background: var(--bg-raised); }

.td {
  padding: 0 8rpx; overflow: hidden; flex-shrink: 0;
}
.td-right { justify-content: flex-end; }
.td-text {
  font-size: 22rpx; color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.table-more {
  padding: 14rpx 8rpx 0;
  font-size: 22rpx; color: var(--text-muted);
}

/* ── 导出方式 2×2 ── */
.action-grid {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 16rpx; padding: 0 var(--page-x);
}

.action-card {
  width: calc(50% - 8rpx);
  padding: 28rpx 24rpx; box-sizing: border-box;
  display: flex; flex-direction: column; align-items: flex-start; gap: 8rpx;
  position: relative; overflow: hidden;
}
.action-icon { font-size: 44rpx; line-height: 1; }
.action-name { font-size: 26rpx; font-weight: 700; color: var(--text-primary); display: block; }
.action-desc { font-size: 20rpx; color: var(--text-secondary); display: block; line-height: 1.5; }

.action-card-locked { opacity: 0.5; }
.lock-badge {
  position: absolute; top: 16rpx; right: 16rpx;
  background: linear-gradient(135deg, var(--gold-bright), var(--gold-dim));
  color: var(--bg-base); border-radius: var(--r-full);
  padding: 4rpx 14rpx; font-size: 20rpx; font-weight: 700;
}

/* ── 导出历史 ── */
.history-card { margin: 0 var(--page-x) 20rpx; overflow: hidden; }
.history-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 20rpx 28rpx; gap: 16rpx;
}
.history-row-border { border-bottom: 1.5rpx solid var(--border-sub); }
.history-icon { font-size: 32rpx; flex-shrink: 0; }
.history-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.history-name { font-size: 26rpx; font-weight: 600; color: var(--text-primary); display: block; }
.history-time { font-size: 22rpx; color: var(--text-muted); display: block; }
