/* pages/ai-edit/ai-edit.wxss */

page { background: #0d0e12; }

.page-root {
  min-height: 100vh;
  background: #0d0e12;
  display: flex;
  flex-direction: column;
}

/* ── 目标标题栏 ────────────────────────────────────────── */
.ae-target-bar {
  display: flex; flex-direction: row; align-items: center;
  gap: 12rpx; padding: 24rpx 32rpx 16rpx;
  background: #16181f;
  border-bottom: 2rpx solid #1e2029;
}
.ae-target-emoji { font-size: 36rpx; }
.ae-target-name  {
  flex: 1; font-size: 28rpx; font-weight: 700;
  color: #f0ede8; overflow: hidden;
  white-space: nowrap; text-overflow: ellipsis;
}
.ae-target-type {
  font-size: 20rpx; color: #9a98a0;
  background: #1e2029; border-radius: 10rpx;
  padding: 4rpx 14rpx; flex-shrink: 0;
}

/* ── 滚动容器 ────────────────────────────────────────────── */
.ae-scroll {
  flex: 1;
  height: 0;
}

/* ══ 图片展示区 ══════════════════════════════════════════ */
.ae-img-section {
  padding: 24rpx 28rpx 8rpx;
  display: flex; flex-direction: column; gap: 16rpx;
}

/* 加载中 */
.ae-loading-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 60rpx 40rpx; gap: 20rpx;
}
.ae-loading-dots { display: flex; flex-direction: row; gap: 14rpx; align-items: center; }
.ae-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #c9a96e; animation: aeBounce 1.4s ease-in-out infinite;
}
.ae-dot-1 { animation-delay: 0s; }
.ae-dot-2 { animation-delay: 0.2s; }
.ae-dot-3 { animation-delay: 0.4s; }
@keyframes aeBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%           { transform: scale(1.2); opacity: 1; }
}
.ae-loading-step { font-size: 28rpx; font-weight: 600; color: #f0ede8; text-align: center; display: block; }
.ae-loading-hint { font-size: 22rpx; color: #5c5b65; text-align: center; display: block; }

/* 错误 */
.ae-error-wrap  { display: flex; flex-direction: column; align-items: center; gap: 20rpx; padding: 60rpx 40rpx; }
.ae-error-icon  { font-size: 64rpx; }
.ae-error-msg   { font-size: 26rpx; color: #9a98a0; text-align: center; line-height: 1.6; display: block; }
.ae-error-retry {
  background: rgba(201,169,110,0.1); border: 2rpx solid rgba(201,169,110,0.35);
  border-radius: 16rpx; padding: 18rpx 48rpx;
  font-size: 26rpx; color: #c9a96e; font-weight: 600;
}

/* 空态 */
.ae-empty {
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx; padding: 60rpx 40rpx;
}
.ae-empty-icon { font-size: 72rpx; }
.ae-empty-txt  { font-size: 26rpx; color: #5c5b65; text-align: center; display: block; }

/* 图片预览框 */
.ae-img-wrap {
  align-self: center; position: relative;
  /* width: 100%;  */
  border-radius: 20rpx; overflow: hidden;
  aspect-ratio: 1 / 1;
}
.ae-img-wrap-poster { aspect-ratio: 3 / 4; }
/* .ae-img {
  width: 100%; height: 100%; display: block;
} */
.ae-img-zoom {
  position: absolute; bottom: 16rpx; right: 16rpx;
  display: flex; flex-direction: row; align-items: center; gap: 6rpx;
  background: rgba(0,0,0,0.45); border-radius: 20rpx; padding: 6rpx 16rpx;
}
.ae-img-zoom-icon { font-size: 22rpx; }
.ae-img-zoom-txt  { font-size: 20rpx; color: rgba(255,255,255,0.8); }

/* 大图角标 */
.ae-img-badge {
  position: absolute; top: 12rpx; left: 12rpx;
  background: rgba(201,169,110,0.9); color: #0d0e12;
  font-size: 20rpx; font-weight: 700;
  border-radius: 10rpx; padding: 4rpx 14rpx;
}
.ae-img-badge-poster {
  background: rgba(154,100,214,0.85); color: #fff;
}

/* Canvas（隐藏，仅用于导出） */
.ae-canvas-hidden {
  position: absolute; opacity: 0; pointer-events: none;
  width: 375px; height: 500px;
  top: -9999rpx; left: -9999rpx;
}

/* ── 操作栏 ─────────────────────────────────────────────── */
.ae-action-bar {
  display: flex; flex-direction: row; gap: 12rpx;
}
.ae-action-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 8rpx; padding: 20rpx 0;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 18rpx;
}
.ae-action-btn-on {
  background: rgba(154,100,214,0.1);
  border-color: rgba(154,100,214,0.4);
}
.ae-action-icon  { font-size: 32rpx; color: #9a98a0; }
.ae-action-label { font-size: 20rpx; color: #9a98a0; }

/* 保存 */
.ae-action-btn:nth-child(1) { background: rgba(201,169,110,0.1); border-color: rgba(201,169,110,0.4); }
.ae-action-btn:nth-child(1) .ae-action-icon  { color: #c9a96e; }
.ae-action-btn:nth-child(1) .ae-action-label { color: #c9a96e; }
/* 分享 */
.ae-action-btn:nth-child(2) { background: rgba(92,143,214,0.1); border-color: rgba(92,143,214,0.35); }
.ae-action-btn:nth-child(2) .ae-action-icon  { color: #5c8fd6; }
.ae-action-btn:nth-child(2) .ae-action-label { color: #5c8fd6; }

/* ══ 编辑面板 ════════════════════════════════════════════ */
.ae-edit-panel {
  margin: 0 28rpx 16rpx;
  padding: 28rpx;
  background: #16181f;
  border-radius: 20rpx;
  border: 2rpx solid #1e2029;
  display: flex; flex-direction: column; gap: 0;
}
.ae-panel-title {
  font-size: 26rpx; font-weight: 700; color: #f0ede8;
  display: block; margin-bottom: 6rpx;
}
.ae-panel-hint {
  font-size: 20rpx; color: #5c5b65;
  display: block; margin-bottom: 20rpx;
}
.ae-section-label {
  font-size: 22rpx; color: #9a98a0;
  display: block; margin: 20rpx 0 10rpx;
}

/* 风格快选 */
.ae-style-row {
  display: flex; flex-direction: row; flex-wrap: wrap; gap: 12rpx;
}
.ae-style-chip {
  padding: 10rpx 20rpx; border-radius: 20rpx;
  background: #1e2029; border: 2rpx solid #2a2d38;
  font-size: 22rpx; color: #9a98a0; font-weight: 500;
}
.ae-style-chip-on {
  background: rgba(201,169,110,0.12);
  border-color: rgba(201,169,110,0.45); color: #c9a96e;
}

/* 文字字段行 */
.ae-field-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 16rpx 0; border-bottom: 2rpx solid #1e2029;
}
.ae-field-label { font-size: 24rpx; color: #9a98a0; width: 96rpx; flex-shrink: 0; }
.ae-field-input { flex: 1; font-size: 26rpx; color: #f0ede8; background: transparent; }

/* 酒款列表 */
.ae-cocktail-row  {
  display: flex; flex-direction: row; align-items: center;
  gap: 12rpx; padding: 10rpx 0; border-bottom: 2rpx solid #1e2029;
}
.ae-cocktail-num   { font-size: 22rpx; color: #5c5b65; width: 28rpx; flex-shrink: 0; }
.ae-cocktail-name  { flex: 1; font-size: 24rpx; color: #f0ede8; background: transparent; }
.ae-cocktail-price { width: 100rpx; font-size: 24rpx; color: #c9a96e; background: transparent; text-align: right; }

/* 补充描述输入框 */
.ae-custom-input {
  width: 100%; min-height: 80rpx;
  background: #1e2029; border: 2rpx solid #2a2d38;
  border-radius: 14rpx; padding: 18rpx 20rpx;
  font-size: 26rpx; color: #f0ede8; box-sizing: border-box;
  margin-top: 4rpx;
}
.ae-custom-ph { color: #5c5b65; }

/* 重新生成按钮 */
.ae-regen-btn {
  margin-top: 24rpx;
  background: rgba(201,169,110,0.1);
  border: 2rpx solid rgba(201,169,110,0.4);
  border-radius: 18rpx; padding: 22rpx 0;
  display: flex; flex-direction: row; align-items: center;
  justify-content: center; gap: 10rpx;
}
.ae-regen-disabled { opacity: 0.45; }
.ae-regen-icon  { font-size: 30rpx; color: #c9a96e; }
.ae-regen-label { font-size: 28rpx; font-weight: 700; color: #c9a96e; }

/* ══ 历史图片 ════════════════════════════════════════════ */
.ae-history-section {
  padding: 16rpx 28rpx 0;
}
.ae-history-header {
  display: flex; flex-direction: row; align-items: center;
  justify-content: space-between; margin-bottom: 16rpx;
}
.ae-history-title { font-size: 26rpx; font-weight: 600; color: #f0ede8; }
.ae-history-loading-txt { font-size: 22rpx; color: #5c5b65; }

.ae-history-empty { padding: 16rpx 0; }
.ae-history-empty text { font-size: 24rpx; color: #5c5b65; }

.ae-history-scroll { width: 100%; }
.ae-history-row {
  display: flex; flex-direction: column; gap: 20rpx; width: 100%;
}

.ae-history-item {
  width: 100%; display: flex; flex-direction: column;
  align-items: center; gap: 8rpx;
}

.ae-history-img-wrap {
  width: 100%; position: relative;
  border-radius: 16rpx;
}
.ae-history-item-on .ae-history-img-wrap {
  outline: 3rpx solid #c9a96e;
}
.ae-history-item-cover .ae-history-img-wrap {
  outline: 3rpx solid rgba(201,169,110,0.6);
}

.ae-history-img {
  width: 100%; border-radius: 16rpx;
  border: 2rpx solid #2a2d38;
  display: block;
}
.ae-history-img-poster { }

.ae-history-loading {
  height: 200rpx;
  display: flex; align-items: center; justify-content: center;
  background: #1e2029; border-radius: 16rpx;
}
.ae-history-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #c9a96e; opacity: 0.5;
  animation: aeBounce 1.4s ease-in-out infinite;
}

/* 角标 */
.ae-history-badge {
  position: absolute; top: 8rpx; left: 8rpx;
  background: rgba(201,169,110,0.9); color: #0d0e12;
  font-size: 18rpx; font-weight: 700;
  border-radius: 8rpx; padding: 3rpx 10rpx;
}
.ae-history-badge-poster {
  background: rgba(154,100,214,0.85); color: #fff;
}

/* 当前选中指示器 */
.ae-history-selected-mark {
  position: absolute; bottom: 8rpx; right: 8rpx;
  background: #c9a96e; color: #0d0e12;
  font-size: 20rpx; font-weight: 900;
  border-radius: 50%; width: 36rpx; height: 36rpx;
  display: flex; align-items: center; justify-content: center;
}

/* 风格标签 */
.ae-history-style {
  font-size: 20rpx; color: #5c5b65;
  text-align: center; display: block;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  width: 100%;
}

/* 操作行 */
.ae-history-actions {
  display: flex; flex-direction: row; gap: 8rpx; width: 100%;
}
.ae-history-act {
  flex: 1; text-align: center; font-size: 20rpx; font-weight: 600;
  padding: 10rpx 0; border-radius: 10rpx;
  border: 2rpx solid #2a2d38; background: #1e2029; color: #9a98a0;
}
.ae-history-act-cover {
  background: rgba(201,169,110,0.1);
  border-color: rgba(201,169,110,0.35); color: #c9a96e;
}
.ae-history-act-save {
  background: rgba(92,143,214,0.1);
  border-color: rgba(92,143,214,0.3); color: #5c8fd6;
}
.ae-history-act-del {
  background: rgba(224,92,92,0.08);
  border-color: rgba(224,92,92,0.25); color: #e05c5c;
}
