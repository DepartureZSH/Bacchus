/* app.wxss — 全局设计系统（Velvet Speakeasy）*/
/* ── CSS 变量写在 page {} 中，小程序子元素可继承 ── */

page {
  /* ══ 背景层（暖黑三层）══ */
  --bg-base:    #0c0d10;
  --bg-surface: #15171e;
  --bg-raised:  #1d1f28;
  --bg-overlay: #252838;

  /* ══ 边框 ══ */
  --border-sub: rgba(255,255,255,0.05);
  --border-mid: rgba(255,255,255,0.09);
  --border-str: rgba(255,255,255,0.18);

  /* ══ 文字 ══ */
  --text-primary:   #f2efe9;
  --text-secondary: #9a98a2;
  --text-muted:     #5e5d68;
  --text-disabled:  #3a3944;

  /* ══ 金铜主色（Amber Copper）══ */
  --gold-bright: #e2b86a;
  --gold-main:   #c9a45a;
  --gold-dim:    #9a7a3e;
  --gold-tint:   rgba(201,164,90,0.10);
  --gold-border: rgba(201,164,90,0.30);

  /* ══ 语义色 ══ */
  --clr-success: #4caf84;
  --clr-danger:  #e05c5c;
  --clr-warn:    #e09a3a;
  --clr-ai:      #8fa8f8;
  --clr-blue:    #5c8fd6;

  /* ══ 阴影 ══ */
  --shadow-card:   0 2rpx 20rpx rgba(0,0,0,0.4);
  --shadow-raised: 0 4rpx 32rpx rgba(0,0,0,0.5);
  --shadow-gold:   0 4rpx 20rpx rgba(201,164,90,0.22);

  /* ══ 圆角（7 级）══ */
  --r-xs:   8rpx;
  --r-sm:   14rpx;
  --r-md:   20rpx;
  --r-lg:   28rpx;
  --r-xl:   36rpx;
  --r-2xl:  48rpx;
  --r-full: 9999rpx;

  /* ══ 间距（基准 8rpx）══ */
  --sp-1:  8rpx;
  --sp-2:  16rpx;
  --sp-3:  24rpx;
  --sp-4:  32rpx;
  --sp-5:  40rpx;
  --sp-6:  48rpx;
  --sp-8:  64rpx;
  --page-x: 28rpx;

  /* ══ 动效 ══ */
  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --dur-fast: 150ms;
  --dur-base: 250ms;
  --dur-slow: 360ms;

  /* ── 全局基础 ── */
  background-color: var(--bg-base);
  color: var(--text-primary);
  font-family: "PingFang SC", -apple-system, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  height: 100%;
}

/* ── Reset ── */
view, text, input, button, scroll-view {
  box-sizing: border-box;
}
button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
}
button::after { border: none; }

/* ════════════════════════════════════════════
   通用卡片
   ════════════════════════════════════════════ */
.card {
  background: var(--bg-surface);
  border: 1.5rpx solid var(--border-sub);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-card);
}

/* ════════════════════════════════════════════
   Section Header
   ════════════════════════════════════════════ */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx var(--sp-4) 20rpx;
}
.section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}
.section-link {
  font-size: 24rpx;
  color: var(--gold-main);
}

/* ════════════════════════════════════════════
   按钮
   ════════════════════════════════════════════ */
.btn-primary {
  background: linear-gradient(145deg, var(--gold-bright), var(--gold-dim));
  color: var(--bg-base);
  border-radius: var(--r-full);
  padding: 32rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  letter-spacing: 4rpx;
  display: block;
  width: 100%;
  box-shadow: var(--shadow-gold);
}

.btn-ghost {
  background: var(--bg-raised);
  color: var(--text-secondary);
  border: 1.5rpx solid var(--border-mid);
  border-radius: var(--r-full);
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  display: block;
  width: 100%;
}

/* ════════════════════════════════════════════
   Badge
   ════════════════════════════════════════════ */
.badge {
  display: inline-block;
  border-radius: var(--r-full);
  padding: 4rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.badge-danger {
  background: rgba(224,92,92,0.12);
  color: var(--clr-danger);
  border: 1rpx solid rgba(224,92,92,0.25);
}
.badge-warn {
  background: rgba(224,154,58,0.12);
  color: var(--clr-warn);
  border: 1rpx solid rgba(224,154,58,0.25);
}
.badge-ok {
  background: rgba(76,175,132,0.12);
  color: var(--clr-success);
  border: 1rpx solid rgba(76,175,132,0.25);
}
.badge-accent {
  background: var(--gold-tint);
  color: var(--gold-main);
  border: 1rpx solid var(--gold-border);
}

/* ════════════════════════════════════════════
   步骤（共用 step-row / step-num / step-text）
   ════════════════════════════════════════════ */
.step-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--gold-tint);
  border: 1.5rpx solid var(--gold-border);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--gold-bright);
  font-weight: 700;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.65;
  padding-top: 4rpx;
}

/* ════════════════════════════════════════════
   备注框（共用）
   ════════════════════════════════════════════ */
.notes-box {
  background: rgba(76,175,132,0.06);
  border: 1.5rpx solid rgba(76,175,132,0.22);
  border-radius: var(--r-sm);
  padding: 14rpx 18rpx;
  margin: 14rpx 0;
}
.notes-text {
  font-size: 24rpx;
  color: var(--clr-success);
  line-height: 1.6;
}

/* ════════════════════════════════════════════
   原料行（共用 ing-dot / detail-ing-name）
   ════════════════════════════════════════════ */
.detail-ing-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.ing-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--gold-main);
  flex-shrink: 0;
}
.detail-ing-name { flex: 1; font-size: 26rpx; color: var(--text-primary); }
.detail-ing-amt  { font-size: 24rpx; color: var(--text-secondary); flex-shrink: 0; }

/* ════════════════════════════════════════════
   空态（共用）
   ════════════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 12rpx;
}
.empty-icon { font-size: 60rpx; display: block; }
.empty-tip  { font-size: 26rpx; color: var(--text-muted); display: block; }

.empty-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 40rpx;
  gap: 16rpx;
}
.empty-full-icon  { font-size: 80rpx; display: block; }
.empty-full-title { font-size: 30rpx; font-weight: 700; color: var(--text-primary); display: block; }
.empty-full-sub   {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  text-align: center;
  line-height: 1.7;
}

/* ════════════════════════════════════════════
   Loading 三点（共用）
   ════════════════════════════════════════════ */
@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40%            { transform: scale(1.2); opacity: 1;   }
}
@keyframes imgBounce {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40%           { transform: scale(1.2); opacity: 1;   }
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
